{% comment %}
  TGPCOP NOTES — Premium Pharmacy Product Card
  Based on provided HTML design
{% endcomment %}

<div class="relative bg-white dark:bg-slate-900 rounded-[32px] overflow-hidden shadow-sm hover:shadow-[0_20px_50px_rgba(7,43,107,0.08)] transition-all duration-500 border border-gray-100 dark:border-slate-800 group flex flex-col h-full">
  <!-- Badges -->
  <div class="absolute top-4 left-4 z-10 flex flex-col gap-2">
    {% if product.tags contains 'Bestseller' or product.tags contains 'bestseller' %}
      <span class="bg-blue-600 text-white text-[10px] font-black px-3 py-1.5 rounded-full tracking-widest uppercase shadow-lg">BESTSELLER</span>
    {% endif %}
    {% if product.compare_at_price > product.price %}
      <span class="bg-[#2E9E36] text-white text-[10px] font-black px-3 py-1.5 rounded-full tracking-widest uppercase shadow-lg">SAVE {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</span>
    {% endif %}
  </div>

  <!-- Image Area -->
  <a href="{{ product.url }}" class="aspect-[3/4] bg-[#F5F8FB] dark:bg-slate-800 overflow-hidden block">
    {% if product.featured_image != blank %}
      <img src="{{ product.featured_image | image_url: width: 800 }}" 
           alt="{{ product.title }}" 
           loading="lazy"
           class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000">
    {% else %}
      <div class="w-full h-full flex items-center justify-center bg-slate-100 dark:bg-slate-800">
        <span class="material-symbols-outlined text-6xl text-[#072B6B]/10">auto_stories</span>
      </div>
    {% endif %}
  </a>

  <!-- Content -->
  <div class="p-6 md:p-8 flex flex-col flex-grow">
    <div class="mb-2">
      {%- assign type_tag = '' -%}
      {%- for tag in product.tags -%}
        {%- if tag contains 'B.Pharm' or tag contains 'D.Pharm' or tag contains 'GPAT' -%}
          {%- assign type_tag = tag -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      <span class="text-[#2E9E36] dark:text-[#41C94B] font-black text-[10px] uppercase tracking-widest">{{ type_tag | default: product.type | default: 'Pharmacy Notes' }}</span>
    </div>

    <h3 class="text-lg font-extrabold text-[#072B6B] dark:text-slate-100 mb-2.5 group-hover:text-[#2E9E36] dark:group-hover:text-[#41C94B] transition-colors leading-snug line-clamp-2 min-h-[3rem]">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    <!-- Ratings (Static for aesthetic as per HTML) -->
    <div class="flex items-center gap-1.5 mb-5">
      <div class="flex text-[#FFB800] dark:text-amber-400">
        {% for i in (1..5) %}
          <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
        {% endfor %}
      </div>
      <span class="text-gray-400 dark:text-slate-500 text-xs font-bold">(128+)</span>
    </div>

    <!-- Footer -->
    <div class="mt-auto flex items-center justify-between border-t border-gray-100 dark:border-slate-800 pt-5">
      <div class="flex flex-col">
        <span class="text-xl font-extrabold text-[#072B6B] dark:text-slate-100">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="text-xs text-gray-400 dark:text-slate-500 line-through font-bold">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="flex">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="bg-[#2E9E36]/10 text-[#2E9E36] dark:bg-[#2E9E36]/20 dark:text-[#41C94B] p-3.5 rounded-2xl hover:bg-[#2E9E36] hover:text-white dark:hover:bg-[#2E9E36] dark:hover:text-white hover:scale-105 transition-all shadow-sm">
          <span class="material-symbols-outlined font-bold text-[18px]">add_shopping_cart</span>
        </button>
      </form>
    </div>
  </div>
</div>
