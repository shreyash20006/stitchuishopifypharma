{% comment %}
  TGPCOP NOTES — Premium Ebook Product Card
  4-col desktop | 2-col tablet | 1-col mobile
  object-fit: contain | hover lift | no broken placeholder
{% endcomment %}

<style>
  .tgp-card {
    background: #ffffff;
    border: 1px solid #E8EEF2;
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    transition: transform 0.3s cubic-bezier(.4,0,.2,1),
                box-shadow 0.3s cubic-bezier(.4,0,.2,1),
                border-color 0.3s ease;
  }
  .tgp-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 24px 56px rgba(11,93,59,0.15),
                0 8px 20px rgba(0,0,0,0.08);
    border-color: rgba(11,93,59,0.25);
  }

  /* Image Area */
  .tgp-card__img-wrap {
    display: block;
    width: 100%;
    height: 270px;
    background: linear-gradient(135deg, #F0F7F4 0%, #EBF5F0 100%);
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
    text-decoration: none;
  }
  .tgp-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 16px;
    transition: transform 0.5s cubic-bezier(.4,0,.2,1);
    display: block;
  }
  .tgp-card:hover .tgp-card__img-wrap img {
    transform: scale(1.05);
  }

  /* Placeholder (no image uploaded yet) */
  .tgp-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: linear-gradient(135deg, #E7F5EF 0%, #D1EDE2 100%);
  }
  .tgp-card__placeholder-icon {
    font-size: 52px;
    color: #0B5D3B;
    opacity: 0.3;
  }
  .tgp-card__placeholder-text {
    font-size: 11px;
    font-weight: 700;
    color: #0B5D3B;
    opacity: 0.4;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Badge */
  .tgp-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #0B5D3B;
    color: #ffffff;
    font-size: 9px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 100px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(11,93,59,0.3);
    z-index: 2;
  }

  /* Instant download badge */
  .tgp-card__dl-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    color: #0B5D3B;
    font-size: 9px;
    font-weight: 700;
    padding: 4px 9px;
    border-radius: 8px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: 1px solid rgba(11,93,59,0.2);
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 3px;
  }

  /* Body */
  .tgp-card__body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 14px;
  }

  /* Semester chip */
  .tgp-card__tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tgp-card__tag {
    font-size: 9px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 6px;
    background: #F0F7F4;
    color: #0B5D3B;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Title */
  .tgp-card__title {
    font-family: 'Manrope', 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: #111827;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.625rem;
    flex-grow: 1;
  }
  .tgp-card__title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s ease;
  }
  .tgp-card__title a:hover { color: #0B5D3B; }

  /* Footer */
  .tgp-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid #F0F0F0;
    padding-top: 14px;
    gap: 8px;
    margin-top: auto;
  }
  .tgp-card__price-wrap { display: flex; flex-direction: column; }
  .tgp-card__price-compare {
    font-size: 0.72rem;
    color: #9CA3AF;
    text-decoration: line-through;
    margin-bottom: 1px;
  }
  .tgp-card__price {
    font-family: 'Manrope', 'Inter', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: #0B5D3B;
    line-height: 1;
  }

  /* Cart button */
  .tgp-card__btn {
    background: #0B5D3B;
    color: #ffffff;
    border: none;
    border-radius: 12px;
    width: 44px;
    height: 44px;
    min-width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
    box-shadow: 0 2px 8px rgba(11,93,59,0.25);
  }
  .tgp-card__btn:hover {
    background: #094d31;
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(11,93,59,0.38);
  }
  .tgp-card__btn:active { transform: scale(0.96); }
  .tgp-card__btn .material-symbols-outlined { font-size: 19px; }
</style>

{%- assign sem_tag = '' -%}
{%- for tag in product.tags -%}
  {%- if tag contains 'Sem' or tag contains 'Semester' -%}
    {%- assign sem_tag = tag -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<div class="tgp-card">

  <a href="{{ product.url }}" class="tgp-card__img-wrap" aria-label="{{ product.title | escape }}">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.title | escape }}"
        loading="lazy"
        width="600"
        height="270"
      >
    {%- else -%}
      <div class="tgp-card__placeholder">
        <span class="material-symbols-outlined tgp-card__placeholder-icon">menu_book</span>
        <span class="tgp-card__placeholder-text">Cover Coming Soon</span>
      </div>
    {%- endif -%}
    <span class="tgp-card__badge">PDF Notes</span>
    <span class="tgp-card__dl-badge">
      <span class="material-symbols-outlined" style="font-size:10px;">download</span>
      Instant
    </span>
  </a>

  <div class="tgp-card__body">
    {%- if sem_tag != '' -%}
      <div class="tgp-card__tags">
        <span class="tgp-card__tag">{{ sem_tag }}</span>
      </div>
    {%- endif -%}

    <h3 class="tgp-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    <div class="tgp-card__footer">
      <div class="tgp-card__price-wrap">
        {%- if product.compare_at_price > product.price -%}
          <span class="tgp-card__price-compare">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="tgp-card__price">{{ product.price | money }}</span>
      </div>

      <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        <input type="hidden" name="quantity" value="1">
        <input type="hidden" name="return_to" value="back">
        <button type="submit" class="tgp-card__btn" title="Add to Cart">
          <span class="material-symbols-outlined">add_shopping_cart</span>
        </button>
      </form>
    </div>
  </div>

</div>
