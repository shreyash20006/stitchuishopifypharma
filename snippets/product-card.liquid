<div class="glass-card rounded-2xl overflow-hidden group hover:shadow-lg transition-all duration-300 flex flex-col h-full">
  <a href="{{ product.url }}" class="block relative aspect-[3/4] overflow-hidden bg-surface-container-lowest">
    {% if product.featured_image %}
      <img src="{{ product.featured_image | image_url: width: 800 }}" 
           alt="{{ product.title }}" 
           class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105 p-2">
    {% else %}
      <div class="w-full h-full bg-surface-container-high flex items-center justify-center">
        <span class="material-symbols-outlined text-4xl opacity-20">image</span>
      </div>
    {% endif %}
    
    <div class="absolute top-4 left-4 bg-primary text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest shadow-sm">
      Premium Notes
    </div>
  </a>

  <div class="p-5 flex flex-col flex-grow space-y-4">
    <div class="space-y-1 flex-grow">
      <h3 class="font-bold text-base text-on-surface line-clamp-2 min-h-[3rem]">
        <a href="{{ product.url }}" class="hover:text-primary transition-colors">{{ product.title }}</a>
      </h3>
      <div class="flex items-center gap-1">
        <div class="flex text-tertiary text-[10px]">
          <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>
        <span class="text-[10px] text-on-surface-variant font-medium">(4.9/5)</span>
      </div>
    </div>

    <div class="flex items-center justify-between gap-4 pt-4 border-t border-outline-variant">
      <div class="flex flex-col">
        {%- if product.compare_at_price > product.price -%}
          <span class="text-[10px] text-on-surface-variant line-through opacity-50">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="text-lg font-bold text-primary">{{ product.price | money }}</span>
      </div>
      
      <form action="/cart/add" method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="bg-primary text-white w-10 h-10 rounded-xl flex items-center justify-center hover:bg-primary/90 transition-all shadow-md group-hover:scale-110 active:scale-95">
          <span class="material-symbols-outlined">add_shopping_cart</span>
        </button>
      </form>
    </div>
  </div>
</div>
