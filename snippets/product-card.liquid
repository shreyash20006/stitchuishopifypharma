<div class="relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-outline-variant h-full flex flex-col">
  {%- if product.compare_at_price > product.price -%}
    <div class="absolute top-4 left-4 z-10">
      <span class="bg-tertiary text-white text-[10px] font-bold px-2 py-1 rounded tracking-widest uppercase">SALE</span>
    </div>
  {%- endif -%}
  
  <a href="{{ product.url }}" class="aspect-[3/4] bg-surface-container overflow-hidden block">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}" 
           alt="{{ product.title }}" 
           class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
           loading="lazy">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-surface-container' }}
    {%- endif -%}
  </a>

  <div class="p-6 flex-grow flex flex-col">
    <span class="text-primary font-bold text-[12px]">{{ product.collections.first.title | upcase }}</span>
    <h3 class="font-bold text-[18px] mt-1 mb-2">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    
    <div class="flex items-center gap-2 mb-4">
      <div class="flex text-yellow-500">
        {%- for i in (1..5) -%}
          <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
        {%- endfor -%}
      </div>
      <span class="text-on-surface-variant text-[12px]">(100+)</span>
    </div>

    <div class="mt-auto flex items-center justify-between">
      <div class="flex items-baseline gap-2">
        <span class="font-bold text-xl text-primary">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="text-on-surface-variant line-through text-sm">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
      
      <form method="post" action="/cart/add">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
        <button type="submit" class="bg-primary-container text-on-primary-container p-2 rounded-lg hover:scale-105 transition-transform flex items-center justify-center">
          <span class="material-symbols-outlined">add_shopping_cart</span>
        </button>
      </form>
    </div>
  </div>
</div>
