<!-- TGPCOP NOTES AI STUDY BUDDY WIDGET -->
<div id="tgpcop-ai-widget" class="fixed bottom-6 right-6 z-[9999] font-sans antialiased">
  
  <!-- Floating Launcher Button -->
  <button id="tgpcop-ai-launcher" class="flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-tr from-[#072B6B] to-[#0E4DA4] text-white shadow-2xl hover:scale-105 active:scale-95 transition-all duration-300 relative group overflow-hidden border border-white/20">
    <!-- Pulsing Glow Ring -->
    <span class="absolute inset-0 rounded-full border-2 border-[#2E9E36] animate-ping opacity-35 scale-105"></span>
    <!-- Animated Medical Icon -->
    <div class="relative z-10 flex flex-col items-center">
      <span class="material-symbols-outlined text-3xl group-hover:rotate-12 transition-transform duration-300">smart_toy</span>
      <span class="text-[9px] font-bold text-[#2E9E36] tracking-wider uppercase mt-0.5">AI BOT</span>
    </div>
    <!-- Mini green status bubble -->
    <span class="absolute top-1 right-1 w-3.5 h-3.5 bg-[#2E9E36] border-2 border-white rounded-full"></span>
  </button>

  <!-- Chat Drawer Panel -->
  <div id="tgpcop-ai-panel" class="hidden absolute bottom-20 right-0 w-[380px] sm:w-[420px] max-w-[calc(100vw-2rem)] h-[600px] max-h-[calc(100vh-8rem)] bg-slate-900/95 backdrop-blur-xl border border-slate-800 rounded-2xl shadow-2xl overflow-hidden flex flex-col transition-all duration-300 translate-y-4 opacity-0 z-[10000]">
    
    <!-- Panel Header -->
    <div class="bg-gradient-to-r from-[#072B6B] to-[#0E4DA4] p-4 text-white flex items-center justify-between border-b border-white/10 shrink-0">
      <div class="flex items-center gap-3">
        <div class="relative">
          <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center border border-white/20">
            <span class="material-symbols-outlined text-2xl text-[#2E9E36]">clinical_a_filled</span>
          </div>
          <span class="absolute bottom-0 right-0 w-3 h-3 bg-[#2E9E36] border-2 border-[#072B6B] rounded-full"></span>
        </div>
        <div>
          <h3 class="font-bold text-sm leading-tight tracking-wide flex items-center gap-1.5">
            TGPCOP Study Buddy
          </h3>
          <p class="text-[11px] text-[#2E9E36] font-medium flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-[#2E9E36] inline-block animate-pulse"></span>
            Online GPAT Coach & Store Guide
          </p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button id="tgpcop-ai-settings-toggle" class="p-1.5 rounded-lg hover:bg-white/15 text-slate-300 hover:text-white transition-colors" title="AI Assistant Settings">
          <span class="material-symbols-outlined text-xl">settings</span>
        </button>
        <button id="tgpcop-ai-close-btn" class="p-1.5 rounded-lg hover:bg-white/15 text-slate-300 hover:text-white transition-colors">
          <span class="material-symbols-outlined text-xl">close</span>
        </button>
      </div>
    </div>

    <!-- API Key Settings Screen Overlay -->
    <div id="tgpcop-ai-settings-screen" class="hidden absolute inset-0 bg-slate-950/95 backdrop-blur-md z-30 p-6 flex flex-col justify-between text-slate-200">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-[#2E9E36]">key</span>
          <h4 class="font-bold text-lg">Configure Gemini API Key</h4>
        </div>
        <p class="text-xs text-slate-400 mb-4 leading-relaxed">
          TGPCOP AI operates fully in your browser. Enter a Google Gemini API Key below to start chatting. The key is saved securely in your local browser storage and never shared.
        </p>
        <div class="bg-slate-900 p-3 rounded-lg border border-slate-800 mb-4">
          <a href="https://aistudio.google.com/app/apikey" target="_blank" class="text-xs text-[#2E9E36] hover:underline flex items-center gap-1 font-semibold">
            Get a FREE Gemini API Key from Google <span class="material-symbols-outlined text-xs">open_in_new</span>
          </a>
        </div>
        <div class="space-y-2">
          <label class="text-[11px] font-bold tracking-wider uppercase text-slate-400">Gemini API Key</label>
          <input type="password" id="tgpcop-gemini-key-input" class="w-full bg-slate-800 border border-slate-700 rounded-lg p-2.5 text-xs text-white placeholder-slate-500 focus:outline-none focus:border-[#2E9E36]" placeholder="Paste your API key here (AIzaSy...)">
        </div>
      </div>
      <div class="flex items-center gap-2 mt-4 shrink-0">
        <button id="tgpcop-ai-settings-save" class="flex-1 bg-[#2E9E36] hover:bg-[#41C94B] text-slate-950 font-bold py-2 px-4 rounded-lg text-xs transition-colors">
          Save Settings
        </button>
        <button id="tgpcop-ai-settings-cancel" class="bg-slate-800 hover:bg-slate-700 text-slate-300 py-2 px-4 rounded-lg text-xs transition-colors">
          Back
        </button>
      </div>
    </div>

    <!-- Active Chat Box -->
    <div class="flex-1 flex flex-col min-h-0 bg-gradient-to-b from-slate-900 to-slate-950">
      
      <!-- Welcome Starter Overlay (when key missing) -->
      <div id="tgpcop-ai-setup-prompt" class="hidden absolute inset-0 z-20 bg-slate-950/95 p-6 flex flex-col justify-center items-center text-center">
        <div class="w-16 h-16 rounded-full bg-gradient-to-tr from-[#072B6B] to-[#0E4DA4] flex items-center justify-center border border-white/20 mb-4">
          <span class="material-symbols-outlined text-4xl text-[#2E9E36]">smart_toy</span>
        </div>
        <h4 class="font-bold text-lg text-slate-100 mb-2">Initialize Your Study Buddy</h4>
        <p class="text-xs text-slate-400 max-w-[280px] mb-6 leading-relaxed">
          Unlock an AI assistant capable of solving GPAT questions, summarizing syllabi, and listing study files in real-time.
        </p>
        <button id="tgpcop-ai-setup-btn" class="bg-[#2E9E36] hover:bg-[#41C94B] text-slate-950 font-extrabold px-6 py-3 rounded-xl text-xs transition-all duration-300 shadow-lg shadow-[#2E9E36]/10 flex items-center gap-2">
          <span class="material-symbols-outlined text-base">vpn_key</span>
          Enter Gemini API Key
        </button>
      </div>

      <!-- Messages Area -->
      <div id="tgpcop-ai-messages" class="flex-1 overflow-y-auto p-4 space-y-4 scroll-smooth">
        <!-- AI Greeting -->
        <div class="flex gap-2.5 items-start">
          <div class="w-8 h-8 rounded-full bg-[#072B6B] shrink-0 border border-slate-700 flex items-center justify-center">
            <span class="material-symbols-outlined text-base text-[#2E9E36]">smart_toy</span>
          </div>
          <div class="max-w-[80%] bg-slate-800/80 border border-slate-700/80 rounded-2xl rounded-tl-none p-3 text-slate-200 text-xs leading-relaxed shadow-sm">
            Hello, pharmacy student! 👋 I'm your **TGPCOP AI Study Buddy**. 
            <br><br>
            I can explain pharmacy concepts, give GPAT prep advice, or help you find premium handwritten study notes. What are we studying today?
          </div>
        </div>

        <!-- Suggestion Chips Container -->
        <div id="tgpcop-ai-chips" class="flex flex-wrap gap-1.5 pt-1 pl-10">
          <button class="tgpcop-ai-chip bg-slate-800 hover:bg-slate-700 text-[10px] text-slate-300 border border-slate-700 rounded-full px-3 py-1.5 transition-colors">
            📚 Recommended Notes
          </button>
          <button class="tgpcop-ai-chip bg-slate-800 hover:bg-slate-700 text-[10px] text-slate-300 border border-slate-700 rounded-full px-3 py-1.5 transition-colors">
            🧬 Explan GPAT syllabus
          </button>
          <button class="tgpcop-ai-chip bg-slate-800 hover:bg-slate-700 text-[10px] text-slate-300 border border-slate-700 rounded-full px-3 py-1.5 transition-colors">
            💊 Pharmacology revision tips
          </button>
          <button class="tgpcop-ai-chip bg-slate-800 hover:bg-slate-700 text-[10px] text-slate-300 border border-slate-700 rounded-full px-3 py-1.5 transition-colors">
            🔎 Search B.Pharm notes
          </button>
        </div>
      </div>

      <!-- Typing Indicator -->
      <div id="tgpcop-ai-typing" class="hidden flex gap-2.5 items-center px-4 py-2 text-slate-400 text-[11px]">
        <div class="w-8 h-8 rounded-full bg-[#072B6B] shrink-0 border border-slate-700 flex items-center justify-center">
          <span class="material-symbols-outlined text-base text-[#2E9E36]">smart_toy</span>
        </div>
        <div class="flex items-center gap-1 bg-slate-800/80 border border-slate-700/80 px-3 py-2 rounded-xl">
          <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
          <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
          <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
        </div>
      </div>

      <!-- Input Drawer Area -->
      <div class="p-3 bg-slate-950 border-t border-slate-800 shrink-0">
        <form id="tgpcop-ai-form" class="flex gap-2 items-center">
          <input type="text" id="tgpcop-ai-input" class="flex-1 bg-slate-900 border border-slate-800 rounded-xl px-3 py-2.5 text-xs text-white placeholder-slate-500 focus:outline-none focus:border-[#2E9E36] focus:ring-1 focus:ring-[#2E9E36]/30" placeholder="Ask about GPAT or search notes..." autocomplete="off">
          <button type="submit" id="tgpcop-ai-send" class="w-10 h-10 rounded-xl bg-gradient-to-tr from-[#072B6B] to-[#0E4DA4] text-white hover:scale-105 active:scale-95 transition-all duration-200 flex items-center justify-center shrink-0 border border-white/10 disabled:opacity-50">
            <span class="material-symbols-outlined text-base text-[#2E9E36]">send</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Inline Liquid Product Catalog compiler -->
<script>
  window.tgpcopStoreCatalog = [
    {%- for product in collections.all.products -%}
      {
        title: {{ product.title | json }},
        price: {{ product.price | money | json }},
        url: {{ product.url | json }},
        type: {{ product.type | json }},
        tags: {{ product.tags | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ];
</script>

<!-- Gemini AI Javascript Engine -->
<script>
  (function() {
    const launcher = document.getElementById('tgpcop-ai-launcher');
    const panel = document.getElementById('tgpcop-ai-panel');
    const closeBtn = document.getElementById('tgpcop-ai-close-btn');
    const settingsToggle = document.getElementById('tgpcop-ai-settings-toggle');
    const settingsScreen = document.getElementById('tgpcop-ai-settings-screen');
    const keyInput = document.getElementById('tgpcop-gemini-key-input');
    const settingsSave = document.getElementById('tgpcop-ai-settings-save');
    const settingsCancel = document.getElementById('tgpcop-ai-settings-cancel');
    const setupPrompt = document.getElementById('tgpcop-ai-setup-prompt');
    const setupBtn = document.getElementById('tgpcop-ai-setup-btn');
    
    const aiForm = document.getElementById('tgpcop-ai-form');
    const aiInput = document.getElementById('tgpcop-ai-input');
    const aiMessages = document.getElementById('tgpcop-ai-messages');
    const aiTyping = document.getElementById('tgpcop-ai-typing');
    const chipsContainer = document.getElementById('tgpcop-ai-chips');

    let chatHistory = [];

    // Toggle Chat Panel visibility
    launcher.addEventListener('click', () => {
      if (panel.classList.contains('hidden')) {
        panel.classList.remove('hidden');
        setTimeout(() => {
          panel.classList.add('opacity-100', 'translate-y-0');
        }, 10);
        checkApiKey();
      } else {
        closeChatPanel();
      }
    });

    closeBtn.addEventListener('click', closeChatPanel);

    function closeChatPanel() {
      panel.classList.remove('opacity-100', 'translate-y-0');
      setTimeout(() => {
        panel.classList.add('hidden');
      }, 300);
    }

    // Toggle Settings Screen
    settingsToggle.addEventListener('click', () => {
      settingsScreen.classList.toggle('hidden');
      const savedKey = localStorage.getItem('tgpcop_gemini_api_key') || '';
      keyInput.value = savedKey;
    });

    settingsCancel.addEventListener('click', () => {
      settingsScreen.classList.add('hidden');
    });

    setupBtn.addEventListener('click', () => {
      settingsScreen.classList.remove('hidden');
    });

    settingsSave.addEventListener('click', () => {
      const key = keyInput.value.trim();
      if (key) {
        localStorage.setItem('tgpcop_gemini_api_key', key);
        settingsScreen.classList.add('hidden');
        checkApiKey();
      } else {
        localStorage.removeItem('tgpcop_gemini_api_key');
        checkApiKey();
      }
    });

    function checkApiKey() {
      const apiKey = localStorage.getItem('tgpcop_gemini_api_key');
      if (!apiKey) {
        setupPrompt.classList.remove('hidden');
      } else {
        setupPrompt.classList.add('hidden');
      }
    }

    // Suggestion Chips
    document.querySelectorAll('.tgpcop-ai-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const text = chip.innerText.replace(/[^\w\s\?]/g, '').trim();
        aiInput.value = text;
        chipsContainer.classList.add('hidden');
        submitMessage(text);
      });
    });

    // Form Submission
    aiForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = aiInput.value.trim();
      if (!text) return;
      
      chipsContainer.classList.add('hidden');
      submitMessage(text);
    });

    async function submitMessage(text) {
      // Append user bubble
      appendMessage(text, 'user');
      aiInput.value = '';
      
      // Show typing indicator
      aiTyping.classList.remove('hidden');
      aiMessages.scrollTop = aiMessages.scrollHeight;

      const apiKey = localStorage.getItem('tgpcop_gemini_api_key');
      if (!apiKey) {
        appendMessage('Please configure your Gemini API Key in the settings panel to chat.', 'system');
        aiTyping.classList.add('hidden');
        return;
      }

      // Build System prompt context
      const catalogText = JSON.stringify(window.tgpcopStoreCatalog || []);
      const systemPrompt = `You are a brilliant, supportive Pharmacy Professor, Study Guide & Shopping Assistant at TGPCOP NOTES. Your purpose is to help pharmacy students with study questions (Pharmacology, Pharmaceutics, Chemistry, GPAT prep guides) and suggest relevant premium handwritten notes/PDF files from our catalog.
Our active store product database is: ${catalogText}.
Instructions:
1. Always keep responses concise, bulleted, visually high-contrast, and highly informative for students.
2. If the student asks for notes or search a product, lookup matching items from the catalog. Suggest them directly with their correct title, price, and include their exact URL (e.g. /products/example-handle) as a clickable link in this format: [Product Name](/products/example-handle) - ₹Price. 
3. Frame your advice scientifically and encouragingly. Use emojis (💊, 🧪, 📚, ✍️) appropriately.`;

      // Build conversation context payload
      chatHistory.push({ role: 'user', text: text });
      
      // Limit history to last 6 messages to preserve token budget
      const contextHistory = chatHistory.slice(-6).map(msg => `${msg.role === 'user' ? 'User' : 'Assistant'}: ${msg.text}`).join('\n');
      const finalPrompt = `${systemPrompt}\n\nRecent Conversation:\n${contextHistory}\n\nAssistant:`;

      try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            contents: [
              {
                parts: [
                  { text: finalPrompt }
                ]
              }
            ]
          })
        });

        const data = await response.json();
        aiTyping.classList.add('hidden');

        if (data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts[0]) {
          const aiResponseText = data.candidates[0].content.parts[0].text;
          appendMessage(aiResponseText, 'ai');
          chatHistory.push({ role: 'ai', text: aiResponseText });
        } else {
          console.error('Gemini API Error details:', data);
          appendMessage('Sorry, I encountered an error communicating with Gemini. Please verify your API Key is valid.', 'system');
        }
      } catch (err) {
        console.error('Fetch Error:', err);
        aiTyping.classList.add('hidden');
        appendMessage('Unable to reach the Gemini API. Please check your internet connection and try again.', 'system');
      }

      aiMessages.scrollTop = aiMessages.scrollHeight;
    }

    function appendMessage(text, sender) {
      const msgDiv = document.createElement('div');
      msgDiv.classList.add('flex', 'gap-2.5', 'items-start');

      if (sender === 'user') {
        msgDiv.innerHTML = `
          <div class="flex-1"></div>
          <div class="max-w-[80%] bg-[#072B6B] border border-white/10 rounded-2xl rounded-tr-none p-3 text-white text-xs leading-relaxed shadow-sm">
            ${escapeHTML(text)}
          </div>
        `;
      } else if (sender === 'system') {
        msgDiv.innerHTML = `
          <div class="w-8 h-8 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-red-400 text-base">warning</span>
          </div>
          <div class="max-w-[80%] bg-red-950/40 border border-red-900/60 rounded-2xl rounded-tl-none p-3 text-red-200 text-[11px] leading-relaxed shadow-sm">
            ${text}
          </div>
        `;
      } else {
        // AI response (parses Markdown bold ** and links [text](url) simply)
        const html = parseSimpleMarkdown(text);
        msgDiv.innerHTML = `
          <div class="w-8 h-8 rounded-full bg-[#072B6B] shrink-0 border border-slate-700 flex items-center justify-center">
            <span class="material-symbols-outlined text-base text-[#2E9E36]">smart_toy</span>
          </div>
          <div class="max-w-[80%] bg-slate-800/80 border border-slate-700/80 rounded-2xl rounded-tl-none p-3 text-slate-200 text-xs leading-relaxed shadow-sm">
            ${html}
          </div>
        `;
      }

      aiMessages.appendChild(msgDiv);
      aiMessages.scrollTop = aiMessages.scrollHeight;
    }

    function escapeHTML(str) {
      return str.replace(/[&<>'"]/g, 
        tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
      );
    }

    function parseSimpleMarkdown(text) {
      // Basic markdown processor for the chatbot output:
      let html = escapeHTML(text);

      // Convert bold **text** to <strong>text</strong>
      html = html.replace(/\*\*([^\*]+)\*\*/g, '<strong>$1</strong>');

      // Convert bullet points starting with * or - to standard line breaks or bullets
      html = html.replace(/^\s*[\*\-]\s+(.*)$/gm, '• $1');

      // Convert links [text](url) to <a href="url" class="...">text</a>
      // Note: need to capture escaped versions or do it on raw
      html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-[#2E9E36] font-bold hover:underline" target="_self">$1</a>');

      // Convert newlines to breaks
      html = html.replace(/\n/g, '<br>');

      return html;
    }

    // Auto verify API key state on initial load
    checkApiKey();
  })();
</script>
