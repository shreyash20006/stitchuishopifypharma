<section class="py-20 bg-[#F8FAF9]">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 text-center">
      {%- for block in section.blocks -%}
        <div class="space-y-4" {{ block.shopify_attributes }}>
          <div class="text-4xl md:text-5xl font-black text-[#0B5D3B] tabular-nums">
            {{ block.settings.stat }}
          </div>
          <div class="text-gray-500 font-bold uppercase tracking-widest text-xs md:text-sm">
            {{ block.settings.label }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Student Trust Stats",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        {
          "type": "text",
          "id": "stat",
          "label": "Number/Stat",
          "default": "10,000+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Pharmacy Students"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Student Trust Stats",
      "blocks": [
        { "type": "stat", "settings": { "stat": "10,000+", "label": "Pharmacy Students" } },
        { "type": "stat", "settings": { "stat": "Premium", "label": "Handwritten Notes" } },
        { "type": "stat", "settings": { "stat": "Instant", "label": "PDF Delivery" } },
        { "type": "stat", "settings": { "stat": "GPAT", "label": "Focused Content" } }
      ]
    }
  ]
}
{% endschema %}
