{%- if section.settings.show_announcement -%}
  <div class="announcement-bar">
    <div class="container">
      <p class="announcement-bar__text">
        {{ section.settings.text }}
        {%- if section.settings.link != blank -%}
          <a href="{{ section.settings.link }}" style="color: #fff; text-decoration: underline; margin-left: 8px;">Learn More</a>
        {%- endif -%}
      </p>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show Announcement", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "Free GPAT 2025 Study Plan Available Now!" },
    { "type": "url", "id": "link", "label": "Link" }
  ]
}
{% endschema %}
