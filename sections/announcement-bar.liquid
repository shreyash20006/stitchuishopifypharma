<div class="announcement-bar bg-gradient-to-r from-[#004429] via-[#0b5d3b] to-[#001D11] text-white py-3 px-4 text-center overflow-hidden relative border-b border-white/5 shadow-inner">
  <div class="max-w-container-max mx-auto">
    <p class="text-[10px] md:text-xs font-black uppercase tracking-[0.25em] drop-shadow-sm animate-pulse">
      {{ section.settings.text }}
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "🎉 Welcome to TGPCOP Digital Hub | Instant PDF Notes for All Semesters"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
