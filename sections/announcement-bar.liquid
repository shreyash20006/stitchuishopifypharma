<div class="announcement-bar bg-primary text-white py-2 px-4 text-center overflow-hidden relative">
  <div class="max-w-container-max mx-auto">
    <p class="text-[11px] md:text-xs font-bold uppercase tracking-[0.2em] animate-pulse">
      {{ section.settings.text }}
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "🎉 Welcome to TGPCOP Digital Hub | Instant PDF Notes for All Semesters"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
