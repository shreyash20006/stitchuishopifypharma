<section class="py-20 bg-white">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="group block p-10 bg-[#F8FAF9] rounded-[32px] border border-gray-100 hover:border-[#0B5D3B20] hover:bg-white hover:shadow-2xl transition-all duration-500 text-center" {{ block.shopify_attributes }}>
          <div class="inline-flex items-center justify-center w-20 h-20 bg-white rounded-2xl shadow-sm group-hover:scale-110 group-hover:bg-[#0B5D3B] transition-all duration-500 mb-8">
            <span class="material-symbols-outlined text-4xl text-[#0B5D3B] group-hover:text-white transition-colors">
              {{ block.settings.icon }}
            </span>
          </div>
          <h3 class="text-xl font-black text-gray-900 mb-2">{{ block.settings.title }}</h3>
          <p class="text-gray-500 font-medium">{{ block.settings.text }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quick Contact Cards",
  "settings": [],
  "blocks": [
    {
      "type": "card",
      "name": "Contact Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Material Icon Name",
          "default": "mail"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Email Support"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Support Text",
          "default": "support@tgpcop.com"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick Contact Cards",
      "blocks": [
        { "type": "card", "settings": { "icon": "mail", "title": "Email Support", "text": "support@tgpcop.com" } },
        { "type": "card", "settings": { "icon": "chat", "title": "WhatsApp Support", "text": "+91 XXXXX XXXXX" } },
        { "type": "card", "settings": { "icon": "photo_camera", "title": "Instagram", "text": "@tgpcop_notes" } },
        { "type": "card", "settings": { "icon": "send", "title": "Telegram", "text": "Join Community" } }
      ]
    }
  ]
}
{% endschema %}
