<section class="py-20 bg-background-main">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
      <div>
        <h2 class="font-bold text-[32px] leading-[40px] text-primary">{{ section.settings.title }}</h2>
        <p class="text-on-surface-variant font-medium mt-2 max-w-xl">{{ section.settings.subtitle }}</p>
      </div>
      <a href="/collections/all" class="text-primary font-bold flex items-center gap-1 hover:underline">
        View All Products
        <span class="material-symbols-outlined">chevron_right</span>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter">
      {%- comment -%}
        If a collection is selected, use it. Otherwise, pull from 'all' collection automatically.
      {%- endcomment -%}
      {%- assign collection = section.settings.collection | default: collections.all -%}
      
      {%- if collection.products_count > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="group">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Onboarding state -->
        {%- for i in (1..4) -%}
          <div class="bg-surface-container rounded-2xl aspect-[3/4] animate-pulse"></div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Automatic Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Latest Study Resources"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "New products added to the store will automatically appear here."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection (Optional)",
      "info": "Leave empty to show all new products automatically."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Automatic Product Grid"
    }
  ]
}
{% endschema %}
