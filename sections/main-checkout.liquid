{%- comment -%}
  Custom Checkout Section for Pharmacy digital notes storefront
  Specially tailored to collect student academic information and redirect to Shopify Checkout.
{%- endcomment -%}

<style>
  #checkout-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }
  #checkout-section-{{ section.id }} .text-primary, 
  #checkout-section-{{ section.id }} .text-\[\#004429\] {
    color: {{ section.settings.primary_brand_color }} !important;
  }
  #checkout-section-{{ section.id }} .bg-primary\/5,
  #checkout-section-{{ section.id }} .bg-\[\#00442908\],
  #checkout-section-{{ section.id }} .bg-\[\#00442906\] {
    background-color: {{ section.settings.primary_brand_color }}10 !important;
  }
  #checkout-section-{{ section.id }} .bg-primary {
    background-color: {{ section.settings.primary_brand_color }} !important;
  }
  #checkout-section-{{ section.id }} .border-primary,
  #checkout-section-{{ section.id }} .border-\[\#00442915\] {
    border-color: {{ section.settings.primary_brand_color }}30 !important;
  }
  #checkout-section-{{ section.id }} .border-primary {
    border-color: {{ section.settings.primary_brand_color }} !important;
  }
  #checkout-section-{{ section.id }} .from-primary {
    --tw-gradient-from: {{ section.settings.primary_brand_color }} !important;
  }
  #checkout-section-{{ section.id }} .to-\[\#005a36\] {
    --tw-gradient-to: {{ section.settings.primary_brand_color }}dd !important;
  }
  #checkout-section-{{ section.id }} .course-pill.active-pill {
    border-color: {{ section.settings.primary_brand_color }} !important;
    background-color: {{ section.settings.primary_brand_color }}15 !important;
    color: {{ section.settings.primary_brand_color }} !important;
  }
</style>

<section id="checkout-section-{{ section.id }}" class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto min-h-[75vh]">
  <div class="flex flex-col gap-8">
    
    <!-- Title & Navigation -->
    <div class="flex flex-col md:flex-row md:items-end justify-between border-b border-outline-variant pb-6 gap-4">
      <div>
        <h1 class="text-4xl font-extrabold text-on-surface tracking-tight">{{ section.settings.title }}</h1>
        <p class="text-on-surface-variant text-sm mt-1">{{ section.settings.subtitle }}</p>
      </div>
      <a href="/cart" class="text-primary font-bold hover:underline flex items-center gap-2 self-start md:self-auto">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        {{ section.settings.back_to_cart_text }}
      </a>
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Left: Checkout Forms & Steps (8 Cols) -->
        <div class="lg:col-span-7 xl:col-span-8 space-y-8">
          
          <!-- Step Progress Tracker -->
          <div class="glass-card p-4 rounded-2xl flex items-center justify-between border border-outline-variant bg-white/50">
            <!-- Step 1 -->
            <div id="tracker-step-1" class="flex items-center gap-3 px-4 py-2 rounded-xl bg-primary text-white transition-all duration-300">
              <span class="w-7 h-7 rounded-full bg-white text-primary flex items-center justify-center font-black text-sm shadow-sm">1</span>
              <span class="font-bold text-sm tracking-tight hidden sm:inline">Student Details</span>
            </div>
            
            <!-- Connection Line -->
            <div class="flex-grow mx-4 h-0.5 bg-gray-200 rounded-full overflow-hidden">
              <div id="tracker-progress-line" class="h-full bg-primary w-0 transition-all duration-500"></div>
            </div>
            
            <!-- Step 2 -->
            <div id="tracker-step-2" class="flex items-center gap-3 px-4 py-2 rounded-xl text-on-surface-variant bg-gray-100 transition-all duration-300">
              <span class="w-7 h-7 rounded-full bg-gray-200 text-on-surface-variant flex items-center justify-center font-black text-sm">2</span>
              <span class="font-bold text-sm tracking-tight hidden sm:inline">Secure Payment</span>
            </div>
          </div>

          <!-- Checkout Form -->
          <form id="checkout-form" class="space-y-6">
            
            <!-- STEP 1: Student Information -->
            <div id="step-1-container" class="glass-card p-6 md:p-8 rounded-3xl border border-outline-variant shadow-lg space-y-6 transition-all duration-500 transform translate-x-0 opacity-100">
              <div class="flex items-center gap-3 border-b border-gray-100 pb-4">
                <span class="material-symbols-outlined text-primary text-2xl font-bold">school</span>
                <div>
                  <h3 class="text-xl font-bold text-on-surface">{{ section.settings.step_1_header }}</h3>
                  <p class="text-xs text-on-surface-variant">{{ section.settings.step_1_subtitle }}</p>
                </div>
              </div>

              <!-- Full Name -->
              <div class="space-y-2 relative">
                <label for="student-name" class="block text-sm font-bold text-on-surface">{{ section.settings.field_name_label }}</label>
                <div class="relative">
                  <span class="material-symbols-outlined absolute left-4 top-3.5 text-gray-400 text-xl">person</span>
                  <input type="text" id="student-name" required placeholder="Shreyash Patil" 
                    class="w-full pl-12 pr-4 py-3.5 bg-white border border-outline-variant rounded-2xl focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-on-surface transition-all">
                </div>
              </div>

              <!-- Two column fields: Email and Whatsapp -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Email Address -->
                <div class="space-y-2">
                  <label for="student-email" class="block text-sm font-bold text-on-surface">{{ section.settings.field_email_label }}</label>
                  <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-3.5 text-gray-400 text-xl">mail</span>
                    <input type="email" id="student-email" required placeholder="student@example.com" 
                      class="w-full pl-12 pr-4 py-3.5 bg-white border border-outline-variant rounded-2xl focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-on-surface transition-all">
                  </div>
                </div>

                <!-- Whatsapp Number -->
                <div class="space-y-2">
                  <label for="student-whatsapp" class="block text-sm font-bold text-on-surface">{{ section.settings.field_whatsapp_label }}</label>
                  <div class="relative">
                    <span class="fab fa-whatsapp absolute left-4 top-4 text-gray-400 text-xl"></span>
                    <input type="tel" id="student-whatsapp" required placeholder="9876543210" 
                      class="w-full pl-12 pr-4 py-3.5 bg-white border border-outline-variant rounded-2xl focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-on-surface transition-all">
                  </div>
                </div>
              </div>

              <!-- Course / Stream Selection -->
              <div class="space-y-3">
                <span class="block text-sm font-bold text-on-surface">{{ section.settings.course_label_text }}</span>
                <input type="hidden" id="student-course" value="{{ section.settings.course_1_label }}">
                <div class="grid grid-cols-3 gap-3">
                  {%- if section.settings.course_1_label != blank -%}
                    <button type="button" onclick="setCourse('{{ section.settings.course_1_label }}', this)" class="course-pill py-3 px-4 rounded-2xl font-bold text-sm text-center border-2 border-primary bg-primary/5 text-primary transition-all shadow-sm active-pill">
                      {{ section.settings.course_1_label }}
                    </button>
                  {%- endif -%}
                  {%- if section.settings.course_2_label != blank -%}
                    <button type="button" onclick="setCourse('{{ section.settings.course_2_label }}', this)" class="course-pill py-3 px-4 rounded-2xl font-bold text-sm text-center border-2 border-outline-variant text-on-surface-variant hover:border-primary hover:bg-primary/5 transition-all">
                      {{ section.settings.course_2_label }}
                    </button>
                  {%- endif -%}
                  {%- if section.settings.course_3_label != blank -%}
                    <button type="button" onclick="setCourse('{{ section.settings.course_3_label }}', this)" class="course-pill py-3 px-4 rounded-2xl font-bold text-sm text-center border-2 border-outline-variant text-on-surface-variant hover:border-primary hover:bg-primary/5 transition-all">
                      {{ section.settings.course_3_label }}
                    </button>
                  {%- endif -%}
                </div>
              </div>

              <!-- Two column fields: Year and College -->
              <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                <!-- Academic Year Selection -->
                <div class="md:col-span-4 space-y-2">
                  <label for="student-year" class="block text-sm font-bold text-on-surface">Academic Year</label>
                  <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-3.5 text-gray-400 text-xl">calendar_month</span>
                    <select id="student-year" class="w-full pl-12 pr-8 py-3.5 bg-white border border-outline-variant rounded-2xl focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-on-surface transition-all appearance-none cursor-pointer">
                      <option value="1st Year">1st Year</option>
                      <option value="2nd Year">2nd Year</option>
                      <option value="3rd Year">3rd Year</option>
                      <option value="4th Year">4th Year</option>
                      <option value="Passed Out">Passed Out</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-4 top-3.5 text-gray-400 pointer-events-none">expand_more</span>
                  </div>
                </div>

                <!-- College Name -->
                <div class="md:col-span-8 space-y-2">
                  <label for="student-college" class="block text-sm font-bold text-on-surface">{{ section.settings.field_college_label }}</label>
                  <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-3.5 text-gray-400 text-xl">account_balance</span>
                    <input type="text" id="student-college" required placeholder="TGP College of Pharmacy" 
                      class="w-full pl-12 pr-4 py-3.5 bg-white border border-outline-variant rounded-2xl focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-on-surface transition-all">
                  </div>
                </div>
              </div>

              <!-- Error Box -->
              <div id="form-error-step-1" class="hidden bg-error/5 border border-error/20 p-4 rounded-2xl flex items-center gap-3 text-error text-xs font-bold animate-pulse">
                <span class="material-symbols-outlined">error</span>
                <span id="form-error-message">Please fill in all mandatory fields correctly.</span>
              </div>

              <!-- Step 1 Button -->
              <div class="pt-2">
                <button type="button" onclick="validateAndGoToStep2()" 
                  class="w-full py-4.5 bg-primary text-white font-extrabold text-base rounded-2xl hover:bg-primary/95 transition-all shadow-lg shadow-primary/10 flex items-center justify-center gap-3 hover:translate-y-[-2px] active:scale-[0.98]">
                  CONTINUE TO PAYMENT
                  <span class="material-symbols-outlined font-black">arrow_forward</span>
                </button>
              </div>
            </div>

            <!-- STEP 2: Secure Payment & Discount (Hidden initially) -->
            <div id="step-2-container" class="hidden glass-card p-6 md:p-8 rounded-3xl border border-outline-variant shadow-lg space-y-6 opacity-0 transform translate-x-12 transition-all duration-500">
              <div class="flex items-center justify-between border-b border-gray-100 pb-4">
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-primary text-2xl font-bold">verified_user</span>
                  <div>
                    <h3 class="text-xl font-bold text-on-surface">{{ section.settings.step_2_header }}</h3>
                    <p class="text-xs text-on-surface-variant">{{ section.settings.step_2_subtitle }}</p>
                  </div>
                </div>
                <button type="button" onclick="goToStep1()" class="text-xs font-black text-primary bg-primary/5 hover:bg-primary/10 px-3 py-1.5 rounded-full transition-all flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm font-black">edit</span>
                  Edit Details
                </button>
              </div>

              <!-- Student Details Preview Card -->
              <div class="p-5 bg-primary/5 border border-[#00442915] rounded-2xl space-y-3">
                <h4 class="text-xs font-bold text-primary uppercase tracking-wider">Verified Academic Profile</h4>
                
                <div class="grid grid-cols-2 gap-4 text-sm">
                  <div>
                    <span class="block text-[10px] text-gray-400 uppercase font-bold tracking-tight">Name</span>
                    <span id="preview-name" class="font-bold text-[#141b2b] dark:text-white">-</span>
                  </div>
                  <div>
                    <span class="block text-[10px] text-gray-400 uppercase font-bold tracking-tight">Delivery Email</span>
                    <span id="preview-email" class="font-bold text-[#141b2b] dark:text-white break-all">-</span>
                  </div>
                  <div>
                    <span class="block text-[10px] text-gray-400 uppercase font-bold tracking-tight">WhatsApp / Course</span>
                    <span id="preview-course" class="font-bold text-[#141b2b] dark:text-white">-</span>
                  </div>
                  <div>
                    <span class="block text-[10px] text-gray-400 uppercase font-bold tracking-tight">College / University</span>
                    <span id="preview-college" class="font-bold text-[#141b2b] dark:text-white line-clamp-1">-</span>
                  </div>
                </div>
              </div>

              <!-- Promo Code Section -->
              <div class="space-y-2">
                <label for="checkout-discount" class="block text-sm font-bold text-on-surface">Apply Discount Code (Optional)</label>
                <div class="flex gap-2">
                  <div class="relative flex-grow">
                    <span class="material-symbols-outlined absolute left-4 top-3 text-gray-400 text-lg">sell</span>
                    <input type="text" id="checkout-discount" placeholder="Enter coupon code (e.g. EXAM25)" 
                      class="w-full pl-11 pr-4 py-3 bg-white border border-outline-variant rounded-xl focus:border-primary outline-none text-sm transition-all uppercase font-semibold">
                  </div>
                  <button type="button" onclick="applyPromoCode()" class="px-5 bg-white border-2 border-primary text-primary font-bold text-sm rounded-xl hover:bg-primary/5 transition-all">
                    Apply
                  </button>
                </div>
                <!-- Applied Alert -->
                <div id="discount-status" class="hidden text-xs font-bold text-primary flex items-center gap-1.5">
                  <span class="material-symbols-outlined text-sm">check_circle</span>
                  <span>Discount code will be automatically applied at the payment page.</span>
                </div>
              </div>

              <!-- Premium Payment Gateways Tab Switcher -->
              <div class="p-6 border border-outline-variant/60 rounded-3xl space-y-5 bg-white/50 dark:bg-black/25 shadow-sm">
                <div class="flex items-center justify-between border-b border-outline-variant/30 pb-3">
                  <span class="text-sm font-black text-on-surface tracking-tight">{{ section.settings.accepted_methods_headline }}</span>
                  <span class="text-[10px] font-black text-[#008a54] dark:text-[#00c878] uppercase flex items-center gap-1 bg-[#008a54]/5 dark:bg-[#00c878]/10 px-2 py-0.5 rounded-full border border-[#008a54]/10">
                    <span class="material-symbols-outlined text-[12px] font-black">lock</span>
                    PCI-DSS Compliant
                  </span>
                </div>

                <!-- Tab Headers -->
                <div class="grid grid-cols-2 gap-2 p-1 bg-surface-container-low dark:bg-surface-container-low rounded-2xl border border-outline-variant/40">
                  <button type="button" onclick="switchPaymentTab('upi', this)" class="payment-tab-btn py-2.5 px-4 rounded-xl font-extrabold text-xs text-center flex items-center justify-center gap-2 border-2 border-primary bg-white dark:bg-surface text-primary shadow-sm transition-all duration-300">
                    <span class="material-symbols-outlined text-sm">qr_code_2</span>
                    UPI / QR Code
                  </button>
                  <button type="button" onclick="switchPaymentTab('card', this)" class="payment-tab-btn py-2.5 px-4 rounded-xl font-extrabold text-xs text-center flex items-center justify-center gap-2 border border-transparent text-on-surface-variant hover:text-on-surface hover:bg-white/40 dark:hover:bg-surface/40 transition-all duration-300">
                    <span class="material-symbols-outlined text-sm">credit_card</span>
                    Cards & Netbanking
                  </button>
                </div>

                <!-- Tab Content 1: UPI & Instant QR Pay -->
                <div id="payment-tab-upi" class="space-y-4 transition-all duration-300">
                  <div class="grid grid-cols-4 gap-2.5">
                    <!-- PhonePe -->
                    <div onclick="selectGateway('phonepe', this)" class="gateway-card bg-white dark:bg-surface border-2 border-primary/20 hover:border-primary p-2.5 rounded-2xl flex flex-col items-center justify-center h-16 shadow-sm hover:scale-[1.03] active:scale-95 cursor-pointer relative transition-all duration-200 active-gateway">
                      <img src="https://img.icons8.com/color/48/phonepe.png" class="h-6 object-contain" alt="PhonePe">
                      <span class="text-[8px] font-black text-on-surface-variant mt-1.5 uppercase">PhonePe</span>
                      <span class="gateway-check absolute top-1 right-1 w-3.5 h-3.5 rounded-full bg-primary text-white flex items-center justify-center text-[8px] font-black border border-white">✓</span>
                    </div>
                    <!-- Google Pay -->
                    <div onclick="selectGateway('gpay', this)" class="gateway-card bg-white dark:bg-surface border border-outline-variant hover:border-primary p-2.5 rounded-2xl flex flex-col items-center justify-center h-16 shadow-sm hover:scale-[1.03] active:scale-95 cursor-pointer relative transition-all duration-200">
                      <img src="https://img.icons8.com/color/48/google-pay.png" class="h-6 object-contain" alt="Google Pay">
                      <span class="text-[8px] font-black text-on-surface-variant mt-1.5 uppercase">G-Pay</span>
                      <span class="gateway-check absolute top-1 right-1.5 w-3.5 h-3.5 rounded-full bg-primary text-white flex items-center justify-center text-[8px] font-black border border-white hidden">✓</span>
                    </div>
                    <!-- Paytm -->
                    <div onclick="selectGateway('paytm', this)" class="gateway-card bg-white dark:bg-surface border border-outline-variant hover:border-primary p-2.5 rounded-2xl flex flex-col items-center justify-center h-16 shadow-sm hover:scale-[1.03] active:scale-95 cursor-pointer relative transition-all duration-200">
                      <img src="https://img.icons8.com/color/48/paytm.png" class="h-5 object-contain" alt="Paytm">
                      <span class="text-[8px] font-black text-on-surface-variant mt-2.5 uppercase">Paytm</span>
                      <span class="gateway-check absolute top-1 right-1.5 w-3.5 h-3.5 rounded-full bg-primary text-white flex items-center justify-center text-[8px] font-black border border-white hidden">✓</span>
                    </div>
                    <!-- Generic UPI QR -->
                    <div onclick="selectGateway('upi_qr', this)" class="gateway-card bg-white dark:bg-surface border border-outline-variant hover:border-primary p-2.5 rounded-2xl flex flex-col items-center justify-center h-16 shadow-sm hover:scale-[1.03] active:scale-95 cursor-pointer relative transition-all duration-200">
                      <img src="https://img.icons8.com/color/48/upi.png" class="h-4 object-contain" alt="UPI QR">
                      <span class="text-[8px] font-black text-on-surface-variant mt-3.5 uppercase">UPI QR</span>
                      <span class="gateway-check absolute top-1 right-1.5 w-3.5 h-3.5 rounded-full bg-primary text-white flex items-center justify-center text-[8px] font-black border border-white hidden">✓</span>
                    </div>
                  </div>
                  
                  <div class="p-3.5 bg-primary/5 rounded-2xl border border-primary/10 flex items-start gap-2.5">
                    <span class="material-symbols-outlined text-primary text-sm font-black mt-0.5">bolt</span>
                    <p id="gateway-hint-text" class="text-[10px] text-on-surface-variant/90 font-bold leading-relaxed">
                      ⚡ Pay instantly via your PhonePe UPI handle. Simply keep your PhonePe app open on your phone or enter your UPI ID.
                    </p>
                  </div>
                </div>

                <!-- Tab Content 2: Cards & Netbanking -->
                <div id="payment-tab-card" class="space-y-4 hidden transition-all duration-300">
                  <div class="grid grid-cols-3 gap-2.5">
                    <!-- Cards -->
                    <div class="bg-white dark:bg-surface border border-outline-variant/60 p-2.5 rounded-2xl flex flex-col items-center justify-center h-16 shadow-sm hover:scale-[1.03] transition-all">
                      <div class="flex items-center gap-1 justify-center">
                        <img src="https://img.icons8.com/color/48/visa.png" class="h-3.5 object-contain" alt="Visa">
                        <img src="https://img.icons8.com/color/48/mastercard.png" class="h-3.5 object-contain" alt="Mastercard">
                      </div>
                      <span class="text-[8px] font-black text-on-surface-variant mt-2 uppercase">Debit / Credit</span>
                    </div>
                    <!-- Netbanking -->
                    <div class="bg-white dark:bg-surface border border-outline-variant/60 p-2.5 rounded-2xl flex flex-col items-center justify-center h-16 shadow-sm hover:scale-[1.03] transition-all">
                      <span class="material-symbols-outlined text-gray-500 text-lg">account_balance</span>
                      <span class="text-[8px] font-black text-on-surface-variant mt-1.5 uppercase">Netbanking</span>
                    </div>
                    <!-- RuPay -->
                    <div class="bg-white dark:bg-surface border border-outline-variant/60 p-2.5 rounded-2xl flex flex-col items-center justify-center h-16 shadow-sm hover:scale-[1.03] transition-all">
                      <img src="https://img.icons8.com/color/48/rupay.png" class="h-3 object-contain" alt="RuPay">
                      <span class="text-[8px] font-black text-on-surface-variant mt-2 uppercase">RuPay / Debit</span>
                    </div>
                  </div>
                  
                  <div class="p-3.5 bg-primary/5 rounded-2xl border border-primary/10 flex items-start gap-2.5">
                    <span class="material-symbols-outlined text-primary text-sm font-black mt-0.5">security</span>
                    <p class="text-[10px] text-on-surface-variant/90 font-bold leading-relaxed">
                      🔒 Payments are securely managed by Shopify Payments using standard 256-bit Secure Socket Layer encryption technology.
                    </p>
                  </div>
                </div>

                <p class="text-[9px] text-on-surface-variant/50 leading-relaxed text-center">
                  {{ section.settings.payment_note }}
                </p>
              </div>

              <!-- Proceed to Pay Submit Button -->
              <div class="space-y-3 pt-2">
                <button type="submit" id="checkout-submit-btn"
                  class="w-full py-5 bg-gradient-to-r from-primary to-[#005a36] text-white font-extrabold text-lg rounded-2xl hover:brightness-105 transition-all shadow-xl shadow-primary/20 flex items-center justify-center gap-3 active:scale-[0.98]">
                  <span class="material-symbols-outlined font-black">lock</span>
                  <span id="btn-text">{{ section.settings.submit_button_text }}</span>
                  <span id="btn-spinner" class="hidden animate-spin w-5 h-5 border-2 border-white border-t-transparent rounded-full"></span>
                </button>
                
                <p class="text-[10px] text-center text-on-surface-variant opacity-60">
                  {{ section.settings.submit_note }}
                </p>
              </div>
            </div>

          </form>
        </div>
        
        <!-- Right: Order Summary Sidebar (4 Cols) -->
        <div class="lg:col-span-5 xl:col-span-4 sticky top-28 space-y-6">
          
          <div class="glass-card p-6 md:p-8 rounded-3xl border border-outline-variant shadow-xl bg-white dark:bg-[#0E1612] space-y-6">
            <h2 class="text-2xl font-extrabold text-on-surface tracking-tight border-b border-gray-100 dark:border-gray-800 pb-4">{{ section.settings.summary_headline }}</h2>
            
            <!-- Cart Items Container -->
            <div class="space-y-4 max-h-[300px] overflow-y-auto no-scrollbar pr-1 border-b border-gray-50 dark:border-gray-800 pb-5">
              {%- for item in cart.items -%}
                <div class="flex gap-4 items-center">
                  <!-- Product Image / Cover -->
                  <div class="w-16 h-22 bg-surface-container-low rounded-xl overflow-hidden border border-gray-100 dark:border-gray-800 flex-shrink-0 relative">
                    {%- if item.image -%}
                      <img src="{{ item.image | image_url: width: 150 }}" alt="{{ item.title }}" class="w-full h-full object-contain p-1.5">
                    {%- else -%}
                      <div class="w-full h-full flex items-center justify-center opacity-20">
                        <span class="material-symbols-outlined text-2xl">book_2</span>
                      </div>
                    {%- endif -%}
                  </div>

                  <!-- Details -->
                  <div class="flex-grow min-w-0">
                    <h4 class="font-bold text-sm text-on-surface truncate">
