</section>

<!-- Interactive Logic for checkout -->
<script>
  function setCourse(courseName, element) {
    document.getElementById('student-course').value = courseName;
    
    // Toggle active styles on buttons
    document.querySelectorAll('.course-pill').forEach(pill => {
      pill.classList.remove('active-pill');
      pill.className = "course-pill py-3 px-4 rounded-2xl font-bold text-sm text-center border-2 border-outline-variant text-on-surface-variant hover:border-primary hover:bg-primary/5 transition-all";
    });
    
    element.className = "course-pill py-3 px-4 rounded-2xl font-bold text-sm text-center border-2 border-primary bg-primary/5 text-primary transition-all shadow-sm active-pill";
  }

  // Go to step 1
  function goToStep1() {
    const step1 = document.getElementById('step-1-container');
    const step2 = document.getElementById('step-2-container');
    const line = document.getElementById('tracker-progress-line');
    
    const step1Tracker = document.getElementById('tracker-step-1');
    const step2Tracker = document.getElementById('tracker-step-2');
    
    // Animate lines
    line.style.width = '0%';
    
    // Tracker update
    step2Tracker.className = "flex items-center gap-3 px-4 py-2 rounded-xl text-on-surface-variant bg-gray-100 transition-all duration-300";
    step2Tracker.querySelector('span').className = "w-7 h-7 rounded-full bg-gray-200 text-on-surface-variant flex items-center justify-center font-black text-sm";
    
    // View animations
    step2.classList.add('hidden', 'opacity-0', 'translate-x-12');
    step1.classList.remove('hidden');
    setTimeout(() => {
      step1.classList.remove('opacity-0', '-translate-x-12');
      step1.classList.add('opacity-100', 'translate-x-0');
    }, 50);
  }

  // Check valid step 1 and proceed to step 2
  function validateAndGoToStep2() {
    const name = document.getElementById('student-name').value.trim();
    const email = document.getElementById('student-email').value.trim();
    const whatsapp = document.getElementById('student-whatsapp').value.trim();
    const course = document.getElementById('student-course').value;
    const year = document.getElementById('student-year').value;
    const college = document.getElementById('student-college').value.trim();
    
    const errorBox = document.getElementById('form-error-step-1');
    const errorMessage = document.getElementById('form-error-message');
    
    // Form validations
    if (!name || !email || !whatsapp || !college) {
      errorMessage.innerText = "Please fill in all details (Name, Email, WhatsApp, and College).";
      errorBox.classList.remove('hidden');
      return;
    }
    
    // Email regex validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      errorMessage.innerText = "Please enter a valid email address for receiving your digital guides.";
      errorBox.classList.remove('hidden');
      return;
    }
    
    // WhatsApp number length check (approximate Indian mobile validation)
    const whatsappClean = whatsapp.replace(/[^0-9]/g, '');
    if (whatsappClean.length < 10) {
      errorMessage.innerText = "Please enter a valid 10-digit WhatsApp number for semester updates.";
      errorBox.classList.remove('hidden');
      return;
    }
    
    // If all is correct, proceed
    errorBox.classList.add('hidden');
    
    // Set previews
    document.getElementById('preview-name').innerText = name;
    document.getElementById('preview-email').innerText = email;
    document.getElementById('preview-course').innerText = whatsappClean + ' • ' + course + ' (' + year + ')';
    document.getElementById('preview-college').innerText = college;
    
    // Animation transitions
    const step1 = document.getElementById('step-1-container');
    const step2 = document.getElementById('step-2-container');
    const line = document.getElementById('tracker-progress-line');
    
    const step2Tracker = document.getElementById('tracker-step-2');
    
    // Progress Line
    line.style.width = '100%';
    
    // Tracker Update
    step2Tracker.className = "flex items-center gap-3 px-4 py-2 rounded-xl bg-primary text-white transition-all duration-300";
    step2Tracker.querySelector('span').className = "w-7 h-7 rounded-full bg-white text-primary flex items-center justify-center font-black text-sm shadow-sm";
    
    // View animations
    step1.classList.add('hidden', 'opacity-0', '-translate-x-12');
    step2.classList.remove('hidden');
    setTimeout(() => {
      step2.classList.remove('opacity-0', 'translate-x-12');
      step2.classList.add('opacity-100', 'translate-x-0');
    }, 50);
  }

  // Display applied coupons nicely
  function applyPromoCode() {
    const code = document.getElementById('checkout-discount').value.trim();
    const discountStatus = document.getElementById('discount-status');
    const discountRow = document.getElementById('discount-row');
    
    if (code.length > 0) {
      discountStatus.classList.remove('hidden');
      discountRow.classList.remove('hidden');
      
      // Visual pulse
      discountStatus.classList.add('animate-bounce');
      setTimeout(() => discountStatus.classList.remove('animate-bounce'), 1000);
    } else {
      discountStatus.classList.add('hidden');
      discountRow.classList.add('hidden');
    }
  }

  // On submit, write cart attributes and redirect to Shopify Checkout prefilled
  document.getElementById('checkout-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const name = document.getElementById('student-name').value.trim();
    const email = document.getElementById('student-email').value.trim();
    const whatsapp = document.getElementById('student-whatsapp').value.trim();
    const course = document.getElementById('student-course').value;
    const year = document.getElementById('student-year').value;
    const college = document.getElementById('student-college').value.trim();
    const discount = document.getElementById('checkout-discount').value.trim();
    
    const submitBtn = document.getElementById('checkout-submit-btn');
    const btnText = document.getElementById('btn-text');
    const spinner = document.getElementById('btn-spinner');
    
    // Show Loading state
    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-80', 'cursor-not-allowed');
    btnText.innerText = "PROCESSING SECURE ORDER...";
    spinner.classList.remove('hidden');
    
    // Formulate Cart Attributes
    const cartAttributes = {
      'Student Name': name,
      'WhatsApp Number': whatsapp,
      'Course Selected': course,
      'Academic Year': year,
      'College Name': college
    };
    
    // AJAX: Update Cart Attributes in Shopify Session
    fetch('/cart/update.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        attributes: cartAttributes
      })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error('Network error while updating cart attributes');
      }
      return response.json();
    })
    .then(data => {
      console.log('Cart attributes successfully updated:', data);
      
      // Formulate prefilled checkout parameters
      // Shopify accepts: /checkout?checkout[email]=email&checkout[billing_address][first_name]=name&discount=discountCode
      let checkoutUrl = '/checkout?';
      
      // Add email
      checkoutUrl += 'checkout[email]=' + encodeURIComponent(email);
      
      // Add name to first name
      checkoutUrl += '&checkout[billing_address][first_name]=' + encodeURIComponent(name);
      
      // Add whatsapp to billing phone (if needed)
      checkoutUrl += '&checkout[billing_address][phone]=' + encodeURIComponent(whatsapp);
      
      // Add discount code if present
      if (discount) {
        checkoutUrl += '&discount=' + encodeURIComponent(discount);
      }
      
      // Redirect student instantly to secure Shopify checkout!
      window.location.href = checkoutUrl;
    })
    .catch(error => {
      console.error('Checkout redirect error:', error);
      // Fallback: Redirect directly to standard checkout if AJAX fails
      let fallbackUrl = '/checkout';
      if (discount) fallbackUrl += '?discount=' + encodeURIComponent(discount);
      window.location.href = fallbackUrl;
  });

  // Switch between UPI and Card tabs
  function switchPaymentTab(tabName, element) {
    // Tabs container visibility
    const upiContent = document.getElementById('payment-tab-upi');
    const cardContent = document.getElementById('payment-tab-card');
    
    if (tabName === 'upi') {
      upiContent.classList.remove('hidden');
      cardContent.classList.add('hidden');
    } else {
      upiContent.classList.add('hidden');
      cardContent.classList.remove('hidden');
    }
    
    // Manage button states
    document.querySelectorAll('.payment-tab-btn').forEach(btn => {
      btn.className = "payment-tab-btn py-2.5 px-4 rounded-xl font-extrabold text-xs text-center flex items-center justify-center gap-2 border border-transparent text-on-surface-variant hover:text-on-surface hover:bg-white/40 dark:hover:bg-surface/40 transition-all duration-300";
    });
    
    element.className = "payment-tab-btn py-2.5 px-4 rounded-xl font-extrabold text-xs text-center flex items-center justify-center gap-2 border-2 border-primary bg-white dark:bg-surface text-primary shadow-sm transition-all duration-300";
  }

  // Select a specific gateway option and update hint message
  function selectGateway(gatewayName, element) {
    // Clear all active gateway cards
    document.querySelectorAll('.gateway-card').forEach(card => {
      card.classList.remove('border-primary', 'bg-primary/5', 'active-gateway');
      card.classList.add('border-outline-variant');
      card.querySelector('.gateway-check').classList.add('hidden');
    });
    
    // Activate clicked card
    element.classList.remove('border-outline-variant');
    element.classList.add('border-primary', 'bg-primary/5', 'active-gateway');
    element.querySelector('.gateway-check').classList.remove('hidden');
    
    // Dynamic text hints
    const hintText = document.getElementById('gateway-hint-text');
    if (gatewayName === 'phonepe') {
      hintText.innerHTML = "⚡ Pay instantly via your PhonePe UPI handle. Simply keep your PhonePe app open on your phone or enter your PhonePe mobile number.";
    } else if (gatewayName === 'gpay') {
      hintText.innerHTML = "⚡ Quick redirection to Google Pay. Verify with your fingerprint/PIN on mobile, or pay securely using your Google Wallet profile.";
    } else if (gatewayName === 'paytm') {
      hintText.innerHTML = "⚡ Complete checkout with Paytm Wallet, Net Banking, or secure UPI. Instant status sync upon payment validation.";
    } else if (gatewayName === 'upi_qr') {
      hintText.innerHTML = "⚡ A custom dynamic QR Code will be loaded on the checkout page. Scan with ANY UPI app (BHIM, PhonePe, Paytm, Google Pay, Mobikwik, etc.) to complete payment instantly.";
    }
  }
</script>

