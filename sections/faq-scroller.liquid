<section class="py-20 bg-surface-container-lowest overflow-hidden">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
      <div class="space-y-4">
        <h2 class="text-3xl md:text-4xl font-bold text-primary">Frequently Asked Questions</h2>
        <p class="text-on-surface-variant max-w-2xl">Everything you need to know about TGPCOP NOTES. Still have questions? Email us at <a href="mailto:contact@tgpcoppharma.shop" class="text-primary font-bold underline">contact@tgpcoppharma.shop</a></p>
      </div>
    </div>

    <!-- FAQ Scroller Container -->
    <div class="relative h-[500px] overflow-hidden group">
      <div class="faq-track grid grid-cols-1 md:grid-cols-2 gap-6 absolute top-0 w-full animate-v-scroll group-hover:pause">
        
        {%- capture faq_items -%}
        <!-- Question 1 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">1. What is TGPCOP NOTES?</h4>
          <p class="text-sm text-on-surface-variant">TGPCOP NOTES is a platform providing handwritten B.Pharmacy notes, study materials, semester bundles, and exam-focused PDFs for pharmacy students.</p>
        </div>
        <!-- Question 2 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">2. Are the notes handwritten or typed?</h4>
          <p class="text-sm text-on-surface-variant">All notes are premium handwritten PDF notes designed for easy understanding and exam preparation.</p>
        </div>
        <!-- Question 3 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">3. How will I receive the notes after payment?</h4>
          <p class="text-sm text-on-surface-variant">After successful payment, the PDF download link will be sent instantly to your email address.</p>
        </div>
        <!-- Question 4 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">4. Do I need to create an account?</h4>
          <p class="text-sm text-on-surface-variant">No, you only need a valid email address to receive your digital products.</p>
        </div>
        <!-- Question 5 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">5. Useful for university exams?</h4>
          <p class="text-sm text-on-surface-variant">Yes, the notes are exam-focused and specially prepared for B.Pharmacy semester exams and quick revision.</p>
        </div>
        <!-- Question 6 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">6. Which courses are available?</h4>
          <p class="text-sm text-on-surface-variant">Currently, B.Pharmacy semester notes, bundles, and pharmacy study materials are available.</p>
        </div>
        <!-- Question 7 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">7. Access on mobile phones?</h4>
          <p class="text-sm text-on-surface-variant">Yes, all PDFs can be accessed on mobile, tablet, laptop, and desktop devices.</p>
        </div>
        <!-- Question 8 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">8. Are the notes downloadable?</h4>
          <p class="text-sm text-on-surface-variant">Yes, all products are instant downloadable PDF files.</p>
        </div>
        <!-- Question 9 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">9. Lifetime access?</h4>
          <p class="text-sm text-on-surface-variant">Yes, once purchased, you can download and keep the notes permanently.</p>
        </div>
        <!-- Question 10 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">10. Do you provide bundles?</h4>
          <p class="text-sm text-on-surface-variant">Yes, complete semester bundles with all subjects are available at discounted prices.</p>
        </div>
        <!-- Question 11 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">11. Can I share the PDFs?</h4>
          <p class="text-sm text-on-surface-variant">No, purchased notes are for personal educational use only.</p>
        </div>
        <!-- Question 12 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">12. Payment methods?</h4>
          <p class="text-sm text-on-surface-variant">We accept UPI, Debit Card, Credit Card, Net Banking, Wallets, and other secure payment methods.</p>
        </div>
        <!-- Question 13 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">13. Didn't receive link?</h4>
          <p class="text-sm text-on-surface-variant">Contact us through WhatsApp, Telegram, or email support and we'll help you quickly.</p>
        </div>
        <!-- Question 14 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">14. Updates for new notes?</h4>
          <p class="text-sm text-on-surface-variant">Yes, join our WhatsApp and Telegram channels for regular updates and new uploads.</p>
        </div>
        <!-- Question 15 -->
        <div class="p-6 rounded-2xl glass-card border border-outline-variant bg-white h-fit">
          <h4 class="font-bold text-primary mb-2">15. How can I contact?</h4>
          <p class="text-sm text-on-surface-variant">You can contact us through WhatsApp, Telegram, Instagram, X, or email support anytime.</p>
        </div>
        {%- endcapture -%}
        
        {{ faq_items }}
        {{ faq_items }} <!-- Duplicate for seamless loop -->
        
      </div>
      
      <!-- Gradient Fades -->
      <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-surface-container-lowest via-surface-container-lowest/80 to-transparent pointer-events-none z-10"></div>
      <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-surface-container-lowest via-surface-container-lowest/80 to-transparent pointer-events-none z-10"></div>
    </div>
  </div>
</section>

<style>
  @keyframes v-scroll {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }
  .animate-v-scroll {
    animation: v-scroll 45s linear infinite;
  }
  .pause {
    animation-play-state: paused;
  }
</style>

{% schema %}
{
  "name": "FAQ Scroller",
  "settings": [],
  "presets": [
    {
      "name": "FAQ Scroller"
    }
  ]
}
{% endschema %}
