<section class="py-20 bg-white" id="faq-section">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-extrabold text-primary mb-4">Frequently Asked Questions</h2>
      <p class="text-on-surface-variant">Got questions? We have answers. Support: <a href="mailto:contact@tgpcoppharma.shop" class="text-primary font-bold">contact@tgpcoppharma.shop</a></p>
    </div>

    <!-- Scrolling FAQ Container -->
    <div class="faq-container relative overflow-hidden rounded-3xl border border-outline-variant bg-surface-container-lowest h-[450px]">
      <div class="faq-inner-track p-6 grid grid-cols-1 md:grid-cols-2 gap-6 animate-faq-scroll">
        
        <!-- Question 1 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">1. What is TGPCOP NOTES?</h4>
          <p class="text-sm text-on-surface-variant">A platform providing premium handwritten B.Pharmacy notes and exam-focused study materials.</p>
        </div>

        <!-- Question 2 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">2. Handwritten or Typed?</h4>
          <p class="text-sm text-on-surface-variant">All notes are premium handwritten PDF notes designed for rapid revision.</p>
        </div>

        <!-- Question 3 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">3. Instant Receipt?</h4>
          <p class="text-sm text-on-surface-variant">Yes, download links are sent instantly to your email after payment.</p>
        </div>

        <!-- Question 4 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">4. Account Required?</h4>
          <p class="text-sm text-on-surface-variant">No, just a valid email is needed for digital delivery.</p>
        </div>

        <!-- Question 5 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">5. Exam-focused?</h4>
          <p class="text-sm text-on-surface-variant">Yes, specially prepared for B.Pharm semester exams and PCI syllabus.</p>
        </div>

        <!-- Question 6 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">6. Available Courses?</h4>
          <p class="text-sm text-on-surface-variant">B.Pharmacy semester notes, bundles, and GPAT materials.</p>
        </div>

        <!-- Question 7 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">7. Mobile Access?</h4>
          <p class="text-sm text-on-surface-variant">Yes, accessible on all devices (Mobile, Tablet, Laptop).</p>
        </div>

        <!-- Question 8 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">8. Downloadable?</h4>
          <p class="text-sm text-on-surface-variant">Yes, all products are downloadable PDF files.</p>
        </div>

        <!-- Question 9 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">9. Lifetime Access?</h4>
          <p class="text-sm text-on-surface-variant">Once purchased, the notes are yours to keep forever.</p>
        </div>

        <!-- Question 10 -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">10. Semester Bundles?</h4>
          <p class="text-sm text-on-surface-variant">Yes, complete bundles are available at discounted prices.</p>
        </div>

        <!-- Duplicate for loop -->
        <div class="p-6 rounded-2xl border border-primary/10 bg-white shadow-sm h-fit">
          <h4 class="font-bold text-primary mb-2">11. Sharing Policy?</h4>
          <p class="text-sm text-on-surface-variant">Personal use only. Copyright TGPCOP NOTES.</p>
        </div>
      </div>
      
      <!-- Fade Overlays -->
      <div class="absolute top-0 w-full h-16 bg-gradient-to-b from-surface-container-lowest to-transparent z-10"></div>
      <div class="absolute bottom-0 w-full h-16 bg-gradient-to-t from-surface-container-lowest to-transparent z-10"></div>
    </div>
  </div>
</section>

<style>
  @keyframes faq-scroll {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }
  .animate-faq-scroll {
    animation: faq-scroll 30s linear infinite;
  }
  .faq-container:hover .animate-faq-scroll {
    animation-play-state: paused;
  }
</style>

{% schema %}
{
  "name": "FAQ Scroller",
  "settings": [],
  "presets": [
    {
      "name": "FAQ Scroller"
    }
  ]
}
{% endschema %}
