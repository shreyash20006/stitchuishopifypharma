<section class="pt-24 pb-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto min-h-[60vh]">
  <div class="flex flex-col gap-8">
    <div class="flex items-end justify-between border-b border-outline-variant pb-6">
      <h1 class="text-4xl font-bold text-on-surface">Your Study Cart</h1>
      <a href="/collections/all" class="text-primary font-semibold hover:underline">Continue Shopping</a>
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Cart Items List -->
        <div class="lg:col-span-8 space-y-6">
          <form action="{{ routes.cart_url }}" method="post" id="cart-form">
            {%- for item in cart.items -%}
              <div class="flex gap-6 p-6 glass-card rounded-2xl border border-outline-variant relative group">
                <!-- Product Image -->
                <div class="w-24 h-32 md:w-32 md:h-40 flex-shrink-0 bg-surface-container-low rounded-xl overflow-hidden border border-outline-variant">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 300 }}" alt="{{ item.title }}" class="w-full h-full object-contain p-2">
                  {%- else -%}
                    <div class="w-full h-full flex items-center justify-center opacity-20">
                      <span class="material-symbols-outlined text-4xl">image</span>
                    </div>
                  {%- endif -%}
                </div>

                <!-- Product Details -->
                <div class="flex-grow flex flex-col justify-between py-2">
                  <div class="space-y-1">
                    <h3 class="font-bold text-lg md:text-xl text-on-surface line-clamp-2">
                      <a href="{{ item.url }}" class="hover:text-primary transition-colors">{{ item.product.title }}</a>
                    </h3>
                    <p class="text-sm text-on-surface-variant italic">{{ item.variant.title | remove: 'Default Title' }}</p>
                  </div>

                  <div class="flex items-center justify-between mt-4">
                    <div class="flex items-center gap-4 bg-surface-container-high rounded-lg px-3 py-2">
                      <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="material-symbols-outlined text-sm opacity-50 hover:opacity-100">remove</a>
                      <span class="font-bold text-sm min-w-[20px] text-center">{{ item.quantity }}</span>
                      <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="material-symbols-outlined text-sm opacity-50 hover:opacity-100">add</a>
                    </div>
                    
                    <div class="text-right">
                      <p class="font-bold text-xl text-primary">{{ item.final_line_price | money }}</p>
                    </div>
                  </div>
                </div>

                <!-- Remove Button -->
                <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="absolute top-4 right-4 text-on-surface-variant hover:text-error transition-colors p-2">
                  <span class="material-symbols-outlined text-xl">close</span>
                </a>
              </div>
            {%- endfor -%}
          </form>
        </div>

        <!-- Order Summary Sidebar -->
        <div class="lg:col-span-4">
          <div class="glass-card p-8 rounded-3xl sticky top-24 space-y-6 border border-primary/10 shadow-xl">
            <h2 class="text-2xl font-bold border-b border-outline-variant pb-4">Order Summary</h2>
            
            <div class="space-y-4">
              <div class="flex justify-between text-on-surface-variant">
                <span>Subtotal ({{ cart.item_count }} items)</span>
                <span class="font-bold text-on-surface">{{ cart.original_total_price | money }}</span>
              </div>
              <div class="flex justify-between text-on-surface-variant">
                <span>Download Delivery</span>
                <span class="text-primary font-bold">FREE</span>
              </div>
            </div>

            <div class="pt-6 border-t border-outline-variant flex justify-between items-end">
              <div class="flex flex-col">
                <span class="text-sm text-on-surface-variant font-bold">TOTAL</span>
                <span class="text-[10px] text-on-surface-variant opacity-60">Inclusive of all taxes</span>
              </div>
              <span class="text-3xl font-bold text-primary">{{ cart.total_price | money }}</span>
            </div>

            <div class="space-y-3 pt-4">
              <button onclick="location.href='/checkout'" class="w-full py-5 bg-primary text-white font-bold rounded-2xl hover:bg-primary/90 transition-all shadow-lg flex items-center justify-center gap-3 active:scale-[0.98]">
                PROCEED TO CHECKOUT
                <span class="material-symbols-outlined">arrow_forward</span>
              </button>
              <p class="text-[10px] text-center text-on-surface-variant opacity-60 px-4">
                By proceeding, you agree to our terms of digital delivery. No physical copies will be shipped.
              </p>
            </div>

            <!-- Trust Badges -->
            <div class="pt-6 flex justify-center gap-4 border-t border-outline-variant opacity-40 grayscale hover:grayscale-0 transition-all duration-500">
              <img src="https://img.icons8.com/color/48/visa.png" class="h-6">
              <img src="https://img.icons8.com/color/48/mastercard.png" class="h-6">
              <img src="https://img.icons8.com/color/48/upi.png" class="h-6">
            </div>
          </div>
        </div>
      </div>
    {%- else -%}
      <!-- Empty State -->
      <div class="flex flex-col items-center justify-center py-32 space-y-6 glass-card rounded-3xl border-2 border-dashed border-outline-variant">
        <div class="w-24 h-24 bg-primary/5 rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-5xl text-primary/30">shopping_cart_off</span>
        </div>
        <div class="text-center space-y-2">
          <h2 class="text-2xl font-bold">Your cart is empty</h2>
          <p class="text-on-surface-variant">Looks like you haven't added any study resources yet.</p>
        </div>
        <a href="/collections/all" class="bg-primary text-white px-10 py-4 rounded-xl font-bold hover:shadow-lg transition-all active:scale-95">
          Start Studying Now
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main Cart",
  "settings": []
}
{% endschema %}
