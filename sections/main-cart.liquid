<main class="pt-10 pb-stack-lg px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
  <!-- Back Button -->
  <div class="mb-stack-md">
    <a href="/collections/all" class="flex items-center gap-2 text-primary font-bold hover:opacity-80">
      <span class="material-symbols-outlined">arrow_back</span>
      Continue Shopping
    </a>
  </div>

  <h1 class="font-bold text-[40px] text-primary mb-stack-lg">Your Cart</h1>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
    <!-- Cart Items -->
    <div class="lg:col-span-8 space-y-4">
      {%- if cart.item_count > 0 -%}
        {%- for item in cart.items -%}
          <div class="glass-card rounded-xl p-4 md:p-6 flex flex-col md:flex-row gap-6 shadow-sm">
            <div class="w-full md:w-32 h-32 rounded-lg overflow-hidden flex-shrink-0 bg-surface-container">
              <img src="{{ item.image | image_url: width: 300 }}" alt="{{ item.title }}" class="w-full h-full object-cover">
            </div>
            <div class="flex-grow flex flex-col justify-between">
              <div>
                <div class="flex justify-between items-start">
                  <span class="bg-secondary-container text-on-secondary-container font-bold text-[12px] px-3 py-1 rounded-full mb-2 inline-block">
                    {{ item.product.collections.first.title | default: 'Pharmacy' }}
                  </span>
                  <a href="{{ item.url_to_remove }}" class="text-on-surface-variant hover:text-error transition-colors">
                    <span class="material-symbols-outlined">delete</span>
                  </a>
                </div>
                <h3 class="font-bold text-[24px] mb-1">{{ item.product.title }}</h3>
                <p class="text-on-surface-variant text-sm">{{ item.variant.title | unless: item.variant.title contains 'Default' }}</p>
              </div>
              <div class="flex justify-between items-center mt-4">
                <div class="flex items-center border border-outline-variant rounded-lg overflow-hidden bg-surface-container-lowest">
                  <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="px-3 py-1 hover:bg-surface-container">-</a>
                  <span class="px-4 font-bold">{{ item.quantity }}</span>
                  <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="px-3 py-1 hover:bg-surface-container">+</a>
                </div>
                <div class="text-right">
                  <span class="font-bold text-[24px] text-primary">{{ item.final_line_price | money }}</span>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="glass-card rounded-xl p-20 text-center space-y-4">
          <span class="material-symbols-outlined text-[64px] text-primary/20">shopping_cart</span>
          <h2 class="font-bold text-2xl">Your cart is empty</h2>
          <a href="/collections/all" class="bg-primary text-white px-8 py-3 rounded-xl inline-block font-bold">Start Shopping</a>
        </div>
      {%- endif -%}
    </div>

    <!-- Summary Sidebar -->
    <div class="lg:col-span-4 space-y-gutter">
      <div class="glass-card rounded-xl p-6 shadow-sm sticky top-24">
        <h2 class="font-bold text-[24px] mb-stack-md text-primary">Order Summary</h2>
        <div class="space-y-3 mb-stack-lg">
          <div class="flex justify-between text-sm">
            <span class="text-on-surface-variant">Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-on-surface-variant">Tax</span>
            <span>Calculated at checkout</span>
          </div>
          <div class="pt-3 border-t border-outline-variant flex justify-between items-center">
            <span class="font-bold">Total</span>
            <span class="font-bold text-[24px] text-primary">{{ cart.total_price | money }}</span>
          </div>
        </div>
        
        <form action="/cart" method="post" id="cart">
          <button type="submit" name="checkout" class="w-full py-4 bg-primary text-on-primary rounded-xl font-bold text-lg hover:opacity-90 transition-all flex items-center justify-center gap-2 shadow-lg">
            Proceed to Checkout
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
        </form>

        <div class="mt-6 flex items-center justify-center gap-4 text-on-surface-variant opacity-60">
          <span class="material-symbols-outlined">lock</span>
          <span class="text-[12px]">Secure Encrypted Checkout</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Recommendations Section -->
  {%- if section.settings.show_recommendations -%}
    <section class="mt-20">
      <div class="flex justify-between items-end mb-stack-lg">
        <div>
          <h2 class="font-bold text-[32px] text-primary">Recommended for you</h2>
          <p class="text-on-surface-variant text-sm">Students who bought these also studied:</p>
        </div>
        <a href="/collections/all" class="text-primary font-bold flex items-center gap-1 hover:underline">
          View All Catalog
          <span class="material-symbols-outlined">chevron_right</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {%- for product in collections[section.settings.recommendations_collection].products limit: 3 -%}
          <div class="bg-surface-container-lowest border border-border-subtle rounded-xl overflow-hidden hover:shadow-lg transition-all transform hover:-translate-y-1">
            <div class="h-40 overflow-hidden">
              <img src="{{ product.featured_image | image_url: width: 600 }}" class="w-full h-full object-cover">
            </div>
            <div class="p-4">
              <span class="text-[10px] font-bold uppercase tracking-wider text-secondary">{{ product.type | default: 'Pharmacy' }}</span>
              <h4 class="font-bold text-lg text-primary mt-1">{{ product.title }}</h4>
              <div class="flex justify-between items-center mt-4">
                <span class="font-bold">{{ product.price | money }}</span>
                <form method="post" action="/cart/add">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                  <button type="submit" class="p-2 bg-primary-container text-white rounded-lg">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">add_shopping_cart</span>
                  </button>
                </form>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}
</main>

{% schema %}
{
  "name": "Main Cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_recommendations",
      "label": "Show Recommendations",
      "default": true
    },
    {
      "type": "collection",
      "id": "recommendations_collection",
      "label": "Recommendations Collection"
    }
  ]
}
{% endschema %}
