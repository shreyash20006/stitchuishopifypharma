<header class="w-full z-50 backdrop-blur-md bg-surface-glass shadow-sm border-b border-outline-variant h-16 sticky top-0">
  <div class="flex justify-between items-center px-margin-desktop h-16 w-full max-w-container-max mx-auto">
    <div class="flex items-center gap-8">
      <a class="flex items-center" href="/">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" 
               alt="{{ shop.name }}" 
               class="h-12 w-auto object-contain">
        {%- else -%}
          <span class="font-bold text-primary text-xl">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      <nav class="hidden lg:flex items-center gap-6">
        {%- for link in linklists[section.settings.menu].links -%}
          <a href="{{ link.url }}" class="{% if link.current %}text-primary border-b-2 border-primary{% else %}text-on-surface-variant hover:text-primary{% endif %} pb-1 font-semibold text-sm transition-colors duration-200">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    </div>
    <div class="flex items-center gap-4">
      <div class="hidden md:flex relative items-center bg-surface-container-low rounded-full px-4 py-1.5 border border-outline-variant">
        <span class="material-symbols-outlined text-on-surface-variant text-[20px]">search</span>
        <form action="/search" method="get" role="search">
          <input class="bg-transparent border-none focus:ring-0 text-sm w-48" 
                 placeholder="Search pharmacy notes..." 
                 type="text"
                 name="q"
                 value="{{ search.terms | escape }}">
        </form>
      </div>
      <div class="flex items-center gap-2">
        <a href="/cart" class="p-2 hover:bg-surface-container rounded-full transition-colors relative">
          <span class="material-symbols-outlined text-primary">shopping_cart</span>
          {%- if cart.item_count > 0 -%}
            <span class="absolute top-0 right-0 bg-error text-white text-[10px] rounded-full h-4 w-4 flex items-center justify-center">
              {{ cart.item_count }}
            </span>
          {%- endif -%}
        </a>
        <a href="/account" class="p-2 hover:bg-surface-container rounded-full transition-colors">
          <span class="material-symbols-outlined text-primary">account_circle</span>
        </a>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
