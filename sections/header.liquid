<header id="site-header" class="sticky top-0 w-full z-50 transition-all duration-500 h-20 lg:h-24 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/30 shadow-sm flex items-center">
  
  <!-- Mobile Header (Visible only on lg:hidden) -->
  <div class="grid grid-cols-3 items-center px-margin-mobile h-full w-full lg:hidden">
    <!-- Left: Hamburger Menu -->
    <div class="flex justify-start">
      <button id="mobile-menu-open" class="p-2 text-primary hover:bg-primary/5 rounded-full transition-colors">
        <span class="material-symbols-outlined text-[28px]">menu</span>
      </button>
    </div>

    <!-- Center: Perfectly Centered Logo -->
    <div class="flex justify-center">
      <a href="{{ routes.root_url }}" class="flex items-center">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAhfmORgRtOg2tRwuyFtkuFySFacNg-gVyhm-yBB5BzXL_NP7H9MZEzAw81YveORvaw3_K51eYp3d-f6ZnpexEXmwa65TN4KUSLCARubhFV0qkRBw_VVEXSUJ3R1iczp1hv2fLwHl8LOG-fviryh8E7T3GR1Iwgy5O2GHVlgqKiFBQ6cp2n68kCBlDicOW8QI4Hn_e97TK4ZtfnoQ_ctGrc5MZ8To_--L8LePvMLLaCuOJ_COVNDDo42_e6ju_4w-jjScvJVbhcTpyt" 
             alt="TGPCOP Logo" 
             class="h-12 w-auto object-contain transition-transform duration-300 active:scale-95">
      </a>
    </div>

    <!-- Right: Search, Cart & Account Icons -->
    <div class="flex justify-end items-center gap-1">
      <button id="search-open" class="p-2 text-primary bg-primary/5 rounded-full active:scale-90 transition-all">
        <span class="material-symbols-outlined text-[24px]">search</span>
      </button>
      <a href="{{ routes.cart_url }}" class="relative p-2 text-primary bg-primary/5 rounded-full active:scale-90 transition-all">
        <span class="material-symbols-outlined text-[24px]">shopping_cart</span>
        {%- if cart.item_count > 0 -%}
          <span class="absolute -top-1 -right-1 bg-error text-white text-[9px] font-black w-4 h-4 flex items-center justify-center rounded-full border-2 border-white">
            {{ cart.item_count }}
          </span>
        {%- endif -%}
      </a>
      <a href="{{ routes.account_url }}" class="p-2 text-primary bg-primary/5 rounded-full active:scale-90 transition-all">
        <span class="material-symbols-outlined text-[24px]">account_circle</span>
      </a>
    </div>
  </div>

  <!-- Desktop Header (Visible only on lg:flex) -->
  <div class="hidden lg:flex justify-between items-center px-margin-desktop h-full w-full max-w-container-max mx-auto">
    <div class="flex items-center">
      <a href="{{ routes.root_url }}" class="flex items-center gap-2 group py-2">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAhfmORgRtOg2tRwuyFtkuFySFacNg-gVyhm-yBB5BzXL_NP7H9MZEzAw81YveORvaw3_K51eYp3d-f6ZnpexEXmwa65TN4KUSLCARubhFV0qkRBw_VVEXSUJ3R1iczp1hv2fLwHl8LOG-fviryh8E7T3GR1Iwgy5O2GHVlgqKiFBQ6cp2n68kCBlDicOW8QI4Hn_e97TK4ZtfnoQ_ctGrc5MZ8To_--L8LePvMLLaCuOJ_COVNDDo42_e6ju_4w-jjScvJVbhcTpyt" 
             alt="TGPCOP Logo" 
             class="h-14 w-auto object-contain transition-transform duration-300 group-hover:scale-105">
      </a>
    </div>

    <!-- Main Navigation -->
    <nav class="flex items-center gap-12">
      <a href="{{ routes.root_url }}" class="nav-link font-bold text-[13px] uppercase tracking-wider text-on-surface-variant hover:text-primary transition-all relative py-4">
        Home
        <span class="absolute bottom-2 left-0 w-0 h-0.5 bg-primary transition-all duration-300 nav-underline"></span>
      </a>
      <a href="/search?q=B.Pharm&options[prefix]=last&type=product" class="nav-link font-bold text-[13px] uppercase tracking-wider text-on-surface-variant hover:text-primary transition-all relative py-4">
        B.Pharm
        <span class="absolute bottom-2 left-0 w-0 h-0.5 bg-primary transition-all duration-300 nav-underline"></span>
      </a>
      <a href="/search?q=D.Pharm&options[prefix]=last&type=product" class="nav-link font-bold text-[13px] uppercase tracking-wider text-on-surface-variant hover:text-primary transition-all relative py-4">
        D.Pharm
        <span class="absolute bottom-2 left-0 w-0 h-0.5 bg-primary transition-all duration-300 nav-underline"></span>
      </a>
      <a href="/collections/all" class="nav-link font-bold text-[13px] uppercase tracking-wider text-on-surface-variant hover:text-primary transition-all relative py-4">
        All Catalog
        <span class="absolute bottom-2 left-0 w-0 h-0.5 bg-primary transition-all duration-300 nav-underline"></span>
      </a>
    </nav>

    <!-- Desktop Icons -->
    <div class="flex items-center gap-3">
      <button id="search-open-desktop" class="p-2.5 text-primary bg-primary/5 rounded-full hover:bg-primary hover:text-white transition-all duration-300 group">
        <span class="material-symbols-outlined">search</span>
      </button>
      <a href="{{ routes.cart_url }}" class="relative p-2.5 text-primary group bg-primary/5 rounded-full hover:bg-primary hover:text-white transition-all duration-300">
        <span class="material-symbols-outlined">shopping_cart</span>
        {%- if cart.item_count > 0 -%}
          <span class="absolute -top-1 -right-1 bg-error text-white text-[9px] font-black w-4 h-4 flex items-center justify-center rounded-full border-2 border-white shadow-sm">
            {{ cart.item_count }}
          </span>
        {%- endif -%}
      </a>
      <a href="{{ routes.account_url }}" class="p-2.5 text-primary bg-primary/5 rounded-full hover:bg-primary hover:text-white transition-all duration-300">
        <span class="material-symbols-outlined">account_circle</span>
      </a>
    </div>
  </div>
</header>

<!-- Mobile Menu Drawer Overlay -->
<div id="mobile-menu-overlay" class="fixed inset-0 bg-black/50 z-[100] backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"></div>

<!-- Mobile Menu Drawer -->
<div id="mobile-menu-drawer" class="fixed top-0 left-0 h-full w-[80%] max-w-[320px] bg-white z-[101] -translate-x-full transition-transform duration-300 ease-in-out shadow-2xl p-6">
  <div class="flex justify-between items-center mb-10">
    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAhfmORgRtOg2tRwuyFtkuFySFacNg-gVyhm-yBB5BzXL_NP7H9MZEzAw81YveORvaw3_K51eYp3d-f6ZnpexEXmwa65TN4KUSLCARubhFV0qkRBw_VVEXSUJ3R1iczp1hv2fLwHl8LOG-fviryh8E7T3GR1Iwgy5O2GHVlgqKiFBQ6cp2n68kCBlDicOW8QI4Hn_e97TK4ZtfnoQ_ctGrc5MZ8To_--L8LePvMLLaCuOJ_COVNDDo42_e6ju_4w-jjScvJVbhcTpyt" 
         alt="Logo" class="h-8 w-auto">
    <button id="mobile-menu-close" class="p-2 text-on-surface-variant hover:bg-on-surface/5 rounded-full">
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>

  <nav class="flex flex-col gap-6">
    <a href="{{ routes.root_url }}" class="flex items-center gap-4 text-lg font-bold text-on-surface hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-primary">home</span> Home
    </a>
    <a href="/search?q=B.Pharm&options[prefix]=last&type=product" class="flex items-center gap-4 text-lg font-bold text-on-surface hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-primary">school</span> B.Pharm
    </a>
    <a href="/search?q=D.Pharm&options[prefix]=last&type=product" class="flex items-center gap-4 text-lg font-bold text-on-surface hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-primary">medication</span> D.Pharm
    </a>
    <hr class="border-outline-variant my-2">
    <a href="/collections/all" class="flex items-center gap-4 text-lg font-bold text-on-surface-variant hover:text-primary transition-colors">
      <span class="material-symbols-outlined">grid_view</span> All Catalog
    </a>
    <a href="{{ routes.account_url }}" class="flex items-center gap-4 text-lg font-bold text-on-surface-variant hover:text-primary transition-colors">
      <span class="material-symbols-outlined">person</span> My Account
    </a>
  </nav>

  </div>
</div>

<!-- Search Overlay -->
<div id="search-overlay" class="fixed inset-0 bg-black/60 z-[200] backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500 flex items-start justify-center pt-20 px-4">
  <div class="bg-white w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden transform -translate-y-10 transition-transform duration-500" id="search-modal">
    <div class="p-6 border-b border-outline-variant flex items-center gap-4">
      <span class="material-symbols-outlined text-primary text-3xl">search</span>
      <input type="text" id="search-input" placeholder="Search notes, ebooks, materials..." class="flex-1 bg-transparent border-none focus:ring-0 text-xl font-medium outline-none text-on-surface" autocomplete="off">
      <button id="search-close" class="p-2 hover:bg-surface-container rounded-full transition-colors">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>
    <div id="search-results" class="max-h-[60vh] overflow-y-auto p-6 hidden">
      <!-- Predictive results -->
    </div>
    <div id="search-empty" class="p-10 text-center text-on-surface-variant flex flex-col items-center gap-4">
      <div class="w-16 h-16 bg-primary/5 rounded-full flex items-center justify-center">
        <span class="material-symbols-outlined text-4xl text-primary/40">manage_search</span>
      </div>
      <p class="font-bold text-lg text-on-surface">What are you looking for today?</p>
      <p class="text-sm opacity-60">Try searching for "B.Pharm 1st Sem" or "Pharmacology"</p>
    </div>
  </div>
</div>

<style>
  .nav-link:hover .nav-underline {
    width: 100%;
  }
  
  header.scrolled {
    height: 76px;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(25px);
    border-bottom: 1px solid rgba(0, 68, 41, 0.1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  #search-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  #search-overlay.active #search-modal {
    transform: translateY(0);
  }

  body.menu-open {
    overflow: hidden;
  }
</style>

<script>
  // Sticky Header Scroll
  window.addEventListener('scroll', function() {
    const header = document.getElementById('site-header');
    if (window.scrollY > 50) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  });

  // Mobile Menu Logic
  const menuOpenBtn = document.getElementById('mobile-menu-open');
  const menuCloseBtn = document.getElementById('mobile-menu-close');
  const menuOverlay = document.getElementById('mobile-menu-overlay');
  const menuDrawer = document.getElementById('mobile-menu-drawer');

  if(menuOpenBtn) {
    menuOpenBtn.addEventListener('click', () => {
      menuOverlay.classList.remove('opacity-0', 'pointer-events-none');
      menuDrawer.classList.remove('-translate-x-full');
      document.body.classList.add('menu-open');
    });
  }

  if(menuCloseBtn) {
    menuCloseBtn.addEventListener('click', closeMenu);
  }
  
  if(menuOverlay) {
    menuOverlay.addEventListener('click', closeMenu);
  }

  function closeMenu() {
    menuOverlay.classList.add('opacity-0', 'pointer-events-none');
    menuDrawer.classList.add('-translate-x-full');
    document.body.classList.remove('menu-open');
  }

  // Search Logic
  const searchOpenBtns = [document.getElementById('search-open'), document.getElementById('search-open-desktop')];
  const searchCloseBtn = document.getElementById('search-close');
  const searchOverlay = document.getElementById('search-overlay');
  const searchModal = document.getElementById('search-modal');
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const searchEmpty = document.getElementById('search-empty');

  searchOpenBtns.forEach(btn => {
    if(btn) {
      btn.addEventListener('click', () => {
        searchOverlay.classList.add('active');
        setTimeout(() => searchInput.focus(), 100);
        document.body.classList.add('menu-open');
      });
    }
  });

  if(searchCloseBtn) {
    searchCloseBtn.addEventListener('click', closeSearch);
  }

  if(searchOverlay) {
    searchOverlay.addEventListener('click', (e) => {
      if(e.target === searchOverlay) closeSearch();
    });
  }

  function closeSearch() {
    searchOverlay.classList.remove('active');
    document.body.classList.remove('menu-open');
    searchInput.value = '';
    searchResults.classList.add('hidden');
    searchEmpty.classList.remove('hidden');
  }

  let searchTimeout;
  if(searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.trim();
      clearTimeout(searchTimeout);
      
      if(query.length < 2) {
        searchResults.classList.add('hidden');
        searchEmpty.classList.remove('hidden');
        return;
      }

      searchTimeout = setTimeout(() => {
        // Shopify Predictive Search API
        fetch(`/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product,collection,article&resources[limit]=10`)
          .then(res => res.json())
          .then(data => {
            const results = data.resources.results;
            renderSearchResults(results);
          })
          .catch(err => console.error('Search error:', err));
      }, 300);
    });
  }

  function renderSearchResults(results) {
    const products = results.products || [];
    const collections = results.collections || [];
    
    if(products.length === 0 && collections.length === 0) {
      searchResults.innerHTML = `
        <div class="text-center py-12">
          <span class="material-symbols-outlined text-5xl opacity-10 mb-4">search_off</span>
          <p class="opacity-60 font-medium">No results found for your search</p>
        </div>`;
    } else {
      let html = '';
      
      if(collections.length > 0) {
        html += `<div class="mb-8"><h3 class="text-[11px] font-black text-primary uppercase tracking-[0.2em] mb-4 opacity-50 px-2">Collections</h3><div class="grid grid-cols-1 gap-2">`;
        collections.forEach(col => {
          html += `<a href="${col.url}" class="flex items-center gap-4 p-3 hover:bg-primary/5 rounded-2xl transition-all group">
            <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
              <span class="material-symbols-outlined text-primary">folder</span>
            </div>
            <span class="font-bold text-on-surface group-hover:text-primary transition-colors">${col.title}</span>
          </a>`;
        });
        html += `</div></div>`;
      }

      if(products.length > 0) {
        html += `<div><h3 class="text-[11px] font-black text-primary uppercase tracking-[0.2em] mb-4 opacity-50 px-2">Products & Ebooks</h3><div class="grid grid-cols-1 gap-3">`;
        products.forEach(prod => {
          const price = prod.price || '';
          html += `<a href="${prod.url}" class="flex items-center gap-4 p-3 hover:bg-primary/5 rounded-2xl transition-all group border border-transparent hover:border-primary/10">
            <div class="w-16 h-16 rounded-xl overflow-hidden bg-surface-container shadow-sm">
              <img src="${prod.image}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="${prod.title}">
            </div>
            <div class="flex-1">
              <p class="font-bold text-on-surface group-hover:text-primary transition-colors line-clamp-1">${prod.title}</p>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-sm font-bold text-primary">${price}</span>
                <span class="text-[10px] bg-primary/10 text-primary px-2 py-0.5 rounded-full font-bold uppercase">INSTANT PDF</span>
              </div>
            </div>
            <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_right</span>
          </a>`;
        });
        html += `</div></div>`;
      }
      
      searchResults.innerHTML = html;
    }
    
    searchResults.classList.remove('hidden');
    searchEmpty.classList.add('hidden');
  }
</script>
