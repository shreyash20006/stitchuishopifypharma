<header id="site-header" class="sticky top-0 w-full z-50 transition-all duration-500 h-16 lg:h-20 bg-white/70 backdrop-blur-xl border-b border-gray-100 flex items-center">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop h-full w-full flex justify-between items-center">
    
    <!-- Logo & Nav -->
    <div class="flex items-center gap-12 h-full">
      <a href="{{ routes.root_url }}" class="flex items-center h-full">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAhfmORgRtOg2tRwuyFtkuFySFacNg-gVyhm-yBB5BzXL_NP7H9MZEzAw81YveORvaw3_K51eYp3d-f6ZnpexEXmwa65TN4KUSLCARubhFV0qkRBw_VVEXSUJ3R1iczp1hv2fLwHl8LOG-fviryh8E7T3GR1Iwgy5O2GHVlgqKiFBQ6cp2n68kCBlDicOW8QI4Hn_e97TK4ZtfnoQ_ctGrc5MZ8To_--L8LePvMLLaCuOJ_COVNDDo42_e6ju_4w-jjScvJVbhcTpyt" 
             alt="TGPCOP Logo" 
             class="h-10 md:h-12 w-auto object-contain transition-transform duration-300 hover:scale-105">
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8 h-full">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="nav-link text-sm font-bold tracking-tight text-gray-500 hover:text-[#004429] transition-all relative py-2">
            {{ link.title }}
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#004429] transition-all duration-300 nav-underline"></span>
          </a>
        {%- endfor -%}
      </nav>
    </div>

    <!-- Search & Icons -->
    <div class="flex items-center gap-4">
      <!-- Desktop Search -->
      <div class="hidden md:flex relative items-center bg-gray-50 rounded-2xl px-4 py-2 border border-gray-100 focus-within:border-[#00442930] focus-within:bg-white transition-all group">
        <span class="material-symbols-outlined text-gray-400 text-[20px] group-focus-within:text-[#004429]">search</span>
        <input type="text" id="header-search-input" placeholder="Search pharmacy notes..." class="bg-transparent border-none focus:ring-0 text-sm font-bold w-48 lg:w-64 outline-none text-[#141b2b]">
        <!-- Predictive Search Results Dropdown -->
        <div id="header-search-results" class="absolute top-full left-0 right-0 mt-2 bg-white rounded-[24px] shadow-2xl border border-gray-100 hidden max-h-[400px] overflow-y-auto p-4 z-[60]"></div>
      </div>

      <div class="flex items-center gap-2">
        <a href="{{ routes.cart_url }}" class="relative p-3 text-[#004429] hover:bg-[#00442905] rounded-2xl transition-all group">
          <span class="material-symbols-outlined text-[24px]">shopping_cart</span>
          {%- if cart.item_count > 0 -%}
            <span class="absolute top-2 right-2 bg-[#004429] text-white text-[9px] font-black w-4 h-4 flex items-center justify-center rounded-full border-2 border-white">
              {{ cart.item_count }}
            </span>
          {%- endif -%}
        </a>
        <a href="{{ routes.account_url }}" class="hidden md:flex p-3 text-[#004429] hover:bg-[#00442905] rounded-2xl transition-all">
          <span class="material-symbols-outlined text-[24px]">account_circle</span>
        </a>
        <button id="mobile-menu-open" class="lg:hidden p-3 text-[#004429] hover:bg-[#00442905] rounded-2xl transition-all">
          <span class="material-symbols-outlined text-[28px]">menu</span>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link:hover .nav-underline { width: 100%; }
  header.scrolled { height: 64px; background-color: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); box-shadow: 0 4px 20px rgba(0,0,0,0.03); }
  .no-scrollbar::-webkit-scrollbar { display: none; }
</style>

<script>
  // Sticky Header Scroll
  window.addEventListener('scroll', function() {
    const header = document.getElementById('site-header');
    if (window.scrollY > 50) header.classList.add('scrolled');
    else header.classList.remove('scrolled');
  });

  // Predictive Search for Header Input
  const searchInput = document.getElementById('header-search-input');
  const searchResults = document.getElementById('header-search-results');
  let searchTimeout;

  if(searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.trim();
      clearTimeout(searchTimeout);
      
      if(query.length < 2) {
        searchResults.classList.add('hidden');
        return;
      }

      searchTimeout = setTimeout(() => {
        fetch(`/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product,collection&resources[limit]=6`)
          .then(res => res.json())
          .then(data => {
            const products = data.resources.results.products || [];
            if(products.length > 0) {
              let html = '<div class="space-y-2">';
              products.forEach(prod => {
                html += `
                  <a href="${prod.url}" class="flex items-center gap-4 p-3 hover:bg-gray-50 rounded-xl transition-all group">
                    <img src="${prod.image}" class="w-12 h-12 rounded-lg object-cover" alt="${prod.title}">
                    <div class="flex-1">
                      <p class="text-sm font-black text-gray-900 line-clamp-1">${prod.title}</p>
                      <p class="text-xs font-bold text-[#004429]">${prod.price}</p>
                    </div>
                  </a>`;
              });
              html += '</div>';
              searchResults.innerHTML = html;
              searchResults.classList.remove('hidden');
            } else {
              searchResults.classList.add('hidden');
            }
          });
      }, 300);
    });

    document.addEventListener('click', (e) => {
      if(!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });
  }
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
