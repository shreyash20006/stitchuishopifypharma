<header id="site-header" class="sticky top-0 w-full z-50 transition-all duration-500 h-16 lg:h-20 bg-[#072B6B] border-b border-[#072B6B]/15 flex items-center shadow-md">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop h-full w-full flex justify-between items-center">
    
    <!-- Logo & Nav -->
    <div class="flex items-center gap-8 h-full">
      <a href="{{ routes.root_url }}" class="flex items-center h-full">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAhfmORgRtOg2tRwuyFtkuFySFacNg-gVyhm-yBB5BzXL_NP7H9MZEzAw81YveORvaw3_K51eYp3d-f6ZnpexEXmwa65TN4KUSLCARubhFV0qkRBw_VVEXSUJ3R1iczp1hv2fLwHl8LOG-fviryh8E7T3GR1Iwgy5O2GHVlgqKiFBQ6cp2n68kCBlDicOW8QI4Hn_e97TK4ZtfnoQ_ctGrc5MZ8To_--L8LePvMLLaCuOJ_COVNDDo42_e6ju_4w-jjScvJVbhcTpyt" 
             alt="TGPCOP Logo" 
             class="h-10 md:h-12 w-auto object-contain transition-transform duration-300 hover:scale-105 brightness-0 invert">
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden xl:flex items-center gap-6 h-full relative">
        <a href="/collections/b-pharm" class="nav-link text-[11px] font-extrabold tracking-wider uppercase text-white/80 hover:text-[#2E9E36] transition-all relative py-2">
          B.Pharm Notes
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#2E9E36] transition-all duration-300 nav-underline"></span>
        </a>
        
        <!-- Semester Dropdown Menu -->
        <div class="relative group h-full flex items-center">
          <button class="nav-link text-[11px] font-extrabold tracking-wider uppercase text-white/80 hover:text-[#2E9E36] transition-all flex items-center gap-1 py-2 outline-none">
            Semester Wise <span class="material-symbols-outlined text-sm">keyboard_arrow_down</span>
          </button>
          <!-- Dropdown Card -->
          <div class="absolute top-full left-0 mt-1 w-52 bg-slate-900/95 backdrop-blur-xl border border-slate-800 rounded-xl shadow-2xl p-2 hidden group-hover:block z-[100] animate-fadeIn">
            {%- for i in (1..8) -%}
              <a href="/collections/semester-{{ i }}" class="block px-3 py-2 text-[11px] font-bold tracking-wide uppercase text-slate-300 hover:bg-slate-800 hover:text-white rounded-lg transition-colors">
                Semester {{ i }} Notes
              </a>
            {%- endfor -%}
          </div>
        </div>

        <a href="/collections/pyqs" class="nav-link text-[11px] font-extrabold tracking-wider uppercase text-white/80 hover:text-[#2E9E36] transition-all relative py-2">
          PYQs
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#2E9E36] transition-all duration-300 nav-underline"></span>
        </a>

        <a href="/collections/handwritten-notes" class="nav-link text-[11px] font-extrabold tracking-wider uppercase text-white/80 hover:text-[#2E9E36] transition-all relative py-2">
          Handwritten Notes
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#2E9E36] transition-all duration-300 nav-underline"></span>
        </a>

        <a href="/collections/important-questions" class="nav-link text-[11px] font-extrabold tracking-wider uppercase text-white/80 hover:text-[#2E9E36] transition-all relative py-2">
          Important Questions
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#2E9E36] transition-all duration-300 nav-underline"></span>
        </a>

        <a href="/collections/practical-files" class="nav-link text-[11px] font-extrabold tracking-wider uppercase text-white/80 hover:text-[#2E9E36] transition-all relative py-2">
          Practical Files
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#2E9E36] transition-all duration-300 nav-underline"></span>
        </a>

        <a href="/collections/mcqs" class="nav-link text-[11px] font-extrabold tracking-wider uppercase text-white/80 hover:text-[#2E9E36] transition-all relative py-2">
          MCQs
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#2E9E36] transition-all duration-300 nav-underline"></span>
        </a>
      </nav>
    </div>

    <!-- Search & Icons -->
    <div class="flex items-center gap-4">
      <!-- Desktop Search -->
      <div class="hidden md:flex relative items-center bg-white/10 text-white rounded-full px-4 py-2 border border-white/15 focus-within:border-[#2E9E36] focus-within:bg-white/20 transition-all group">
        <span class="material-symbols-outlined text-white/60 text-[20px] group-focus-within:text-[#2E9E36]">search</span>
        <input type="text" id="header-search-input" placeholder="Search notes..." class="bg-transparent border-none focus:ring-0 text-xs font-bold w-36 lg:w-48 outline-none text-white placeholder-white/50 focus:placeholder-white/70">
        <!-- Predictive Search Results Dropdown -->
        <div id="header-search-results" class="absolute top-full left-0 right-0 mt-2 bg-slate-900 border border-slate-800 rounded-2xl shadow-2xl hidden max-h-[400px] overflow-y-auto p-3 z-[60]"></div>
      </div>

      <div class="flex items-center gap-1.5">
        <!-- Theme Toggle Switcher -->
        <button class="theme-toggle-btn p-2 text-white/80 hover:text-white hover:bg-white/10 rounded-full transition-all duration-300 flex items-center justify-center" aria-label="Toggle Theme Mode">
          <span class="theme-toggle-light-icon material-symbols-outlined text-[22px] transition-transform duration-500 hover:rotate-45">light_mode</span>
          <span class="theme-toggle-dark-icon material-symbols-outlined text-[22px] hidden transition-transform duration-500 hover:-rotate-12">dark_mode</span>
        </button>

        <a href="{{ routes.cart_url }}" class="relative p-2 text-white/80 hover:text-white hover:bg-white/10 rounded-full transition-all group flex items-center justify-center">
          <span class="material-symbols-outlined text-[22px]">shopping_cart</span>
          <span class="cart-count-badge absolute -top-0.5 -right-0.5 bg-[#2E9E36] text-white text-[9px] font-black w-4 h-4 flex items-center justify-center rounded-full border border-[#072B6B] {% if cart.item_count == 0 %}hidden{% endif %}">
            {{ cart.item_count }}
          </span>
        </a>
        <a href="{{ routes.account_url }}" class="hidden md:flex p-2 text-white/80 hover:text-white hover:bg-white/10 rounded-full transition-all">
          <span class="material-symbols-outlined text-[22px]">account_circle</span>
        </a>
        <button id="mobile-menu-open" class="lg:hidden p-2 text-white/80 hover:text-white hover:bg-white/10 rounded-full transition-all">
          <span class="material-symbols-outlined text-[24px]">menu</span>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link:hover .nav-underline { width: 100%; }
  header.scrolled { height: 64px; background-color: rgba(7, 43, 107, 0.95) !important; backdrop-filter: blur(20px); box-shadow: 0 4px 30px rgba(0,0,0,0.15); }
  html.dark header.scrolled { background-color: rgba(7, 15, 30, 0.95) !important; box-shadow: 0 4px 30px rgba(0,0,0,0.4) !important; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
</style>

<script>
  // Sticky Header Scroll
  window.addEventListener('scroll', function() {
    const header = document.getElementById('site-header');
    if (window.scrollY > 50) header.classList.add('scrolled');
    else header.classList.remove('scrolled');
  });

  // Predictive Search for Header Input
  const searchInput = document.getElementById('header-search-input');
  const searchResults = document.getElementById('header-search-results');
  let searchTimeout;

  if(searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.trim();
      clearTimeout(searchTimeout);
      
      if(query.length < 2) {
        searchResults.classList.add('hidden');
        return;
      }

      searchTimeout = setTimeout(() => {
        fetch(`/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product,collection&resources[limit]=6`)
          .then(res => res.json())
          .then(data => {
            const products = data.resources.results.products || [];
            if(products.length > 0) {
              let html = '<div class="space-y-1.5">';
              products.forEach(prod => {
                html += `
                  <a href="${prod.url}" class="flex items-center gap-3 p-2.5 hover:bg-slate-800 rounded-xl transition-all group text-left">
                    <img src="${prod.image}" class="w-10 h-10 rounded-lg object-cover border border-slate-700" alt="${prod.title}">
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-slate-100 line-clamp-1">${prod.title}</p>
                      <p class="text-[10px] font-black text-[#2E9E36]">${prod.price}</p>
                    </div>
                  </a>`;
              });
              html += '</div>';
              searchResults.innerHTML = html;
              searchResults.classList.remove('hidden');
            } else {
              searchResults.classList.add('hidden');
            }
          });
      }, 300);
    });

    document.addEventListener('click', (e) => {
      if(!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });
  }
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
