            </div>

            <!-- Sparkles -->
            <div class="sparkles" aria-hidden="true">
              <div class="spark sp1"><div class="spark-dot"></div></div>
              <div class="spark sp2"><div class="spark-ring"></div></div>
              <div class="spark sp3"><div class="spark-dot"></div></div>
              <div class="spark sp4"><div class="spark-ring"></div></div>
              <div class="spark sp5"><div class="spark-dot"></div></div>
              <div class="spark sp6"><div class="spark-ring"></div></div>
              <div class="spark sp7"><div class="spark-dot"></div></div>
