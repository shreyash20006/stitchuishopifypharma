<style>
  .hero-banner__media,
  .hero-banner__image-wrapper,
  .hero-banner .media,
  .hero-media-container {
    background: none !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
  }

  .hero-img-contain {
    object-fit: {{ section.settings.image_fit }} !important;
  }

  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<section class="relative overflow-hidden bg-white pt-16 pb-24 md:pt-32 md:pb-40">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Content Side -->
      <div class="relative z-10 space-y-8 animate-fade-in">
        <span class="inline-block bg-[#cfe9da] text-[#52695e] px-5 py-2 rounded-full font-bold text-xs tracking-widest uppercase shadow-sm">
          {{ section.settings.badge_text }}
        </span>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-[#141b2b] leading-[1.1] tracking-tight">
          {{ section.settings.title_rich | default: 'QUALITY PHARMACY NOTES MADE FOR <span class="text-[#004429]">B.PHARM & D.PHARM</span> STUDENTS' }}
        </h1>
        
        <p class="text-lg md:text-xl text-gray-500 font-medium leading-relaxed max-w-xl">
          {{ section.settings.description }}
        </p>
        
        <div class="flex flex-wrap gap-4 pt-4">
          <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="bg-[#004429] text-white px-10 py-5 rounded-2xl font-bold hover:scale-105 transition-all shadow-xl shadow-[#00442920]">
            {{ section.settings.button_text }}
          </a>
          <a href="{{ section.settings.secondary_button_link | default: '#' }}" class="bg-white text-[#004429] border-2 border-[#00442910] px-10 py-5 rounded-2xl font-bold hover:bg-[#004429] hover:text-white transition-all flex items-center gap-2 group">
            <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">chat</span>
            {{ section.settings.secondary_button_text }}
          </a>
        </div>
      </div>

      <!-- Image Side -->
      <div class="relative">
        <div class="bg-[#e1e8fd] rounded-[48px] p-8 md:p-12 overflow-hidden aspect-video lg:aspect-square flex items-center justify-center relative group" style="min-height: {{ section.settings.banner_height }}px;">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#00442905] to-transparent pointer-events-none"></div>
          {%- if section.settings.hero_image != blank -%}
            <img src="{{ section.settings.hero_image | image_url: width: 1400 }}" 
                 alt="{{ section.settings.badge_text }}" 
                 class="w-full h-full hero-img-contain drop-shadow-[0_20px_60px_rgba(0,0,0,0.1)] transition-all duration-700 group-hover:scale-105 group-hover:-rotate-1">
          {%- else -%}
            <div class="rounded-3xl w-full aspect-square bg-white/50 flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
              <span class="material-symbols-outlined text-6xl">image</span>
            </div>
          {%- endif -%}
        </div>
        <!-- Decorative elements -->
        <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-[#8ad4a8]/20 rounded-full blur-3xl"></div>
        <div class="absolute -top-6 -right-6 w-48 h-48 bg-[#004429]/5 rounded-full blur-3xl"></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "PREMIUM PHARMACY HUB"
    },
    {
      "type": "inline_richtext",
      "id": "title_rich",
      "label": "Heading (Use <span> for green text)",
      "default": "QUALITY PHARMACY NOTES MADE FOR <span class=\"text-[#004429]\">B.PHARM & D.PHARM</span> STUDENTS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Handwritten exam-focused notes, GPAT materials & instant PDF downloads. Master your curriculum with clarity and speed."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Primary Button Text",
      "default": "Shop Notes"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Join WhatsApp"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Media Fitting",
      "options": [
        { "value": "contain", "label": "Contain (No Cropping)" },
        { "value": "cover", "label": "Cover (Fill Space)" }
      ],
      "default": "contain"
    },
    {
      "type": "range",
      "id": "banner_height",
      "min": 400,
      "max": 800,
      "step": 50,
      "default": 600,
      "unit": "px",
      "label": "Min Section Height"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
