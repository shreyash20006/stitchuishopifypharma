<section class="hero-banner">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-badge">
          <span>{{ section.settings.badge_text | default: "🎓 Over 5000+ Students Trust Us" }}</span>
        </div>
        <h1 class="hero-title">{{ section.settings.heading | default: "Premium Pharmacy Notes & Study Resources" }}</h1>
        <p class="hero-subtitle">{{ section.settings.subheading | default: "Access top-quality handwritten and typed notes for B.Pharm, D.Pharm, and GPAT preparations." }}</p>
        <div class="hero-actions">
          <a href="{{ section.settings.primary_btn_link | default: "/collections/all" }}" class="btn btn--primary btn--lg">{{ section.settings.primary_btn_text | default: "Explore Notes" }}</a>
          <a href="{{ section.settings.secondary_btn_link | default: "/pages/free-resources" }}" class="btn btn--outline btn--lg">{{ section.settings.secondary_btn_text | default: "Free Resources" }}</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-img-card">
          {% if section.settings.hero_image != blank %}
            <img src="{{ section.settings.hero_image | image_url: width: 800 }}" alt="Hero Image">
          {% else %}
            <div style="background: var(--color-surface-green); aspect-ratio: 4/3; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 5rem;">📚</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge Text" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "primary_btn_text", "label": "Primary Button Text" },
    { "type": "url", "id": "primary_btn_link", "label": "Primary Button Link" },
    { "type": "text", "id": "secondary_btn_text", "label": "Secondary Button Text" },
    { "type": "url", "id": "secondary_btn_link", "label": "Secondary Button Link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
