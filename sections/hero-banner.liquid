                <!-- BOOK 2 — PHARMACEUTICS -->
                <div class="book book-2 b2" data-tip="hover to open">
                  <div class="book-pages"></div>
                  <div class="book-face">
                    <div class="book-cover">
                      <div class="book-cover-front">
                        <div class="book-icon">🧪</div>
                        <div class="book-title">PHARMA&shy;CEUTICS</div>
                        <div class="book-divider"></div>
                        <div class="book-subtitle">DOSAGE FORMS</div>
