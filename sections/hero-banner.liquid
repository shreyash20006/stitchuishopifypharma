                      </div>
                      <div class="book-inner">
                        <div class="inner-line"></div>
                        <div class="inner-line"></div>
                        <div class="inner-line"></div>
                        <div class="inner-line"></div>
                        <div class="inner-line"></div>
                        <div class="inner-line"></div>
                        <div class="inner-line"></div>
                      </div>
                    </div>
                    <div class="book-spine">
                      <span class="spine-text">PHARMACEUTICS</span>
