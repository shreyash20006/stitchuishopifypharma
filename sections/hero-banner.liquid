<section class="relative overflow-hidden bg-gradient-to-br from-surface to-secondary-container/20 pt-16 pb-24 md:pt-24 md:pb-32">
  <div class="max-w-container-max mx-auto px-margin-desktop grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <div class="space-y-8">
      <div class="inline-flex items-center gap-3 px-4 py-2 bg-primary/10 text-primary rounded-full font-bold text-sm border border-primary/20">
        <span class="font-bold">{{ section.settings.badge_text }}</span>
      </div>
      <h1 class="font-bold text-[40px] leading-[48px] text-on-surface max-w-xl">
        {{ section.settings.title }}
      </h1>
      <p class="text-lg text-on-surface-variant max-w-lg">
        {{ section.settings.description }}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="{{ section.settings.button_link }}" class="bg-primary text-on-primary px-8 py-4 rounded-xl font-semibold hover:opacity-90 transition-all flex items-center gap-2 shadow-lg shadow-primary/20">
          {{ section.settings.button_text }}
        </a>
        <a href="{{ section.settings.secondary_button_link }}" class="bg-surface-container-lowest border border-primary text-primary px-8 py-4 rounded-xl font-semibold hover:bg-primary/5 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined">chat</span>
          {{ section.settings.secondary_button_text }}
        </a>
      </div>
    </div>
    <div class="relative">
      <div class="absolute -top-10 -right-10 w-64 h-64 bg-tertiary/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="relative z-10 glass-card p-4 rounded-3xl rotate-2 shadow-2xl">
        {%- if section.settings.hero_image != blank -%}
          <img src="{{ section.settings.hero_image | image_url: width: 1000 }}" 
               alt="{{ section.settings.title }}" 
               class="rounded-2xl w-full h-auto object-cover aspect-[4/3]">
        {%- else -%}
          <div class="rounded-2xl w-full h-auto aspect-[4/3] bg-surface-container flex items-center justify-center text-on-surface-variant">
            Hero Image Placeholder
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "TRUSTED BY 10,000+ PHARMACY STUDENTS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "QUALITY PHARMACY NOTES MADE FOR B.PHARM STUDENTS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Handwritten exam-focused notes, GPAT materials & instant PDF downloads. Master your curriculum with clarity and speed."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Primary Button Text",
      "default": "Shop Notes"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Join WhatsApp"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
