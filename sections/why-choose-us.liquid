{%- comment -%}
  Dynamic "Why Study With TGPCOP" section
  Allows complete drag-and-drop customization of B.Pharm feature cards, badges, statistics, and social triggers.
{%- endcomment -%}

<section class="py-24 overflow-hidden bg-white dark:!bg-surface border-t border-gray-100 dark:border-border-subtle/30">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop space-y-20">
    
    <!-- Section Header -->
    <div class="text-center space-y-6 max-w-3xl mx-auto" data-aos="fade-up">
      {%- if section.settings.badge_text != blank -%}
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary/5 dark:bg-secondary/10 border border-secondary/10 dark:border-secondary/20 mb-2">
          <span class="material-symbols-outlined text-secondary dark:text-tertiary text-sm" style="font-variation-settings: 'FILL' 1;">
            {{ section.settings.badge_icon | default: 'verified' }}
          </span>
          <span class="text-[10px] font-black uppercase tracking-widest text-secondary dark:text-tertiary">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h2 class="text-4xl md:text-6xl font-black text-primary dark:text-[#EAF0F6] tracking-tight">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
      
      {%- if section.settings.subtitle != blank -%}
        <p class="text-lg text-on-surface-variant/80 dark:text-on-surface-variant/70 font-medium leading-relaxed">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-{{ section.settings.columns_desktop | default: 3 }} gap-8">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'feature_card' -%}
            {%- assign is_dark = block.settings.use_dark_theme -%}
            
            <div class="group relative rounded-[2.5rem] p-8 border transition-all duration-500 flex flex-col h-full {{ block.shopify_attributes }}
              {% if is_dark %}
                bg-[#072B6B] border-white/10 hover:border-[#2E9E36] dark:hover:border-[#41C94B] hover:shadow-[0_20px_50px_rgba(46,158,54,0.3)]
              {% else %}
                bg-white dark:bg-surface border-outline-variant dark:border-border-subtle/50 hover:border-[#072B6B] dark:hover:border-[#2E9E36] hover:shadow-[0_20px_50px_rgba(7,43,107,0.15)]
              {% endif %}" 
              data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 100 }}">
              
              <!-- Soft Glow effect on hover -->
              <div class="absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity rounded-[2.5rem]
                {% if is_dark %}
                  from-[#2E9E36]/20 to-transparent
                {% else %}
                  from-[#072B6B]/5 dark:from-[#2E9E36]/10 to-transparent
                {% endif %}"></div>
              
              <div class="relative space-y-6 flex-grow">
                <!-- Icon Frame -->
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-500
                  {% if is_dark %}
                    bg-white/10 text-white
                  {% else %}
                    bg-primary/10 dark:bg-secondary/15 text-primary dark:text-secondary
                  {% endif %}">
                  <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">
                    {{ block.settings.icon | default: 'psychology' }}
                  </span>
                </div>
                
                <!-- Text contents -->
                <div class="space-y-3">
                  <h3 class="text-2xl font-black {% if is_dark %}text-white{% else %}text-primary dark:text-[#EAF0F6]{% endif %}">
                    {{ block.settings.title }}
                  </h3>
                  <p class="text-sm leading-relaxed {% if is_dark %}text-white/60{% else %}text-on-surface-variant dark:text-on-surface-variant/70{% endif %}">
                    {{ block.settings.description }}
                  </p>
                </div>

                <!-- Stats Blocks -->
                {%- if block.settings.stat_1_val != blank or block.settings.stat_2_val != blank -%}
                  <div class="grid grid-cols-2 gap-3">
                    {%- if block.settings.stat_1_val != blank -%}
                      <div class="p-4 rounded-2xl border
                        {% if is_dark %}
                          bg-white/5 border-white/10
                        {% else %}
                          bg-surface-container-lowest dark:bg-surface-container-low border-outline-variant dark:border-border-subtle/40
                        {% endif %}">
                        <p class="text-xl font-black {% if is_dark %}text-white{% else %}text-secondary dark:text-tertiary{% endif %}">
                          {{ block.settings.stat_1_val }}
                        </p>
                        <p class="text-[10px] uppercase font-bold {% if is_dark %}text-white/40{% else %}text-on-surface-variant/40 dark:text-on-surface-variant/40{% endif %}">
                          {{ block.settings.stat_1_lbl }}
                        </p>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.stat_2_val != blank -%}
                      <div class="p-4 rounded-2xl border
                        {% if is_dark %}
                          bg-white/5 border-white/10
                        {% else %}
                          bg-surface-container-lowest dark:bg-surface-container-low border-outline-variant dark:border-border-subtle/40
                        {% endif %}">
                        <p class="text-xl font-black {% if is_dark %}text-white{% else %}text-secondary dark:text-tertiary{% endif %}">
                          {{ block.settings.stat_2_val }}
                        </p>
                        <p class="text-[10px] uppercase font-bold {% if is_dark %}text-white/40{% else %}text-on-surface-variant/40 dark:text-on-surface-variant/40{% endif %}">
                          {{ block.settings.stat_2_lbl }}
                        </p>
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                <!-- Media Preview Cover -->
                <div class="relative aspect-video rounded-2xl overflow-hidden group/media border
                  {% if is_dark %}
                    bg-white/5 border-white/10
                  {% else %}
                    bg-surface-container-high dark:bg-[#1E293B] border-outline-variant dark:border-border-subtle/40
                  {% endif %}">
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" 
                         alt="{{ block.settings.title }}" 
                         class="w-full h-full object-cover transition-transform duration-700 group-hover/media:scale-110">
                  {%- else -%}
                    <div class="w-full h-full flex flex-col items-center justify-center opacity-25 {% if is_dark %}text-white{% else %}text-on-surface-variant dark:text-on-surface-variant{% endif %}">
                      <span class="material-symbols-outlined text-4xl mb-2">{{ block.settings.placeholder_icon | default: 'draw' }}</span>
                      <p class="text-[10px] font-bold">{{ block.settings.placeholder_text | default: 'Preview Sample' }}</p>
                    </div>
                  {%- endif -%}
                  
                  {%- if block.settings.hover_badge != blank -%}
                    <div class="absolute inset-0 bg-[#072B6B]/40 backdrop-blur-sm opacity-0 group-hover/media:opacity-100 transition-all duration-300 flex items-center justify-center">
                      <span class="px-6 py-2 bg-white dark:bg-surface text-primary dark:text-secondary font-black text-xs uppercase tracking-widest shadow-xl rounded-lg">
                        {{ block.settings.hover_badge }}
                      </span>
                    </div>
                  {%- endif -%}
                </div>
              </div>

              <!-- Button CTA -->
              {%- if block.settings.btn_text != blank -%}
                <a href="{{ block.settings.btn_link | default: '/collections/all' }}" 
                   class="relative mt-8 w-full py-4 rounded-2xl font-black text-sm uppercase tracking-widest text-center border-2 border-transparent transition-all shadow-lg active:scale-95 z-10
                     {% if is_dark %}
                       bg-secondary text-white hover:bg-white hover:text-primary dark:hover:bg-white dark:hover:text-primary
                     {% else %}
                       bg-[#072B6B] dark:bg-[#0E4DA4] text-white hover:bg-secondary dark:hover:bg-secondary
                     {% endif %}">
                  {{ block.settings.btn_text }}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <!-- Rating Strip & Community -->
    {%- if section.settings.show_rating_strip -%}
      <div class="flex flex-col md:flex-row items-center justify-between gap-8 pt-12 border-t border-outline-variant dark:border-border-subtle/40">
        <div class="flex items-center gap-4">
          <div class="flex text-secondary dark:text-tertiary">
            {%- for i in (1..5) -%}
              <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
            {%- endfor -%}
          </div>
          <span class="text-sm font-bold text-primary dark:text-[#EAF0F6]">{{ section.settings.rating_text }}</span>
        </div>
        
        {%- if section.settings.social_link != blank -%}
          <a href="{{ section.settings.social_link }}" target="_blank" 
             class="flex items-center gap-3 px-6 py-3 rounded-full bg-blue-50 dark:bg-blue-950/20 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-900/30 hover:bg-blue-600 dark:hover:bg-blue-500 hover:text-white dark:hover:text-white transition-all group">
            <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">
              {{ section.settings.social_icon | default: 'send' }}
            </span>
            <span class="text-sm font-black uppercase tracking-widest">{{ section.settings.social_text }}</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Why Study With TGPCOP",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Cards per Row (Desktop)"
    },
    {
      "type": "header",
      "content": "Section Header Branding"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Header Badge Text",
      "default": "Trusted by 50,000+ B.Pharmacy Students"
    },
    {
      "type": "text",
      "id": "badge_icon",
      "label": "Header Badge Icon",
      "default": "verified"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "Why study with TGPCOP?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Section Description",
      "default": "We don't just provide notes; we provide a high-performance visual learning system designed specifically for pharmacy excellence."
    },
    {
      "type": "header",
      "content": "Rating & Community Strip"
    },
    {
      "type": "checkbox",
      "id": "show_rating_strip",
      "label": "Show Rating & Social Strip",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "4.9/5 Average Student Rating"
    },
    {
      "type": "text",
      "id": "social_text",
      "label": "Social Button Text",
      "default": "Join Telegram Community"
    },
    {
      "type": "text",
      "id": "social_icon",
      "label": "Social Button Icon",
      "default": "send"
    },
    {
      "type": "url",
      "id": "social_link",
      "label": "Social Link URL"
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "checkbox",
          "id": "use_dark_theme",
          "label": "Use Dark Accent Theme",
          "default": false
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Material Icon Name",
          "default": "psychology"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Visual Learning Strategy"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card Description",
          "default": "Structured handwritten-style notes with memory anchors and visual understanding blocks."
        },
        {
          "type": "header",
          "content": "Statistics Grid"
        },
        {
          "type": "text",
          "id": "stat_1_val",
          "label": "Stat 1 Value",
          "default": "70%"
        },
        {
          "type": "text",
          "id": "stat_1_lbl",
          "label": "Stat 1 Label",
          "default": "Faster Recall"
        },
        {
          "type": "text",
          "id": "stat_2_val",
          "label": "Stat 2 Value",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "stat_2_lbl",
          "label": "Stat 2 Label",
          "default": "Syllabus Coverage"
        },
        {
          "type": "header",
          "content": "Card Media Cover"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Cover Image (Override)"
        },
        {
          "type": "text",
          "id": "placeholder_icon",
          "label": "Placeholder Symbol Icon",
          "default": "draw"
        },
        {
          "type": "text",
          "id": "placeholder_text",
          "label": "Placeholder Display Text",
          "default": "Handwritten Samples"
        },
        {
          "type": "text",
          "id": "hover_badge",
          "label": "Hover Reveal Badge",
          "default": "Preview Notes"
        },
        {
          "type": "header",
          "content": "Button Call-To-Action"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Label",
          "default": "View Sample Notes"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Study With TGPCOP",
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "use_dark_theme": false,
            "icon": "psychology",
            "title": "Visual Learning Strategy",
            "description": "Structured handwritten-style notes with memory anchors and visual understanding blocks.",
            "stat_1_val": "70%",
            "stat_1_lbl": "Faster Recall",
            "stat_2_val": "100%",
            "stat_2_lbl": "Syllabus Coverage",
            "placeholder_icon": "draw",
            "placeholder_text": "Handwritten Samples",
            "hover_badge": "Preview Notes",
            "btn_text": "View Sample Notes"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "use_dark_theme": true,
            "icon": "bolt",
            "title": "Quick Revision Strategy",
            "description": "One-shot revision tables and exam-focused summaries for last minute preparation.",
            "stat_1_val": "5 Min",
            "stat_1_lbl": "Quick Sheets",
            "stat_2_val": "IMP",
            "stat_2_lbl": "Topic Focus",
            "placeholder_icon": "table_rows",
            "placeholder_text": "Revision Tables",
            "hover_badge": "View Charts",
            "btn_text": "Download Preview"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "use_dark_theme": false,
            "icon": "assignment_turned_in",
            "title": "Exam Oriented Content",
            "description": "Previous year questions, important answers and university-focused preparation.",
            "stat_1_val": "PYQs",
            "stat_1_lbl": "Included",
            "stat_2_val": "TOP",
            "stat_2_lbl": "Most Asked",
            "placeholder_icon": "quiz",
            "placeholder_text": "Paper Samples",
            "hover_badge": "Start Learning",
            "btn_text": "Get Started"
          }
        }
      ]
    }
  ]
}
{% endschema %}
