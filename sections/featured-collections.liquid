<section class="py-20 bg-background-main">
  <div class="max-w-container-max mx-auto px-margin-desktop">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
      <div>
        <h2 class="font-bold text-[32px] leading-[40px] text-on-surface">{{ section.settings.title }}</h2>
        <p class="text-on-surface-variant font-medium mt-2">{{ section.settings.description }}</p>
      </div>
      <a class="text-primary font-semibold hover:underline" href="/collections">View All Collections →</a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-gutter">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {% render 'collection-card', collection: block.settings.collection, button_text: block.settings.button_text %}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Automatic Mode: Show first 3 collections if no blocks are added {%- endcomment -%}
        {%- for collection in collections limit: 3 -%}
          {%- unless collection.handle == 'all' or collection.handle == 'frontpage' -%}
            {% render 'collection-card', collection: collection, button_text: 'Explore Now' %}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Featured Collections"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Curated resources for every stage of your pharmacy journey."
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Explore Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections"
    }
  ]
}
{% endschema %}
