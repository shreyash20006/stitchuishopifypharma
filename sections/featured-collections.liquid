<section class="section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{{ section.settings.title | default: "Featured Notes" }}</h2>
      <p class="section-sub">{{ section.settings.subtitle }}</p>
    </div>

    <div class="product-grid">
      {% if section.settings.collection != blank %}
        {% for product in section.settings.collection.products limit: 8 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <div class="product-card">
            <div class="product-card__image" style="display:flex; align-items:center; justify-content:center; font-size:4rem;">📄</div>
            <div class="product-card__info">
              <h3 class="product-card__title">Sample Note {{ i }}</h3>
              <p class="product-card__price">$9.99</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Featured Notes" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Hand-picked resources for your studies" },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
