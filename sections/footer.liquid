<footer class="w-full mt-20 bg-inverse-surface text-surface-variant pt-16 pb-8 px-margin-mobile md:px-margin-desktop">
  <div class="max-w-container-max mx-auto space-y-16">
    
    <!-- Follow Community Image (DYNAMIC SETTING) -->
    <div class="w-full rounded-3xl overflow-hidden shadow-2xl border border-white/5">
      {%- if section.settings.footer_banner != blank -%}
        <a href="{{ section.settings.banner_link | default: '#' }}" class="block">
          <img src="{{ section.settings.footer_banner | image_url: width: 2000 }}" 
               alt="TGPCOP Community" 
               class="w-full h-auto object-cover transition-transform duration-500 hover:scale-[1.02]">
        </a>
      {%- else -%}
        <div class="w-full py-20 bg-white/5 flex flex-col items-center justify-center border-2 border-dashed border-white/20 rounded-2xl">
          <span class="material-symbols-outlined text-5xl mb-4 opacity-40">image</span>
          <p class="font-bold opacity-60">Click "Select Image" in Footer settings to add your banner</p>
        </div>
      {%- endif -%}
      
      <div class="bg-white/5 p-4 flex flex-wrap justify-center gap-6 text-[10px] uppercase tracking-widest text-primary-fixed font-bold">
        <a href="https://whatsapp.com/channel/0029Vb7bPYAICVfklGHiIW0v" target="_blank" class="hover:text-white transition-colors">WhatsApp</a>
        <a href="https://t.me/tgpcopnotes" target="_blank" class="hover:text-white transition-colors">Telegram</a>
        <a href="https://instagram.com/tgpcop.notes" target="_blank" class="hover:text-white transition-colors">Instagram</a>
        <a href="https://x.com/TGPCOPNOTES" target="_blank" class="hover:text-white transition-colors">X (Twitter)</a>
        <a href="https://pin.it/6Df5gqrxL" target="_blank" class="hover:text-white transition-colors">Pinterest</a>
      </div>
    </div>

    <!-- Main Footer Columns -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8 pt-4">
      <!-- Brand Column -->
      <div class="space-y-6">
        <h3 class="text-white font-black text-2xl tracking-tight">TGPCOP NOTES</h3>
        <p class="text-sm leading-relaxed opacity-60 max-w-xs">
          Empowering pharmacy students across India with premium, exam-focused handwritten notes and GPAT study materials. 
        </p>
        <div class="flex gap-4 opacity-60">
          <img src="https://img.icons8.com/color/48/visa.png" class="h-6 grayscale hover:grayscale-0 transition-all">
          <img src="https://img.icons8.com/color/48/mastercard.png" class="h-6 grayscale hover:grayscale-0 transition-all">
          <img src="https://img.icons8.com/color/48/upi.png" class="h-6 grayscale hover:grayscale-0 transition-all">
        </div>
      </div>

      <!-- Quick Navigation -->
      <div class="space-y-6">
        <h4 class="text-white font-bold text-sm uppercase tracking-widest">Explore</h4>
        <nav class="flex flex-col gap-4">
          <a href="{{ routes.root_url }}" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">Home</a>
          <a href="/collections/b-pharm" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">B.Pharmacy Notes</a>
          <a href="/collections/d-pharm" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">D.Pharmacy Notes</a>
          <a href="/collections/all" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">All Resources</a>
        </nav>
      </div>

      <!-- Professional Policies -->
      <div class="space-y-6">
        <h4 class="text-white font-bold text-sm uppercase tracking-widest">Policies</h4>
        <nav class="flex flex-col gap-4">
          <a href="/policies/refund-policy" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">Return & Refund Policy</a>
          <a href="/policies/privacy-policy" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">Privacy Policy</a>
          <a href="/policies/terms-of-service" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">Terms of Service</a>
          <a href="/policies/shipping-policy" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">Shipping Policy</a>
          <a href="/policies/legal-notice" class="text-sm hover:text-primary-fixed hover:translate-x-1 transition-all">Legal Notice</a>
        </nav>
      </div>

      <!-- Contact Support -->
      <div class="space-y-6">
        <h4 class="text-white font-bold text-sm uppercase tracking-widest">Contact Support</h4>
        <div class="space-y-4">
          <a href="mailto:contact@tgpcoppharma.shop" class="flex items-center gap-3 text-sm group">
            <span class="material-symbols-outlined text-primary-fixed group-hover:scale-110 transition-transform">mail</span>
            contact@tgpcoppharma.shop
          </a>
          <a href="/policies/contact-information" class="flex items-center gap-3 text-sm group">
            <span class="material-symbols-outlined text-primary-fixed group-hover:scale-110 transition-transform">location_on</span>
            Contact Information
          </a>
          <div class="pt-2">
            <p class="text-[10px] opacity-40 uppercase font-bold mb-2">Availability</p>
            <p class="text-xs opacity-60">Mon - Sat: 10:00 AM - 6:00 PM</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust Badges (Horizontal on Desktop, Grid on Mobile) -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 py-12 border-y border-white/10">
      <div class="flex items-center gap-4 group">
        <span class="material-symbols-outlined text-primary-fixed text-4xl group-hover:rotate-12 transition-transform">cloud_download</span>
        <div>
          <h4 class="font-bold text-xs text-white">INSTANT DOWNLOAD</h4>
          <p class="text-[10px] opacity-40">Get notes instantly</p>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <span class="material-symbols-outlined text-primary-fixed text-4xl group-hover:rotate-12 transition-transform">verified_user</span>
        <div>
          <h4 class="font-bold text-xs text-white">SAFE PAYMENT</h4>
          <p class="text-[10px] opacity-40">Secure checkout</p>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <span class="material-symbols-outlined text-primary-fixed text-4xl group-hover:rotate-12 transition-transform">picture_as_pdf</span>
        <div>
          <h4 class="font-bold text-xs text-white">EXAM FOCUSED</h4>
          <p class="text-[10px] opacity-40">High quality PDFs</p>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <span class="material-symbols-outlined text-primary-fixed text-4xl group-hover:rotate-12 transition-transform">headset_mic</span>
        <div>
          <h4 class="font-bold text-xs text-white">SUPPORT</h4>
          <p class="text-[10px] opacity-40">Available 24/7</p>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
      <div class="flex items-center gap-4">
        <span class="text-white/40 text-[10px] font-medium tracking-[0.2em] uppercase">Dream it. Plan it. Study it.</span>
      </div>
      <p class="text-[10px] opacity-40">© 2025 TGPCOP NOTES. All Rights Reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Branded Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_banner",
      "label": "Community Banner Image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner Click Link"
    }
  ]
}
{% endschema %}
