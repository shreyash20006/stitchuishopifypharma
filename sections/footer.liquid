<footer class="bg-inverse-surface text-surface-variant pt-20 pb-10 rounded-t-[40px] mt-stack-lg">
  <div class="max-w-container-max mx-auto px-margin-desktop grid grid-cols-1 md:grid-cols-4 gap-gutter mb-16">
    <div class="space-y-6">
      <a class="inline-block" href="/">
        {%- if section.settings.footer_logo != blank -%}
          <img src="{{ section.settings.footer_logo | image_url: width: 200 }}" class="h-16 w-auto object-contain brightness-0 invert">
        {%- else -%}
          <span class="text-white font-bold text-2xl">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      <p class="text-base text-surface-variant/80">
        {{ section.settings.bio }}
      </p>
      <div class="flex gap-4">
        {%- if settings.social_instagram_link != blank -%}
          <a class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary transition-all" href="{{ settings.social_instagram_link }}">
            <span class="material-symbols-outlined text-[20px]">camera</span>
          </a>
        {%- endif -%}
        {%- if settings.social_telegram_link != blank -%}
          <a class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary transition-all" href="{{ settings.social_telegram_link }}">
            <span class="material-symbols-outlined text-[20px]">social_leaderboard</span>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- for linklist in section.settings.menus -%}
      <div>
        <h4 class="text-white font-bold mb-6">{{ linklists[linklist].title }}</h4>
        <ul class="space-y-4 text-base">
          {%- for link in linklists[linklist].links -%}
            <li><a class="hover:text-primary-fixed transition-colors" href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endfor -%}

    <div>
      <h4 class="text-white font-bold mb-6">Newsletter</h4>
      <p class="text-base mb-4 text-surface-variant/80">Get the latest pharmacy news and study tips.</p>
      {%- form 'customer', class: 'space-y-4' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input class="w-full bg-white/5 border-white/10 rounded-xl px-4 py-3 text-white focus:ring-primary focus:border-primary" 
               placeholder="Enter your email" 
               type="email"
               name="contact[email]"
               required>
        <button type="submit" class="w-full bg-primary text-on-primary py-3 rounded-xl font-bold hover:bg-primary/90 transition-all">Subscribe</button>
      {%- endform -%}
    </div>
  </div>
  <div class="max-w-container-max mx-auto px-margin-desktop pt-8 border-t border-white/10 text-center">
    <p class="text-sm text-surface-variant/50">© {{ 'now' | date: "%Y" }} {{ shop.name }}. {{ section.settings.copyright_text }}</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "bio",
      "label": "Store Bio",
      "default": "Empowering Pharmacy Excellence through curated, high-quality handwritten notes and GPAT resources."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Empowering Pharmacy Excellence. Built for Students, by Students."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
