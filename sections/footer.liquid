<footer class="w-full mt-20 bg-gradient-to-br from-[#004429] to-[#002111] text-surface-variant pt-16 pb-8 px-margin-mobile md:px-margin-desktop border-t border-white/5">
  <div class="max-w-container-max mx-auto space-y-16">
    
    <!-- Follow Community Image -->
    <div class="w-full rounded-3xl overflow-hidden shadow-2xl border border-white/10 group">
      {%- if section.settings.footer_banner != blank -%}
        <a href="{{ section.settings.banner_link | default: '#' }}" class="block overflow-hidden">
          <img src="{{ section.settings.footer_banner | image_url: width: 2000 }}" 
               alt="TGPCOP Community" 
               class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.03]">
        </a>
      {%- else -%}
        <div class="w-full py-20 bg-white/5 flex flex-col items-center justify-center border-2 border-dashed border-white/20 rounded-2xl">
          <span class="material-symbols-outlined text-5xl mb-4 opacity-40 text-primary-fixed">image</span>
          <p class="font-bold opacity-60 text-primary-fixed">Click "Select Image" in Footer settings to add your banner</p>
        </div>
      {%- endif -%}
      
      <div class="bg-black/20 backdrop-blur-md p-4 flex flex-wrap justify-center gap-6 text-[11px] uppercase tracking-[0.2em] text-primary-fixed font-black">
        <a href="https://whatsapp.com/channel/0029Vb7bPYAICVfklGHiIW0v" target="_blank" class="hover:text-white transition-colors">WhatsApp</a>
        <a href="https://t.me/tgpcopnotes" target="_blank" class="hover:text-white transition-colors">Telegram</a>
        <a href="https://instagram.com/tgpcop.notes" target="_blank" class="hover:text-white transition-colors">Instagram</a>
        <a href="https://x.com/TGPCOPNOTES" target="_blank" class="hover:text-white transition-colors">X (Twitter)</a>
        <a href="https://pin.it/6Df5gqrxL" target="_blank" class="hover:text-white transition-colors">Pinterest</a>
      </div>
    </div>

    <!-- Main Footer Columns -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8 pt-4">
      <!-- Brand Column -->
      <div class="space-y-6">
        <h3 class="text-white font-black text-2xl tracking-tighter">{{ section.settings.brand_name | default: 'TGPCOP NOTES' }}</h3>
        <p class="text-sm leading-relaxed text-white/60 max-w-xs">
          {{ section.settings.brand_description }}
        </p>
      </div>

      <!-- Quick Navigation -->
      <div class="space-y-6">
        <h4 class="text-primary-fixed font-black text-xs uppercase tracking-widest">{{ section.settings.menu_1_title | default: 'Explore' }}</h4>
        <nav class="flex flex-col gap-4">
          {%- for link in section.settings.menu_1.links -%}
            <a href="{{ link.url }}" class="text-sm text-white/70 hover:text-white hover:translate-x-1 transition-all">{{ link.title }}</a>
          {%- endfor -%}
        </nav>
      </div>

      <!-- Professional Policies -->
      <div class="space-y-6">
        <h4 class="text-primary-fixed font-black text-xs uppercase tracking-widest">{{ section.settings.menu_2_title | default: 'Policies' }}</h4>
        <nav class="flex flex-col gap-4">
          {%- for link in section.settings.menu_2.links -%}
            <a href="{{ link.url }}" class="text-sm text-white/70 hover:text-white hover:translate-x-1 transition-all">{{ link.title }}</a>
          {%- endfor -%}
        </nav>
      </div>

      <!-- Contact Support -->
      <div class="space-y-6">
        <h4 class="text-primary-fixed font-black text-xs uppercase tracking-widest">{{ section.settings.contact_title | default: 'Support' }}</h4>
        <div class="space-y-4">
          {%- if section.settings.contact_email != blank -%}
            <a href="mailto:{{ section.settings.contact_email }}" class="flex items-center gap-3 text-sm text-white/70 group">
              <span class="material-symbols-outlined text-primary-fixed group-hover:scale-110 transition-transform">mail</span>
              {{ section.settings.contact_email }}
            </a>
          {%- endif -%}
          {%- if section.settings.contact_link != blank -%}
            <a href="{{ section.settings.contact_link }}" class="flex items-center gap-3 text-sm text-white/70 group">
              <span class="material-symbols-outlined text-primary-fixed group-hover:scale-110 transition-transform">location_on</span>
              {{ section.settings.contact_link_text | default: 'Contact Information' }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Trust Badges -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 py-12 border-y border-white/10">
      <div class="flex items-center gap-4 group">
        <span class="material-symbols-outlined text-primary-fixed text-4xl group-hover:rotate-12 transition-transform">cloud_download</span>
        <div>
          <h4 class="font-black text-[10px] text-white uppercase tracking-wider">INSTANT DOWNLOAD</h4>
          <p class="text-[10px] text-white/40 uppercase">Get notes instantly</p>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <span class="material-symbols-outlined text-primary-fixed text-4xl group-hover:rotate-12 transition-transform">verified_user</span>
        <div>
          <h4 class="font-black text-[10px] text-white uppercase tracking-wider">SAFE PAYMENT</h4>
          <p class="text-[10px] text-white/40 uppercase">Secure checkout</p>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <span class="material-symbols-outlined text-primary-fixed text-4xl group-hover:rotate-12 transition-transform">picture_as_pdf</span>
        <div>
          <h4 class="font-black text-[10px] text-white uppercase tracking-wider">EXAM FOCUSED</h4>
          <p class="text-[10px] text-white/40 uppercase">High quality PDFs</p>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <span class="material-symbols-outlined text-primary-fixed text-4xl group-hover:rotate-12 transition-transform">headset_mic</span>
        <div>
          <h4 class="font-black text-[10px] text-white uppercase tracking-wider">SUPPORT</h4>
          <p class="text-[10px] text-white/40 uppercase">Available 24/7</p>
        </div>
      </div>
    </div>

    <!-- Dynamic Payment Icons Section -->
    <div class="flex flex-col items-center gap-8 py-4">
      <div class="flex flex-wrap justify-center items-center gap-4 md:gap-6">
        {%- if section.settings.pay_visa != blank -%}
          <div class="bg-white p-2 md:p-3 rounded-lg shadow-xl border border-white/10 flex items-center justify-center min-w-[60px] md:min-w-[80px] h-10 md:h-12 hover:-translate-y-1 transition-all duration-300">
            <img src="{{ section.settings.pay_visa | image_url: height: 60 }}" alt="Visa" class="h-5 md:h-7 w-auto object-contain">
          </div>
        {%- endif -%}
        {%- if section.settings.pay_mastercard != blank -%}
          <div class="bg-white p-2 md:p-3 rounded-lg shadow-xl border border-white/10 flex items-center justify-center min-w-[60px] md:min-w-[80px] h-10 md:h-12 hover:-translate-y-1 transition-all duration-300">
            <img src="{{ section.settings.pay_mastercard | image_url: height: 60 }}" alt="Mastercard" class="h-5 md:h-7 w-auto object-contain">
          </div>
        {%- endif -%}
        {%- if section.settings.pay_rupay != blank -%}
          <div class="bg-white p-2 md:p-3 rounded-lg shadow-xl border border-white/10 flex items-center justify-center min-w-[60px] md:min-w-[80px] h-10 md:h-12 hover:-translate-y-1 transition-all duration-300">
            <img src="{{ section.settings.pay_rupay | image_url: height: 60 }}" alt="RuPay" class="h-5 md:h-7 w-auto object-contain">
          </div>
        {%- endif -%}
        {%- if section.settings.pay_upi != blank -%}
          <div class="bg-white p-2 md:p-3 rounded-lg shadow-xl border border-white/10 flex items-center justify-center min-w-[60px] md:min-w-[80px] h-10 md:h-12 hover:-translate-y-1 transition-all duration-300">
            <img src="{{ section.settings.pay_upi | image_url: height: 60 }}" alt="UPI" class="h-5 md:h-7 w-auto object-contain">
          </div>
        {%- endif -%}
        {%- if section.settings.pay_razorpay != blank -%}
          <div class="bg-white p-2 md:p-3 rounded-lg shadow-xl border border-white/10 flex items-center justify-center min-w-[60px] md:min-w-[80px] h-10 md:h-12 hover:-translate-y-1 transition-all duration-300">
            <img src="{{ section.settings.pay_razorpay | image_url: height: 60 }}" alt="Razorpay" class="h-5 md:h-7 w-auto object-contain">
          </div>
        {%- endif -%}
        {%- if section.settings.pay_cashfree != blank -%}
          <div class="bg-white p-2 md:p-3 rounded-lg shadow-xl border border-white/10 flex items-center justify-center min-w-[60px] md:min-w-[80px] h-10 md:h-12 hover:-translate-y-1 transition-all duration-300">
            <img src="{{ section.settings.pay_cashfree | image_url: height: 60 }}" alt="Cashfree" class="h-5 md:h-7 w-auto object-contain">
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 pt-8 border-t border-white/5">
      <p class="text-[10px] text-white/30 uppercase tracking-[0.3em] font-medium">Dream it. Plan it. Study it.</p>
      <p class="text-[10px] text-white/30 tracking-wider">© 2025 TGPCOP NOTES. All Rights Reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "TGPCOP Branded Footer",
  "settings": [
    {
      "type": "header",
      "content": "Branding Content"
    },
    {
      "type": "image_picker",
      "id": "footer_banner",
      "label": "Community Banner Image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner Click Link"
    },
    {
      "type": "header",
      "content": "Footer Navigation"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "TGPCOP NOTES"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description",
      "default": "Empowering pharmacy students across India with premium, exam-focused handwritten notes and GPAT study materials."
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Menu 1 Title",
      "default": "Explore"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu 1"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Menu 2 Title",
      "default": "Policies"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2"
    },
    {
      "type": "header",
      "content": "Contact Support"
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Contact Title",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact Email",
      "default": "contact@tgpcoppharma.shop"
    },
    {
      "type": "text",
      "id": "contact_link_text",
      "label": "Contact Link Text",
      "default": "Contact Information"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact Link"
    },
    {
      "type": "header",
      "content": "Payment Logos (Colorful PNGs recommended)"
    },
    {
      "type": "image_picker",
      "id": "pay_visa",
      "label": "1. Visa Logo"
    },
    {
      "type": "image_picker",
      "id": "pay_mastercard",
      "label": "2. MasterCard Logo"
    },
    {
      "type": "image_picker",
      "id": "pay_rupay",
      "label": "3. RuPay Logo"
    },
    {
      "type": "image_picker",
      "id": "pay_upi",
      "label": "4. UPI Logo"
    },
    {
      "type": "image_picker",
      "id": "pay_razorpay",
      "label": "5. Razorpay Logo"
    },
    {
      "type": "image_picker",
      "id": "pay_cashfree",
      "label": "6. Cashfree Logo"
    }
  ]
}
{% endschema %}
