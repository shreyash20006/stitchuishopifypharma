<div id="cart-drawer-overlay" class="fixed inset-0 bg-black/60 z-[100] backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-500"></div>

<div id="cart-drawer" class="fixed top-0 right-0 h-full w-full max-w-[450px] bg-white z-[101] translate-x-full transition-transform duration-500 ease-in-out shadow-[-20px_0_50px_rgba(0,0,0,0.1)] flex flex-col">
  
  <!-- Header -->
  <div class="p-6 md:p-8 border-b border-gray-100 flex justify-between items-center bg-white sticky top-0 z-10">
    <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-[#004429] text-3xl">shopping_basket</span>
      <h2 class="text-2xl font-black text-[#141b2b] tracking-tight">Your Cart</h2>
      <span id="cart-count-badge" class="bg-[#004429] text-white text-[10px] font-black px-2.5 py-1 rounded-full">{{ cart.item_count }}</span>
    </div>
    <button id="cart-drawer-close" class="p-2.5 hover:bg-gray-100 rounded-full transition-all text-gray-400 hover:text-gray-900">
      <span class="material-symbols-outlined text-[28px]">close</span>
    </button>
  </div>

  <!-- Content Area -->
  <div id="cart-drawer-items" class="flex-grow overflow-y-auto p-6 md:p-8 space-y-6 no-scrollbar">
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="flex gap-6 group relative" data-id="{{ item.key }}">
          <div class="w-24 h-32 rounded-2xl overflow-hidden bg-gray-50 flex-shrink-0 border border-gray-100">
            <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title }}" class="w-full h-full object-cover">
          </div>
          <div class="flex-grow py-1">
            <h3 class="text-lg font-black text-[#141b2b] leading-tight mb-1 group-hover:text-[#004429] transition-colors">
              {{ item.product.title }}
            </h3>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Digital Ebook • PDF</p>
            
            <div class="flex items-center justify-between">
              <span class="text-xl font-black text-[#004429]">{{ item.final_line_price | money }}</span>
              <button class="remove-cart-item p-2 text-gray-300 hover:text-error transition-colors" data-key="{{ item.key }}">
                <span class="material-symbols-outlined text-[20px]">delete</span>
              </button>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="h-full flex flex-col items-center justify-center text-center p-10 opacity-40">
        <span class="material-symbols-outlined text-[100px] mb-6">shopping_cart_off</span>
        <p class="text-xl font-black text-[#141b2b]">Your cart is empty</p>
        <p class="text-sm font-bold text-gray-500 mt-2">Start adding some notes to get started!</p>
        <a href="/collections/all" class="mt-8 px-8 py-3 bg-[#004429] text-white rounded-xl font-black shadow-lg">Browse Catalog</a>
      </div>
    {%- endif -%}
  </div>

  <!-- Footer -->
  {%- if cart.item_count > 0 -%}
    <div class="p-8 border-t border-gray-100 bg-white space-y-6">
      <div class="flex justify-between items-end">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-[0.2em] mb-1">Total Amount</p>
          <p class="text-3xl font-black text-[#141b2b]">{{ cart.total_price | money }}</p>
        </div>
        <div class="text-right">
          <p class="text-[10px] font-bold text-[#004429] bg-[#00442910] px-3 py-1 rounded-full">SECURE CHECKOUT</p>
        </div>
      </div>

      <div class="space-y-3">
        <a href="/pages/checkout" class="w-full py-5 rounded-2xl bg-[#004429] text-white font-black text-lg shadow-xl hover:bg-[#003320] transition-all flex items-center justify-center gap-3 active:scale-[0.98]">
          <span class="material-symbols-outlined">lock</span>
          CHECKOUT NOW
        </a>
        <button id="continue-shopping" class="w-full py-4 text-sm font-black text-gray-400 hover:text-[#004429] transition-colors">
          CONTINUE SHOPPING
        </button>
      </div>

      <div class="flex items-center justify-center gap-4 opacity-40 grayscale">
        <img src="https://cdn.shopify.com/s/files/1/0611/8411/4844/files/visa.png?v=1645445201" class="h-4 w-auto" alt="Visa">
        <img src="https://cdn.shopify.com/s/files/1/0611/8411/4844/files/mastercard.png?v=1645445201" class="h-4 w-auto" alt="Mastercard">
        <img src="https://cdn.shopify.com/s/files/1/0611/8411/4844/files/upi.png?v=1645445201" class="h-6 w-auto" alt="UPI">
      </div>
    </div>
  {%- endif -%}
</div>

<div id="cart-toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] bg-[#141b2b] text-white px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-4 translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
  <div class="w-8 h-8 bg-[#004429] rounded-full flex items-center justify-center">
    <span class="material-symbols-outlined text-[18px]">check</span>
  </div>
  <span class="font-bold tracking-tight">Added to Cart! 🛒</span>
</div>

<style>
  #cart-drawer.open { transform: translateX(0); }
  #cart-drawer-overlay.open { opacity: 1; pointer-events: auto; }
  #cart-toast.active { transform: translateY(0) translateX(-50%); opacity: 1; }
</style>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
