<section class="py-24 bg-white dark:bg-[#0A0F0D] transition-colors border-t border-gray-100 dark:border-[#1F362A]/30 overflow-hidden">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="flex justify-between items-center mb-16">
      <div>
        <h2 class="text-4xl md:text-6xl font-black text-[#001D11] dark:text-[#EDF7F2] tracking-tight">{{ section.settings.title }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="text-lg text-on-surface-variant/80 dark:text-[#9EAF9F]/70 font-medium mt-2 leading-relaxed">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      <div class="flex gap-4">
        <button class="slider-prev w-12 h-12 rounded-full border border-[#004429]/20 dark:border-[#8ad4a8]/30 flex items-center justify-center bg-white dark:bg-[#0E1612] text-[#004429] dark:text-[#8ad4a8] hover:bg-[#004429] dark:hover:bg-[#0b5d3b] hover:text-white dark:hover:text-white transition-all group shadow-sm">
          <span class="material-symbols-outlined font-bold transition-transform group-hover:-translate-x-1">chevron_left</span>
        </button>
        <button class="slider-next w-12 h-12 rounded-full border border-[#004429]/20 dark:border-[#8ad4a8]/30 flex items-center justify-center bg-white dark:bg-[#0E1612] text-[#004429] dark:text-[#8ad4a8] hover:bg-[#004429] dark:hover:bg-[#0b5d3b] hover:text-white dark:hover:text-white transition-all group shadow-sm">
          <span class="material-symbols-outlined font-bold transition-transform group-hover:translate-x-1">chevron_right</span>
        </button>
      </div>
    </div>

    <div class="product-slider flex gap-8 overflow-x-auto pb-12 snap-x no-scrollbar -mx-4 px-4">
      {%- assign products_rendered = 0 -%}
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            <div class="min-w-[280px] md:min-w-[340px] lg:min-w-[380px] snap-start" {{ block.shopify_attributes }}>
              {% render 'product-card', product: block.settings.product %}
            </div>
            {%- assign products_rendered = products_rendered | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if products_rendered == 0 -%}
        <!-- Fallback: Automatically render actual products if no blocks are manually selected -->
        {%- if collections.all.products_count > 0 -%}
          {%- for product in collections.all.products limit: 8 -%}
            <div class="min-w-[280px] md:min-w-[340px] lg:min-w-[380px] snap-start">
              {% render 'product-card', product: product %}
            </div>
          {%- endfor -%}
        {%- else -%}
          <!-- Empty state placeholder -->
          {%- for i in (1..4) -%}
            <div class="min-w-[300px] aspect-[3/4] bg-gray-100 dark:bg-white/5 rounded-[40px] animate-pulse"></div>
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    </div>
    
    {% if section.settings.view_all_link != blank %}
      <div class="mt-12 text-center md:hidden">
        <a href="{{ section.settings.view_all_link }}" class="inline-block bg-[#004429] dark:bg-[#0b5d3b] text-white px-8 py-4 rounded-2xl font-bold hover:shadow-lg transition-all active:scale-95">
          {{ section.settings.view_all_text }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .product-slider { scroll-behavior: smooth; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sliders = document.querySelectorAll('.product-slider');
    sliders.forEach(slider => {
      const parent = slider.closest('section');
      const prev = parent.querySelector('.slider-prev');
      const next = parent.querySelector('.slider-next');
      
      if (prev && next) {
        prev.addEventListener('click', () => {
          slider.scrollBy({ left: -400, behavior: 'smooth' });
        });
        next.addEventListener('click', () => {
          slider.scrollBy({ left: 400, behavior: 'smooth' });
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Manual Product Showcase",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Bestsellers This Week"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Most downloaded notes and exam guides."
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Mobile Button Text",
      "default": "Shop All Notes"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "Mobile Button Link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Selected Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bestsellers Slider",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
