<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="flex justify-between items-center mb-16">
      <div>
        <h2 class="text-3xl md:text-5xl font-black text-[#141b2b]">{{ section.settings.title }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="text-gray-500 font-medium text-lg mt-2">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      <div class="flex gap-4">
        <button class="slider-prev w-12 h-12 rounded-full border-2 border-gray-100 flex items-center justify-center hover:bg-[#004429] hover:text-white hover:border-[#004429] transition-all group shadow-sm">
          <span class="material-symbols-outlined font-bold transition-transform group-hover:-translate-x-1">chevron_left</span>
        </button>
        <button class="slider-next w-12 h-12 rounded-full border-2 border-gray-100 flex items-center justify-center hover:bg-[#004429] hover:text-white hover:border-[#004429] transition-all group shadow-sm">
          <span class="material-symbols-outlined font-bold transition-transform group-hover:translate-x-1">chevron_right</span>
        </button>
      </div>
    </div>

    <div class="product-slider flex gap-8 overflow-x-auto pb-12 snap-x no-scrollbar -mx-4 px-4">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            <div class="min-w-[280px] md:min-w-[340px] lg:min-w-[380px] snap-start" {{ block.shopify_attributes }}>
              {% render 'product-card', product: block.settings.product %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <!-- Empty state placeholder -->
        {%- for i in (1..4) -%}
          <div class="min-w-[300px] aspect-[3/4] bg-gray-100 rounded-[40px] animate-pulse"></div>
        {%- endfor -%}
      {%- endif -%}
    </div>
    
    {% if section.settings.view_all_link != blank %}
      <div class="mt-12 text-center md:hidden">
        <a href="{{ section.settings.view_all_link }}" class="inline-block bg-[#004429] text-white px-8 py-4 rounded-2xl font-bold">
          {{ section.settings.view_all_text }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .product-slider { scroll-behavior: smooth; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sliders = document.querySelectorAll('.product-slider');
    sliders.forEach(slider => {
      const parent = slider.closest('section');
      const prev = parent.querySelector('.slider-prev');
      const next = parent.querySelector('.slider-next');
      
      if (prev && next) {
        prev.addEventListener('click', () => {
          slider.scrollBy({ left: -400, behavior: 'smooth' });
        });
        next.addEventListener('click', () => {
          slider.scrollBy({ left: 400, behavior: 'smooth' });
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Manual Product Showcase",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Bestsellers This Week"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Most downloaded notes and exam guides."
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Mobile Button Text",
      "default": "Shop All Notes"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "Mobile Button Link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Selected Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bestsellers Slider",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
