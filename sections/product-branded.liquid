<main class="pt-24 pb-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
    <!-- Image Gallery -->
    <div class="lg:col-span-7 space-y-6">
      <div class="aspect-[4/5] rounded-3xl overflow-hidden glass-card">
        <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title }}" class="w-full h-full object-cover">
      </div>
      <div class="grid grid-cols-4 gap-4">
        {%- for image in product.images limit: 4 -%}
          <div class="aspect-square rounded-2xl overflow-hidden glass-card cursor-pointer hover:border-primary transition-all">
            <img src="{{ image | image_url: width: 300 }}" alt="{{ product.title }}" class="w-full h-full object-cover">
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- Product Info -->
    <div class="lg:col-span-5 space-y-8 sticky top-24 h-fit">
      <div class="space-y-4">
        <div class="flex items-center gap-4">
          <span class="bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest">PCI New Syllabus</span>
          <div class="flex text-tertiary">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-on-surface leading-tight">{{ product.title }}</h1>
        <div class="flex items-end gap-4">
          <span class="text-3xl font-bold text-primary">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="text-xl text-on-surface-variant line-through mb-1">{{ product.compare_at_price | money }}</span>
            <span class="bg-error/10 text-error px-3 py-1 rounded-lg text-sm font-bold mb-1">Save {{ product.compare_at_price | minus: product.price | money }}</span>
          {%- endif -%}
        </div>
      </div>

      <div class="flex items-start gap-4 p-4 rounded-2xl bg-primary/5 border border-primary/10">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">verified</span>
        <div>
          <p class="font-bold text-sm text-on-surface">Verified Academic Content</p>
          <p class="text-sm text-on-surface-variant">Instant PDF delivery. Access your notes immediately after payment.</p>
        </div>
      </div>

      <p class="text-lg text-on-surface-variant leading-relaxed">
        {{ product.description }}
      </p>

      <div class="space-y-4 pt-6">
        <form action="/cart/add" method="post" enctype="multipart/form-data" class="space-y-4">
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          <input type="hidden" name="quantity" value="1">
          
          <button type="submit" class="w-full py-4 rounded-xl bg-primary text-white font-bold hover:bg-primary/90 transition-all shadow-lg flex items-center justify-center gap-2">
            <span class="material-symbols-outlined">shopping_cart</span>
            ADD TO CART - {{ product.price | money }}
          </button>
          
          <button type="button" onclick="location.href='/checkout'" class="w-full py-4 rounded-xl bg-white border-2 border-primary text-primary font-bold hover:bg-primary/5 transition-all">
            BUY IT NOW
          </button>
        </form>
      </div>

      <div class="pt-6 space-y-4 border-t border-outline-variant">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
          <span class="text-sm text-on-surface-variant">PCI Syllabus Aligned (Latest 2024)</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
          <span class="text-sm text-on-surface-variant">Hand-drawn Mechanism Diagrams</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
          <span class="text-sm text-on-surface-variant">GPAT Focused Quick-Recall Points</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bento Features Grid -->
  <section class="mt-32 space-y-12">
    <div class="text-center space-y-4">
      <h2 class="text-3xl md:text-4xl font-bold">Why study with TGPCOP?</h2>
      <p class="text-on-surface-variant">Optimized for rapid understanding and exam success.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-2 glass-card p-10 rounded-3xl space-y-6 bg-gradient-to-br from-white/80 to-primary/5">
        <span class="material-symbols-outlined text-5xl text-primary">psychology</span>
        <h3 class="text-2xl font-bold">Visual Learning Strategy</h3>
        <p class="text-on-surface-variant leading-relaxed">Our notes use hierarchical information design and mnemonic anchors to help you remember complex drug classifications and chemical structures with 70% less effort.</p>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/50 p-4 rounded-2xl border border-white">
            <p class="font-bold text-primary">70%</p>
            <p class="text-xs">Faster Recall</p>
          </div>
          <div class="bg-white/50 p-4 rounded-2xl border border-white">
            <p class="font-bold text-primary">100%</p>
            <p class="text-xs">Syllabus Coverage</p>
          </div>
        </div>
      </div>
      <div class="glass-card p-10 rounded-3xl space-y-6 bg-surface-container-low">
        <span class="material-symbols-outlined text-5xl text-tertiary">bolt</span>
        <h3 class="text-2xl font-bold">Quick Revision</h3>
        <p class="text-on-surface-variant">Summary tables at the end of every chapter for last-minute exam preparation.</p>
        <div class="aspect-video rounded-2xl overflow-hidden bg-primary/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-4xl opacity-20">table_view</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Student Reviews -->
  <section class="mt-32 space-y-12">
    <div class="flex flex-col md:flex-row justify-between items-end gap-6 border-b border-outline-variant pb-8">
      <div class="space-y-4">
        <h2 class="text-3xl md:text-4xl font-bold">What Students Say</h2>
        <p class="text-lg text-on-surface-variant">Trusted by over 5,000+ Pharmacy students across India.</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="p-6 rounded-xl glass-card space-y-4 border border-border-subtle">
            <div class="flex gap-1 text-primary">
              {%- for i in (1..block.settings.rating) -%}
                <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
              {%- endfor -%}
            </div>
            <p class="text-sm text-on-surface italic">"{{ block.settings.content }}"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary-container text-white flex items-center justify-center font-bold">
                {{ block.settings.author | slice: 0, 2 | upcase }}
              </div>
              <div>
                <p class="font-bold text-sm">{{ block.settings.author }}</p>
                <p class="text-[12px] text-on-surface-variant">{{ block.settings.author_info }}</p>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
</main>

<!-- Sticky Purchase Bar -->
<div class="fixed bottom-0 left-0 w-full bg-surface border-t border-outline-variant px-margin-mobile py-3 md:hidden z-50 flex items-center justify-between shadow-2xl">
  <div class="flex flex-col">
    {%- if product.compare_at_price > product.price -%}
      <span class="text-[12px] text-on-surface-variant line-through">{{ product.compare_at_price | money }}</span>
    {%- endif -%}
    <span class="font-bold text-[20px] text-primary">{{ product.price | money }}</span>
  </div>
  <form action="/cart/add" method="post" enctype="multipart/form-data">
    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
    <button type="submit" class="px-8 py-3 rounded-xl bg-primary text-white font-bold shadow-lg active:scale-95 transition-all flex items-center gap-2">
      <span class="material-symbols-outlined text-sm">shopping_cart</span>
      Add
    </button>
  </form>
</div>

{% schema %}
{
  "name": "Branded Product",
  "settings": [],
  "blocks": [
    {
      "type": "review",
      "name": "Student Review",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Student Name",
          "default": "Aditya Sharma"
        },
        {
          "type": "text",
          "id": "author_info",
          "label": "Semester/College",
          "default": "6th Sem, B.Pharm"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Review Content",
          "default": "The pharmacological classifications are so easy to remember now. Highly recommended for anyone struggling with memorization."
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Rating"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Branded Product"
    }
  ]
}
{% endschema %}
