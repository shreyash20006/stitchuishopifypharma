<section class="py-24 bg-[#F9F9FF] dark:bg-[#0A0F0D] border-y border-gray-100 dark:border-[#1F362A]/30">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="flex justify-between items-end mb-16">
      <div>
        <h2 class="text-3xl md:text-5xl font-black text-[#141b2b] dark:text-[#EDF7F2]">{{ section.settings.title }}</h2>
        <p class="text-gray-500 dark:text-[#9EAF9F]/60 font-medium text-lg mt-2">{{ section.settings.subtitle }}</p>
      </div>
      {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}" class="text-[#004429] dark:text-[#8ad4a8] font-bold hover:underline hidden md:block">{{ section.settings.link_text }} →</a>
      {% endif %}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {%- assign new_arrivals_rendered = 0 -%}
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          {%- if product != blank -%}
            <div class="flex flex-col sm:flex-row items-stretch gap-8 p-6 bg-white/70 dark:bg-[#0E1612]/70 backdrop-blur-xl rounded-[40px] border border-white/50 dark:border-[#1F362A]/50 shadow-sm hover:shadow-[0_20px_50px_rgba(0,68,41,0.15)] hover:border-[#00442920] dark:hover:border-[#8ad4a8]/30 transition-all duration-500 group" {{ block.shopify_attributes }}>
              <!-- Product Image -->
              <div class="w-full sm:w-48 h-64 flex-shrink-0 bg-[#F3F4F6] dark:bg-[#101B15] rounded-[32px] overflow-hidden relative">
                {% if product.featured_image != blank %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" 
                       alt="{{ product.title }}" 
                       class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                {% elsif block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 400 }}" 
                       alt="{{ block.settings.title }}" 
                       class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                {% else %}
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-5xl text-gray-200 dark:text-gray-700">auto_stories</span>
                  </div>
                {% endif %}
                
                <div class="absolute top-4 left-4">
                  <span class="bg-[#cfe9da] dark:bg-[#0b5d3b]/40 text-[#004429] dark:text-[#8ad4a8] text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-wider shadow-sm">
                    {{ block.settings.badge | default: 'New Arrival' }}
                  </span>
                </div>
              </div>

              <!-- Product Info -->
              <div class="flex flex-col justify-center flex-grow py-4">
                <h3 class="text-2xl font-black text-[#141b2b] dark:text-[#EDF7F2] mb-2 group-hover:text-[#004429] dark:group-hover:text-[#8ad4a8] transition-colors line-clamp-2">
                  {{ block.settings.title | default: product.title | default: 'New Product' }}
                </h3>
                <p class="text-gray-500 dark:text-[#9EAF9F]/60 font-medium leading-relaxed mb-6 line-clamp-2">
                  {{ block.settings.text | default: product.description | strip_html | truncate: 120 }}
                </p>
                
                <div class="mt-auto flex items-center justify-between border-t border-gray-100 dark:border-[#1F362A]/40 pt-6">
                  <div class="flex flex-col">
                    <span class="text-2xl font-black text-[#004429] dark:text-[#8ad4a8]">{{ product.price | money | default: '₹149' }}</span>
                    {% if product.compare_at_price > product.price %}
                      <span class="text-sm text-gray-400 dark:text-[#9EAF9F]/40 line-through font-bold">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                  </div>
                  <a href="{{ product.url | default: '#' }}" class="text-[#004429] dark:text-[#8ad4a8] font-black text-sm flex items-center gap-2 hover:translate-x-2 transition-transform">
                    {{ section.settings.button_text | default: 'View Details' }}
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
                  </a>
                </div>
              </div>
            </div>
            {%- assign new_arrivals_rendered = new_arrivals_rendered | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if new_arrivals_rendered == 0 -%}
        <!-- Fallback: Automatically render actual products if no blocks are manually selected -->
        {%- if collections.all.products_count > 0 -%}
          {%- for product in collections.all.products limit: 4 -%}
            <div class="flex flex-col sm:flex-row items-stretch gap-8 p-6 bg-white/70 dark:bg-[#0E1612]/70 backdrop-blur-xl rounded-[40px] border border-white/50 dark:border-[#1F362A]/50 shadow-sm hover:shadow-[0_20px_50px_rgba(0,68,41,0.15)] hover:border-[#00442920] dark:hover:border-[#8ad4a8]/30 transition-all duration-500 group">
              <!-- Product Image -->
              <div class="w-full sm:w-48 h-64 flex-shrink-0 bg-[#F3F4F6] dark:bg-[#101B15] rounded-[32px] overflow-hidden relative">
                {% if product.featured_image != blank %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" 
                       alt="{{ product.title }}" 
                       class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                {% else %}
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-5xl text-gray-200 dark:text-gray-750">auto_stories</span>
                  </div>
                {% endif %}
                
                <div class="absolute top-4 left-4">
                  <span class="bg-[#cfe9da] dark:bg-[#0b5d3b]/40 text-[#004429] dark:text-[#8ad4a8] text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-wider shadow-sm">
                    New Arrival
                  </span>
                </div>
              </div>

              <!-- Product Info -->
              <div class="flex flex-col justify-center flex-grow py-4">
                <h3 class="text-2xl font-black text-[#141b2b] dark:text-[#EDF7F2] mb-2 group-hover:text-[#004429] dark:group-hover:text-[#8ad4a8] transition-colors line-clamp-2">
                  {{ product.title }}
                </h3>
                <p class="text-gray-500 dark:text-[#9EAF9F]/60 font-medium leading-relaxed mb-6 line-clamp-2">
                  {{ product.description | strip_html | truncate: 120 }}
                </p>
                
                <div class="mt-auto flex items-center justify-between border-t border-gray-100 dark:border-[#1F362A]/40 pt-6">
                  <div class="flex flex-col">
                    <span class="text-2xl font-black text-[#004429] dark:text-[#8ad4a8]">{{ product.price | money }}</span>
                    {% if product.compare_at_price > product.price %}
                      <span class="text-sm text-gray-400 dark:text-[#9EAF9F]/40 line-through font-bold">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                  </div>
                  <a href="{{ product.url }}" class="text-[#004429] dark:text-[#8ad4a8] font-black text-sm flex items-center gap-2 hover:translate-x-2 transition-transform">
                    View Details
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
                  </a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          <!-- Empty onboarding grids -->
          {%- for i in (1..2) -%}
            <div class="h-64 bg-gray-100 dark:bg-[#0E1612] rounded-[40px] animate-pulse"></div>
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "New Arrivals Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "New Arrivals"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The latest updates to our curated pharmacy library."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "View All New Arrivals"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Card Link Text",
      "default": "View Details"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Override Description"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "default": "NEW ARRIVAL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New Arrivals Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
