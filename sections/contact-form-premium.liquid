<section id="contact-form" class="py-24 bg-white">
  <div class="max-w-4xl mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="bg-white rounded-[48px] p-8 md:p-16 border border-gray-100 shadow-2xl shadow-gray-200/50">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-[#0B5D3B] mb-4">Send us a Message</h2>
        <p class="text-gray-500 font-medium">We usually respond within a few hours during business days.</p>
      </div>

      {%- form 'contact' -%}
        {%- if form.posted_successfully? -%}
          <div class="bg-[#E7F5EF] text-[#0B5D3B] p-6 rounded-2xl font-bold text-center mb-8 animate-fade-in">
            <span class="material-symbols-outlined block mb-2 text-4xl">check_circle</span>
            Thank you for reaching out! We've received your message and will get back to you soon.
          </div>
        {%- elsif form.errors -%}
          <div class="bg-red-50 text-red-600 p-6 rounded-2xl font-bold mb-8">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-2">
            <label class="text-sm font-black text-[#0B5D3B] uppercase tracking-widest pl-2">Your Name</label>
            <input type="text" name="contact[name]" placeholder="Enter your name" required
                   class="w-full bg-[#F8FAF9] border-2 border-transparent focus:border-[#0B5D3B20] focus:bg-white p-5 rounded-2xl outline-none transition-all font-medium text-gray-900">
          </div>
          <div class="space-y-2">
            <label class="text-sm font-black text-[#0B5D3B] uppercase tracking-widest pl-2">Email Address</label>
            <input type="email" name="contact[email]" placeholder="example@email.com" required
                   class="w-full bg-[#F8FAF9] border-2 border-transparent focus:border-[#0B5D3B20] focus:bg-white p-5 rounded-2xl outline-none transition-all font-medium text-gray-900">
          </div>
        </div>

        <div class="mt-8 space-y-2">
          <label class="text-sm font-black text-[#0B5D3B] uppercase tracking-widest pl-2">Message</label>
          <textarea name="contact[body]" rows="6" placeholder="How can we help you today?" required
                    class="w-full bg-[#F8FAF9] border-2 border-transparent focus:border-[#0B5D3B20] focus:bg-white p-5 rounded-2xl outline-none transition-all font-medium text-gray-900 resize-none"></textarea>
        </div>

        <div class="mt-12 text-center">
          <button type="submit" class="bg-[#0B5D3B] text-white px-16 py-6 rounded-2xl font-black text-lg hover:scale-105 hover:shadow-2xl transition-all shadow-xl shadow-[#0b5d3b20]">
            Send Message
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Contact Form",
  "settings": [],
  "presets": [
    {
      "name": "Premium Contact Form"
    }
  ]
}
{% endschema %}
