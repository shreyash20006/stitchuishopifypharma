<section class="py-20 px-margin-mobile md:px-margin-desktop">
  <div class="max-w-container-max mx-auto bg-gradient-to-br from-[#072B6B] to-[#2E9E36] rounded-[48px] overflow-hidden shadow-2xl relative">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-[100px] -mr-48 -mt-48"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-black/10 rounded-full blur-[80px] -ml-32 -mb-32"></div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center p-12 md:p-24 relative z-10">
      <div class="text-white">
        <div class="flex items-center gap-6 mb-10">
          <div class="w-20 h-20 bg-white rounded-3xl p-3 shadow-xl">
            {% if section.settings.logo != blank %}
              <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="Logo" class="w-full h-full object-contain">
            {% else %}
               <span class="material-symbols-outlined text-[#2E9E36] text-5xl flex items-center justify-center h-full">groups</span>
            {% endif %}
          </div>
          <span class="text-xl font-bold tracking-tight opacity-90">{{ section.settings.badge_text }}</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black mb-8 leading-[1.1]">
          {{ section.settings.title }}
        </h2>
        
        <p class="text-lg md:text-xl text-white/80 font-medium mb-12 max-w-xl leading-relaxed">
          {{ section.settings.text }}
        </p>
        
        <a href="{{ section.settings.button_link | default: '#' }}" class="inline-flex items-center gap-4 bg-white text-[#072B6B] hover:text-[#2E9E36] px-10 py-5 rounded-2xl font-black text-lg hover:scale-105 transition-all shadow-2xl group">
          <span class="material-symbols-outlined font-bold group-hover:rotate-12 transition-transform">chat</span>
          {{ section.settings.button_text }}
        </a>
      </div>

      <div class="relative hidden lg:flex justify-center">
        <div class="absolute inset-0 bg-white/5 blur-[120px] rounded-full"></div>
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 1000 }}" 
               alt="Community" 
               class="relative z-10 w-full max-w-md drop-shadow-[0_40px_80px_rgba(0,0,0,0.3)] animate-float">
        {% else %}
          <img src="{{ 'community-milestone.png' | asset_url }}" 
               alt="TGPCOP Community Milestone" 
               class="relative z-10 w-full max-w-md drop-shadow-[0_30px_60px_rgba(7,43,107,0.25)] animate-float">
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>

{% schema %}
{
  "name": "Community Banner",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Official Community"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join Our 50K+ Strong Pharmacy Community"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Get daily MCQ polls, GPAT tips, and early access to new notes directly on your WhatsApp. No spam, just pure value."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Join WhatsApp Group"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Overlay"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    }
  ],
  "presets": [
    {
      "name": "Community Banner"
    }
  ]
}
{% endschema %}
