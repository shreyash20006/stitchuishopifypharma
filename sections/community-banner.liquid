<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-20">
  <div class="bg-[#005232] rounded-[48px] p-12 md:p-24 text-center text-white relative overflow-hidden shadow-2xl shadow-[#00442930] flex flex-col items-center">
    <!-- Background accents -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -mr-48 -mt-48"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full blur-2xl -ml-32 -mb-32"></div>

    <div class="relative z-10 max-w-2xl space-y-8 animate-fade-in">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-white/10 rounded-3xl backdrop-blur-md mb-4 border border-white/20">
        <span class="material-symbols-outlined text-4xl text-[#8ad4a8]">forum</span>
      </div>
      
      <h2 class="text-3xl md:text-5xl font-black leading-tight">{{ section.settings.title }}</h2>
      
      <p class="text-lg md:text-xl text-[#cfe9da] font-medium leading-relaxed">
        {{ section.settings.text }}
      </p>
      
      <div class="pt-4">
        <a href="{{ section.settings.link }}" class="inline-flex items-center gap-4 bg-[#8ad4a8] text-[#002111] px-12 py-6 rounded-full font-black text-lg hover:bg-white hover:scale-105 transition-all shadow-xl shadow-black/10 group">
          <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">chat_bubble</span>
          {{ section.settings.button_text }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Community Banner",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Join Our Pharmacy Community"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "Get free notes, daily quiz, and exam updates directly on your phone. Connect with over 15,000 pharmacy peers."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Join WhatsApp Group"
    },
    {
      "type": "url",
      "id": "link",
      "label": "WhatsApp Link"
    }
  ],
  "presets": [
    {
      "name": "Community Banner"
    }
  ]
}
{% endschema %}
