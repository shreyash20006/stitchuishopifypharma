{%- comment -%}
  Premium Newsletter Section
  Fully customizable dynamic section with advanced theme customizer controls.
{%- endcomment -%}

<section class="w-full relative overflow-hidden" 
         style="background-color: {{ section.settings.bg_color | default: '#ffffff' }}; 
                padding-top: {{ section.settings.padding_top | default: 80 }}px; 
                padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;">
  
  <!-- Dynamic Glow Background Elements -->
  {%- if section.settings.show_glows -%}
    <div class="absolute top-0 left-1/4 w-96 h-96 blur-[120px] rounded-full pointer-events-none" 
         style="background-color: {{ section.settings.glow_color_1 | default: '#0B5D3B' }}0d;"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 blur-[120px] rounded-full pointer-events-none" 
         style="background-color: {{ section.settings.glow_color_2 | default: '#43A047' }}0d;"></div>
  {%- endif -%}

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <div class="glass-card backdrop-blur-xl border border-white/80 shadow-[0_20px_50px_rgba(0,0,0,0.05)] rounded-[40px] p-8 md:p-16 text-center space-y-10"
         style="background-color: {{ section.settings.card_bg_color | default: 'rgba(255, 255, 255, 0.4)' }};">
      
      <!-- Logo & Badge -->
      <div class="space-y-4 flex flex-col items-center">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" class="h-12 w-auto object-contain">
        {%- else -%}
          <h2 class="text-2xl font-black tracking-tighter" style="color: {{ section.settings.primary_color | default: '#0B5D3B' }};">
            {{ section.settings.title_logo | default: 'TGPCOP NOTES' }}
          </h2>
        {%- endif -%}
        
        {%- if section.settings.badge_text != blank -%}
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider"
               style="background-color: {{ section.settings.primary_color | default: '#0B5D3B' }}15; 
                      color: {{ section.settings.primary_color | default: '#0B5D3B' }};">
            <span class="material-symbols-outlined text-sm">{{ section.settings.badge_icon | default: 'verified' }}</span>
            {{ section.settings.badge_text }}
          </div>
        {%- endif -%}
      </div>

      <!-- Content -->
      <div class="space-y-4">
        <h3 class="text-3xl md:text-4xl font-bold leading-tight" 
            style="color: {{ section.settings.text_color_heading | default: '#001D11' }};">
          {{ section.settings.heading | default: 'Stay Updated with TGPCOP NOTES 📚' }}
        </h3>
        <p class="max-w-2xl mx-auto leading-relaxed" 
           style="color: {{ section.settings.text_color_body | default: '#404942' }};">
          {{ section.settings.description | default: 'Get latest B.Pharmacy notes, exam updates, GPAT materials, discounts & important PDF uploads directly in your inbox.' }}
        </p>
      </div>

      <!-- Subscription Form -->
      <div class="max-w-lg mx-auto">
        {%- form 'customer', class: 'relative group' -%}
          <input type="hidden" name="contact[tags]" value="newsletter, brevo_sync">
          <div class="flex flex-col md:flex-row gap-3 p-2 bg-white rounded-3xl shadow-lg border border-outline-variant focus-within:border-primary transition-all"
               style="border-color: {{ section.settings.outline_color | default: '#bfc9c0' }};">
            <input 
              type="email" 
              name="contact[email]" 
              placeholder="{{ section.settings.placeholder_text | default: 'Enter your email address' }}" 
              class="flex-1 px-6 py-4 rounded-2xl outline-none text-on-surface placeholder:text-on-surface-variant/50"
              required
            >
            <button 
              type="submit" 
              class="text-white px-8 py-4 rounded-2xl font-bold transition-all active:scale-[0.98]"
              style="background: linear-gradient(135deg, {{ section.settings.btn_color_1 | default: '#0B5D3B' }}, {{ section.settings.btn_color_2 | default: '#43A047' }});"
            >
              {{ section.settings.btn_text | default: 'Subscribe Now' }}
            </button>
          </div>

          {%- if form.posted_successfully? -%}
            <p class="mt-4 font-bold flex items-center justify-center gap-2" id="newsletter-success-msg"
               style="color: {{ section.settings.primary_color | default: '#0B5D3B' }};">
              <span class="material-symbols-outlined">check_circle</span>
              {{ section.settings.success_message | default: 'Welcome to the community! Check your inbox soon.' }}
            </p>
            <script>
              // Set persistent flag to suppress other popups
              localStorage.setItem('tgpcop_subscribed', 'true');
              // Proactively hide popup elements
              document.querySelectorAll('.pushowl-optin, .brevo-popup, .jdgm-prompt').forEach(el => el.style.display = 'none');
            </script>
          {%- endif -%}
        {%- endform -%}
      </div>

      <!-- Trust Badges -->
      {%- if section.settings.trust_text != blank -%}
        <p class="text-xs font-medium text-on-surface-variant/60 flex flex-wrap justify-center gap-x-4 gap-y-2 uppercase tracking-widest">
          {{ section.settings.trust_text | default: '✅ No Spam • Instant Updates • Free Study Resources' }}
        </p>
      {%- endif -%}

      <!-- Social Integration -->
      {%- if section.settings.show_social -%}
        <div class="pt-8 border-t" style="border-color: {{ section.settings.outline_color | default: '#bfc9c0' }}40;">
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-on-surface-variant/40 mb-6">
            {{ section.settings.social_title | default: 'Join our social circles' }}
          </p>
          <div class="flex justify-center gap-6">
            {%- if settings.social_whatsapp_link != blank or section.settings.social_whatsapp_override != blank -%}
              {%- assign whatsapp_url = section.settings.social_whatsapp_override | default: settings.social_whatsapp_link -%}
              <a href="{{ whatsapp_url }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
                <i class="fa-brands fa-whatsapp text-xl text-[#25D366]"></i>
              </a>
            {%- endif -%}
            
            {%- if settings.social_telegram_link != blank or section.settings.social_telegram_override != blank -%}
              {%- assign telegram_url = section.settings.social_telegram_override | default: settings.social_telegram_link -%}
              <a href="{{ telegram_url }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
                <i class="fa-brands fa-telegram text-xl text-[#0088cc]"></i>
              </a>
            {%- endif -%}

            {%- if settings.social_instagram_link != blank or section.settings.social_instagram_override != blank -%}
              {%- assign instagram_url = section.settings.social_instagram_override | default: settings.social_instagram_link -%}
              <a href="{{ instagram_url }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
                <i class="fa-brands fa-instagram text-xl text-[#E4405F]"></i>
              </a>
            {%- endif -%}

            {%- if settings.social_twitter_link != blank or section.settings.social_twitter_override != blank -%}
              {%- assign twitter_url = section.settings.social_twitter_override | default: settings.social_twitter_link -%}
              <a href="{{ twitter_url }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
                <i class="fa-brands fa-x-twitter text-xl text-black"></i>
              </a>
            {%- endif -%}

            {%- if settings.social_pinterest_link != blank or section.settings.social_pinterest_override != blank -%}
              {%- assign pinterest_url = section.settings.social_pinterest_override | default: settings.social_pinterest_link -%}
              <a href="{{ pinterest_url }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
                <i class="fa-brands fa-pinterest text-xl text-[#BD081C]"></i>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Newsletter",
  "settings": [
    {
      "type": "header",
      "content": "Branding & Logos"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Custom Brand Logo"
    },
    {
      "type": "text",
      "id": "title_logo",
      "label": "Text Logo (Alternative)",
      "default": "TGPCOP NOTES"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Trusted by B.Pharmacy Students"
    },
    {
      "type": "text",
      "id": "badge_icon",
      "label": "Badge Material Icon",
      "default": "verified"
    },
    {
      "type": "header",
      "content": "Typography & Texts"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay Updated with TGPCOP NOTES 📚"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Get latest B.Pharmacy notes, exam updates, GPAT materials, discounts & important PDF uploads directly in your inbox."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Email Placeholder Text",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Subscribe Button Text",
      "default": "Subscribe Now"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Subscription Success Message",
      "default": "Welcome to the community! Check your inbox soon."
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust Disclaimers Text",
      "default": "✅ No Spam • Instant Updates • Free Study Resources"
    },
    {
      "type": "header",
      "content": "Colors & Layout"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Overlay",
      "default": "rgba(255, 255, 255, 0.4)"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Theme Primary Accent Color",
      "default": "#0B5D3B"
    },
    {
      "type": "color",
      "id": "text_color_heading",
      "label": "Heading Text Color",
      "default": "#001D11"
    },
    {
      "type": "color",
      "id": "text_color_body",
      "label": "Body Text Color",
      "default": "#404942"
    },
    {
      "type": "color",
      "id": "btn_color_1",
      "label": "Gradient Button Color 1",
      "default": "#0B5D3B"
    },
    {
      "type": "color",
      "id": "btn_color_2",
      "label": "Gradient Button Color 2",
      "default": "#43A047"
    },
    {
      "type": "color",
      "id": "outline_color",
      "label": "Input Borders & Outlines",
      "default": "#bfc9c0"
    },
    {
      "type": "header",
      "content": "Paddings & Glow Effects"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 140,
      "step": 10,
      "default": 80,
      "unit": "px",
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 140,
      "step": 10,
      "default": 80,
      "unit": "px",
      "label": "Padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_glows",
      "label": "Show Soft Background Light Glows",
      "default": true
    },
    {
      "type": "color",
      "id": "glow_color_1",
      "label": "Glow 1 Color Accent",
      "default": "#0B5D3B"
    },
    {
      "type": "color",
      "id": "glow_color_2",
      "label": "Glow 2 Color Accent",
      "default": "#43A047"
    },
    {
      "type": "header",
      "content": "Social Media Links Integration"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Display Social Share Circles",
      "default": true
    },
    {
      "type": "text",
      "id": "social_title",
      "label": "Social Group Title",
      "default": "Join our social circles"
    },
    {
      "type": "url",
      "id": "social_whatsapp_override",
      "label": "WhatsApp Override Link"
    },
    {
      "type": "url",
      "id": "social_telegram_override",
      "label": "Telegram Override Link"
    },
    {
      "type": "url",
      "id": "social_instagram_override",
      "label": "Instagram Override Link"
    },
    {
      "type": "url",
      "id": "social_twitter_override",
      "label": "Twitter Override Link"
    },
    {
      "type": "url",
      "id": "social_pinterest_override",
      "label": "Pinterest Override Link"
    }
  ],
  "presets": [
    {
      "name": "Premium Newsletter"
    }
  ]
}
{% endschema %}
