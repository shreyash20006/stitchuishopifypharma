<section class="w-full py-20 bg-white relative overflow-hidden">
  <!-- Soft Green Glow Background Elements -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#0B5D3B]/5 blur-[120px] rounded-full"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#43A047]/5 blur-[120px] rounded-full"></div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <div class="glass-card bg-white/40 backdrop-blur-xl border border-white/80 shadow-[0_20px_50px_rgba(0,0,0,0.05)] rounded-[40px] p-8 md:p-16 text-center space-y-10">
      
      <!-- Logo & Badge -->
      <div class="space-y-4 flex flex-col items-center">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="TGPCOP NOTES" class="h-12 w-auto object-contain">
        {%- else -%}
          <h2 class="text-2xl font-black text-[#0B5D3B] tracking-tighter">TGPCOP NOTES</h2>
        {%- endif -%}
        
        <div class="inline-flex items-center gap-2 bg-[#0B5D3B]/10 text-[#0B5D3B] px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider">
          <span class="material-symbols-outlined text-sm">verified</span>
          Trusted by B.Pharmacy Students
        </div>
      </div>

      <!-- Content -->
      <div class="space-y-4">
        <h3 class="text-3xl md:text-4xl font-bold text-[#001D11] leading-tight">
          Stay Updated with TGPCOP NOTES 📚
        </h3>
        <p class="text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
          Get latest B.Pharmacy notes, exam updates, GPAT materials, discounts & important PDF uploads directly in your inbox.
        </p>
      </div>

      <!-- Subscription Form (Brevo/Shopify Compatible) -->
      <div class="max-w-lg mx-auto">
        {%- form 'customer', class: 'relative group' -%}
          <input type="hidden" name="contact[tags]" value="newsletter, brevo_sync">
          <div class="flex flex-col md:flex-row gap-3 p-2 bg-white rounded-3xl shadow-lg border border-outline-variant focus-within:border-[#0B5D3B] transition-all">
            <input 
              type="email" 
              name="contact[email]" 
              placeholder="Enter your email address" 
              class="flex-1 px-6 py-4 rounded-2xl outline-none text-on-surface placeholder:text-on-surface-variant/50"
              required
            >
            <button 
              type="submit" 
              class="bg-gradient-to-r from-[#0B5D3B] to-[#43A047] text-white px-8 py-4 rounded-2xl font-bold hover:shadow-[0_10px_20px_rgba(11,93,59,0.3)] hover:scale-[1.02] transition-all active:scale-[0.98]"
            >
              Subscribe Now
            </button>
          </div>

          {%- if form.posted_successfully? -%}
            <p class="mt-4 text-[#0B5D3B] font-bold flex items-center justify-center gap-2">
              <span class="material-symbols-outlined">check_circle</span>
              Welcome to the community! Check your inbox soon.
            </p>
          {%- endif -%}
        {%- endform -%}
      </div>

      <!-- Trust Badges -->
      <p class="text-xs font-medium text-on-surface-variant/60 flex flex-wrap justify-center gap-x-4 gap-y-2 uppercase tracking-widest">
        <span>✅ No Spam</span>
        <span>•</span>
        <span>Instant Updates</span>
        <span>•</span>
        <span>Free Study Resources</span>
      </p>

      <!-- Social Integration -->
      <div class="pt-8 border-t border-outline-variant/30">
        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-on-surface-variant/40 mb-6">Join our social circles</p>
        <div class="flex justify-center gap-6">
          <a href="{{ settings.social_whatsapp_link }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
            <i class="fa-brands fa-whatsapp text-xl text-[#25D366]"></i>
          </a>
          <a href="{{ settings.social_telegram_link }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
            <i class="fa-brands fa-telegram text-xl text-[#0088cc]"></i>
          </a>
          <a href="{{ settings.social_instagram_link }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
            <i class="fa-brands fa-instagram text-xl text-[#E4405F]"></i>
          </a>
          <a href="{{ settings.social_twitter_link }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
            <i class="fa-brands fa-x-twitter text-xl text-black"></i>
          </a>
          <a href="{{ settings.social_pinterest_link }}" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white shadow-md border border-outline-variant hover:-translate-y-1 transition-transform group">
            <i class="fa-brands fa-pinterest text-xl text-[#BD081C]"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "TGPCOP Logo"
    }
  ],
  "presets": [
    {
      "name": "Premium Newsletter"
    }
  ]
}
{% endschema %}
