<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-24">
  <div class="text-center mb-16">
    <h2 class="text-3xl md:text-5xl font-black text-gray-900 mb-4">{{ section.settings.title }}</h2>
    <p class="text-gray-500 font-medium text-lg">{{ section.settings.subtitle }}</p>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {%- for block in section.blocks -%}
      <div class="p-10 border border-gray-100 rounded-[32px] bg-[#F8FAF9] hover:bg-white hover:border-[#00442920] hover:shadow-2xl transition-all duration-500 group" {{ block.shopify_attributes }}>
        <div class="inline-flex items-center justify-center w-16 h-16 bg-white rounded-2xl shadow-sm group-hover:scale-110 group-hover:bg-[#004429] transition-all duration-500 mb-8">
          <span class="material-symbols-outlined text-3xl text-[#004429] group-hover:text-white transition-colors">
            {{ block.settings.icon }}
          </span>
        </div>
        <h4 class="text-xl font-black text-gray-900 mb-4">{{ block.settings.title }}</h4>
        <p class="text-gray-600 leading-relaxed font-medium">
          {{ block.settings.text }}
        </p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "The TGPCOP Advantage",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "The TGPCOP Advantage"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sub-title",
      "default": "Why 10,000+ pharmacy students trust our resources"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Material Icon Name",
          "default": "edit_document"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Handwritten Content"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Authored by subject experts, maintaining a personal touch that makes complex topics easier to memorize."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "The TGPCOP Advantage",
      "blocks": [
        { "type": "feature", "settings": { "icon": "edit_document", "title": "Handwritten Content" } },
        { "type": "feature", "settings": { "icon": "target", "title": "Exam Focused" } },
        { "type": "feature", "settings": { "icon": "download_done", "title": "Instant Download" } },
        { "type": "feature", "settings": { "icon": "payments", "title": "Affordable Pricing" } },
        { "type": "feature", "settings": { "icon": "translate", "title": "Easy Language" } },
        { "type": "feature", "settings": { "icon": "auto_stories", "title": "PCI Syllabus Based" } }
      ]
    }
  ]
}
{% endschema %}
