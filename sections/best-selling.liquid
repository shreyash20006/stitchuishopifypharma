<section class="py-20 bg-background overflow-hidden">
  <div class="max-w-container-max mx-auto px-margin-desktop">
    <div class="flex justify-between items-center mb-12">
      <h2 class="font-bold text-[32px] text-on-surface">{{ section.settings.title }}</h2>
      <div class="flex gap-2">
        <button class="w-10 h-10 rounded-full border border-outline flex items-center justify-center hover:bg-surface-container transition-colors">
          <span class="material-symbols-outlined">chevron_left</span>
        </button>
        <button class="w-10 h-10 rounded-full border border-outline flex items-center justify-center hover:bg-surface-container transition-colors">
          <span class="material-symbols-outlined">chevron_right</span>
        </button>
      </div>
    </div>
    <div class="flex gap-gutter overflow-x-auto pb-8 snap-x no-scrollbar">
      {%- for product in collections[section.settings.collection].products limit: section.settings.products_to_show -%}
        <div class="min-w-[280px] md:min-w-[320px] snap-start group">
          {% render 'product-card', product: product %}
        </div>
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="min-w-[280px] md:min-w-[320px] snap-start group">
            <div class="relative bg-white rounded-2xl overflow-hidden shadow-sm border border-outline-variant">
              <div class="aspect-[3/4] bg-surface-container"></div>
              <div class="p-6">
                <div class="h-4 w-1/2 bg-surface-container-high rounded mb-2"></div>
                <div class="h-6 w-3/4 bg-surface-container-high rounded mb-4"></div>
                <div class="h-6 w-1/4 bg-surface-container-high rounded"></div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Best Selling Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Bestsellers This Week"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Best Selling Products"
    }
  ]
}
{% endschema %}
