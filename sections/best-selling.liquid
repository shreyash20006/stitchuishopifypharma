<section class="py-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto overflow-hidden">
  <div class="flex justify-between items-end mb-10">
    <div>
      <h2 class="font-bold text-[32px] text-primary">{{ section.settings.title }}</h2>
      <p class="text-on-surface-variant text-sm">{{ section.settings.subtitle }}</p>
    </div>
    <a href="{{ section.settings.collection.url }}" class="text-primary font-bold flex items-center gap-1 hover:underline">
      View All
      <span class="material-symbols-outlined">chevron_right</span>
    </a>
  </div>

  <div class="flex gap-6 overflow-x-auto pb-8 snap-x no-scrollbar">
    {%- assign collection = section.settings.collection -%}
    {%- if collection != blank and collection.products_count > 0 -%}
      {%- for product in collection.products limit: 8 -%}
        <div class="min-w-[280px] md:min-w-[320px] snap-start">
          {% render 'product-card', product: product %}
        </div>
      {%- endfor -%}
    {%- else -%}
      <!-- Fallback for empty collection during setup -->
      {%- for i in (1..4) -%}
        <div class="min-w-[280px] md:min-w-[320px] snap-start opacity-50">
          <div class="bg-surface-container h-80 rounded-2xl mb-4 animate-pulse"></div>
          <div class="h-4 bg-surface-container rounded w-3/4 mb-2"></div>
          <div class="h-4 bg-surface-container rounded w-1/2"></div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Dynamic Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Best Selling Notes"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Most loved by Pharmacy students"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }
  ],
  "presets": [
    {
      "name": "Dynamic Best Sellers"
    }
  ]
}
{% endschema %}
