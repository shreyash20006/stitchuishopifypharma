<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0B5D3B">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    {{ content_for_header }}

    {%- liquid
      assign body_font = settings.type_body_font
      assign header_font = settings.type_header_font
    -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <style>
      :root {
        --color-primary: {{ settings.colors_primary | default: '#0B5D3B' }};
        --color-primary-rgb: {{ settings.colors_primary | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-secondary: {{ settings.colors_secondary | default: '#8B5CF6' }};
        --color-background: {{ settings.colors_background | default: '#FFFFFF' }};
        --color-text: {{ settings.colors_text | default: '#1A1A1A' }};
        --color-text-muted: {{ settings.colors_text_muted | default: '#666666' }};
        --font-body: 'Inter', sans-serif;
        --font-heading: 'Manrope', sans-serif;
      }
    </style>
  </head>

  <body class="gradient">
          {{ content_for_layout }}
        </body>
      