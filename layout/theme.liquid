    <style>
      :root {
        --color-background: #F5F8FB;
        --color-on-background: #1E293B;
        --color-surface: #ffffff;
        --color-on-surface: #1E293B;
        --color-surface-container: #EAF0F6;
        --color-surface-container-low: #F0F4F8;
        --color-surface-container-lowest: #ffffff;
        --color-surface-container-high: #DCE3EA;
        --color-surface-container-highest: #CBD5E1;
        --color-outline-variant: #DCE3EA;
        --color-on-surface-variant: #475569;
        --color-surface-glass: rgba(255, 255, 255, 0.7);
        --color-border-subtle: #DCE3EA;
      }
      html.dark {
        --color-background: #070F1E;
        --color-on-background: #EAF0F6;
        --color-surface: #0F172A;
        --color-on-surface: #EAF0F6;
        --color-surface-container: #1E293B;
        --color-surface-container-low: #161F30;
        --color-surface-container-lowest: #0C1322;
        --color-surface-container-high: #2A374A;
        --color-surface-container-highest: #334155;
        --color-outline-variant: #2E3A4E;
        --color-on-surface-variant: #94A3B8;
        --color-surface-glass: rgba(15, 23, 42, 0.75);
        --color-border-subtle: #2E3A4E;
      }

      /* Base body transition */
      body {
        font-family: 'Inter', sans-serif !important;
        background-color: var(--color-background);
        color: var(--color-on-background);
        transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Outfit', 'Manrope', sans-serif !important;
        letter-spacing: -0.02em;
      }

      /* Premium Dynamic Overrides for Dark Mode */
      html.dark .bg-white,
      html.dark .bg-surface-container-lowest,
      html.dark .bg-surface {
        background-color: var(--color-surface) !important;
      }
      
      html.dark .bg-gray-50,
      html.dark .bg-surface-container-low {
        background-color: var(--color-surface-container-low) !important;
      }
      
      html.dark .bg-surface-container {
        background-color: var(--color-surface-container) !important;
      }

      html.dark .bg-gray-100 {
        background-color: var(--color-surface-container-high) !important;
      }

      html.dark .text-gray-900,
      html.dark .text-black,
      html.dark .text-on-background,
      html.dark .text-on-surface {
        color: var(--color-on-background) !important;
      }

      html.dark .text-gray-500,
      html.dark .text-gray-600,
      html.dark .text-on-surface-variant {
        color: var(--color-on-surface-variant) !important;
      }

      html.dark .border-gray-100,
      html.dark .border-gray-200,
      html.dark .border-outline-variant,
      html.dark .border-border-subtle {
        border-color: var(--color-outline-variant) !important;
      }

