    <!-- TGPCOP Control Center Activation Script -->
    <script>
      (function() {
        const adminPanel = document.getElementById('tgpcop-admin-panel');
        const adminBtn = document.getElementById('tgpcop-admin-btn');
        const adminConsole = document.getElementById('tgpcop-admin-console');
        const adminClose = document.getElementById('tgpcop-admin-close');

        if (!adminPanel) return;

        // Force check for saved unlock state
        const isUnlocked = localStorage.getItem('tgpcop_admin_unlocked') === 'true';
        if (isUnlocked) {
          adminPanel.classList.remove('hidden');
        }

        // Toggle Console Box
        if (adminBtn) {
          adminBtn.addEventListener('click', () => {
            adminConsole.classList.toggle('hidden');
            const icon = adminBtn.querySelector('.material-symbols-outlined');
            if (icon) {
              icon.style.transform = adminConsole.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(90deg)';
              icon.style.transition = 'transform 0.3s ease';
            }
          });
        }

        if (adminClose) {
          adminClose.addEventListener('click', () => {
            adminConsole.classList.add('hidden');
            const icon = adminBtn.querySelector('.material-symbols-outlined');
            if (icon) icon.style.transform = 'rotate(0deg)';
          });
        }

        // Keyboard Shortcut: Ctrl + Shift + A
        document.addEventListener('keydown', (e) => {
          if (e.ctrlKey && e.shiftKey && e.key.toLowerCase() === 'a') {
            e.preventDefault();
            toggleAdminActivation();
          }
        });

        // Logo Double Click Trigger
        const headerLogo = document.querySelector('header img');
        if (headerLogo) {
          headerLogo.style.cursor = 'pointer';
          headerLogo.addEventListener('dblclick', () => {
            toggleAdminActivation();
          });
        }

        function toggleAdminActivation() {
          const currentlyUnlocked = localStorage.getItem('tgpcop_admin_unlocked') === 'true';
          if (currentlyUnlocked) {
            localStorage.removeItem('tgpcop_admin_unlocked');
            adminPanel.classList.add('hidden');
            adminConsole.classList.add('hidden');
            console.log('🔒 TGPCOP Store Admin Toolbar Locked.');
          } else {
            localStorage.setItem('tgpcop_admin_unlocked', 'true');
            adminPanel.classList.remove('hidden');
            adminConsole.classList.remove('hidden');
            console.log('🔓 TGPCOP Store Admin Toolbar Activated!');
          }
        }
      })();
    </script>
    {% render 'ai-study-buddy' %}
  </body>
</html>
