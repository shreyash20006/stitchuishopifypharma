<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <script>
      (function() {
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.className = theme;
      })();
    </script>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <meta name="theme-color" content="#004429">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                "on-secondary-fixed-variant": "#354b41",
                "secondary": "#4c6358",
                "on-tertiary-fixed-variant": "#5a00c6",
                "outline-variant": "var(--color-outline-variant)",
                "tertiary-container": "#6616d7",
                "tertiary-fixed-dim": "#d2bbff",
                "inverse-primary": "#8dd6ab",
                "secondary-container": "#cfe9da",
                "primary-container": "#0b5d3b",
                "on-surface-variant": "var(--color-on-surface-variant)",
                "background": "var(--color-background)",
                "surface-tint": "#004429",
                "inverse-surface": "#293040",
                "surface-container": "var(--color-surface-container)",
                "primary-fixed": "#a8f3c6",
                "surface-container-highest": "var(--color-surface-container-highest)",
                "on-secondary-fixed": "#092017",
                "surface": "var(--color-surface)",
                "on-error": "#ffffff",
                "tertiary": "#4b00a7",
                "on-tertiary-fixed": "#25005a",
                "error": "#ba1a1a",
                "primary-fixed-dim": "#8dd6ab",
                "on-primary": "#ffffff",
                "on-background": "var(--color-on-background)",
                "surface-glass": "var(--color-surface-glass)",
                "surface-bright": "var(--color-surface)",
                "tertiary-fixed": "#eaddff",
                "primary": "#004429",
                "background-main": "var(--color-background)",
                "secondary-fixed-dim": "#b3ccbe",
                "surface-container-low": "var(--color-surface-container-low)",
                "on-primary-fixed": "#002111",
                "on-error-container": "#93000a",
                "inverse-on-surface": "#edf0ff",
                "surface-variant": "var(--color-surface-container)",
                "on-surface": "var(--color-on-surface)",
                "surface-container-lowest": "var(--color-surface-container-lowest)",
                "on-tertiary": "#ffffff",
                "on-secondary-container": "#52695e",
                "on-tertiary-container": "#d1b9ff",
                "surface-dim": "#d3daef",
                "error-container": "#ffdad6",
                "on-primary-container": "#8ad4a8",
                "outline": "#707a72",
                "border-subtle": "var(--color-border-subtle)",
                "on-secondary": "#ffffff",
                "on-primary-fixed-variant": "#005232",
                "surface-container-high": "var(--color-surface-container-high)",
                "secondary-fixed": "#cfe9da"
            },
            "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
            },
            "spacing": {
                "margin-mobile": "1rem",
                "container-max": "1280px",
                "gutter": "1.5rem",
                "margin-desktop": "2rem",
                "stack-md": "1rem",
                "stack-sm": "0.5rem",
                "stack-lg": "2rem"
            }
          }
        }
      }
    </script>

    <style>
      :root {
        --color-background: #F9FAFB;
        --color-on-background: #141b2b;
        --color-surface: #ffffff;
        --color-on-surface: #141b2b;
        --color-surface-container: #F1F3FF;
        --color-surface-container-low: #F8FAFC;
        --color-surface-container-lowest: #ffffff;
        --color-surface-container-high: #E2E8F0;
        --color-surface-container-highest: #DCE2F7;
        --color-outline-variant: #E5E7EB;
        --color-on-surface-variant: #4b5563;
        --color-surface-glass: rgba(255, 255, 255, 0.7);
        --color-border-subtle: #E5E7EB;
      }
      html.dark {
        --color-background: #080D0A;
        --color-on-background: #EDF7F2;
        --color-surface: #0E1612;
        --color-on-surface: #EDF7F2;
        --color-surface-container: #15221B;
        --color-surface-container-low: #101B15;
        --color-surface-container-lowest: #0B110E;
        --color-surface-container-high: #1E3027;
        --color-surface-container-highest: #283F33;
        --color-outline-variant: #1F362A;
        --color-on-surface-variant: #9EAF9F;
        --color-surface-glass: rgba(14, 22, 18, 0.75);
        --color-border-subtle: #1F362A;
      }

      /* Base body transition */
      body {
        background-color: var(--color-background);
        color: var(--color-on-background);
        transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
      }

      /* Premium Dynamic Overrides for Dark Mode */
      html.dark .bg-white,
      html.dark .bg-surface-container-lowest,
      html.dark .bg-surface {
        background-color: var(--color-surface) !important;
      }
      
      html.dark .bg-gray-50,
      html.dark .bg-surface-container-low {
        background-color: var(--color-surface-container-low) !important;
      }
      
      html.dark .bg-surface-container {
        background-color: var(--color-surface-container) !important;
      }

      html.dark .bg-gray-100 {
        background-color: var(--color-surface-container-high) !important;
      }

      html.dark .text-gray-900,
      html.dark .text-black,
      html.dark .text-on-background,
      html.dark .text-on-surface {
        color: var(--color-on-background) !important;
      }

      html.dark .text-gray-500,
      html.dark .text-gray-600,
      html.dark .text-on-surface-variant {
        color: var(--color-on-surface-variant) !important;
      }

      html.dark .border-gray-100,
      html.dark .border-gray-200,
      html.dark .border-outline-variant,
      html.dark .border-border-subtle {
        border-color: var(--color-outline-variant) !important;
      }

      html.dark header#site-header {
        background-color: rgba(14, 22, 18, 0.8) !important;
        border-bottom-color: var(--color-outline-variant) !important;
      }

      html.dark .glass-card {
        background: rgba(14, 22, 18, 0.7) !important;
        border: 1px solid rgba(31, 54, 42, 0.5) !important;
      }

      .glass-card {
          background: rgba(255, 255, 255, 0.7);
          backdrop-filter: blur(12px);
          border: 1px solid rgba(229, 231, 235, 0.5);
          transition: background 0.3s ease, border-color 0.3s ease;
      }
      .material-symbols-outlined {
          font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      /* Hide scrollbar for clean horizontal scrolling */
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

      @keyframes cart-bounce {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.3) rotate(-10deg); }
      }
      .animate-cart-bounce { animation: cart-bounce 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    </style>
    <!-- Judge.me Custom Styling -->
  <style>
    .jdgm-widget.jdgm-widget {
      --jdgm-primary-color: #004429 !important;
      --jdgm-star-color: #004429 !important;
    }
    .jdgm-rev-widg__title { font-weight: 900 !important; }
    .jdgm-preview-badge .jdgm-star { color: #004429 !important; }
  </style>
</head>

  <body class="bg-background text-on-surface font-body-md selection:bg-primary-fixed selection:text-on-primary-fixed">
    {% section 'announcement-bar' %}
    {% section 'header' %}
    {% section 'cart-drawer' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}


    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    <!-- Subscription Popup Suppression -->
    <!-- Global Cart & UX Logic -->
    <script>
      // Cart Drawer Toggle
      const cartDrawer = document.getElementById('cart-drawer');
      const cartOverlay = document.getElementById('cart-drawer-overlay');
      const cartClose = document.getElementById('cart-drawer-close');
      const cartCountBadges = document.querySelectorAll('#cart-count-badge, .cart-count-badge');
      const cartToast = document.getElementById('cart-toast');

      function openCart() {
        cartDrawer.classList.add('open');
        cartOverlay.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeCart() {
        cartDrawer.classList.remove('open');
        cartOverlay.classList.remove('open');
        document.body.style.overflow = '';
      }

      if(cartClose) cartClose.onclick = closeCart;
      if(cartOverlay) cartOverlay.onclick = closeCart;
      document.querySelectorAll('#continue-shopping').forEach(btn => btn.onclick = closeCart);

      // Intercept Add to Cart
      document.addEventListener('submit', function(e) {
        if (e.target.action && e.target.action.includes('/cart/add')) {
          e.preventDefault();
          const formData = new FormData(e.target);
          
          fetch('/cart/add.js', {
            method: 'POST',
            body: formData
          })
          .then(res => res.json())
          .then(item => {
            showToast();
            updateCartDrawer();
            animateCartIcon();
            openCart();
          })
          .catch(err => console.error('Add to cart error:', err));
        }
      });

      // Update Cart Drawer Content
      function updateCartDrawer() {
        fetch('/?section_id=cart-drawer')
          .then(res => res.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newContent = doc.getElementById('cart-drawer-items').innerHTML;
            const newFooter = doc.querySelector('#cart-drawer .p-8');
            const newCount = doc.getElementById('cart-count-badge').innerText;

            document.getElementById('cart-drawer-items').innerHTML = newContent;
            if (newFooter) {
              const currentFooter = document.querySelector('#cart-drawer .p-8');
              if (currentFooter) currentFooter.outerHTML = newFooter.outerHTML;
              else cartDrawer.appendChild(newFooter);
            } else {
              const currentFooter = document.querySelector('#cart-drawer .p-8');
              if (currentFooter) currentFooter.remove();
            }

            // Update all count badges
            document.querySelectorAll('#cart-count-badge, .cart-count-badge').forEach(badge => {
              badge.innerText = newCount;
              badge.style.display = parseInt(newCount) > 0 ? 'flex' : 'none';
            });

            bindRemoveEvents();
          });
      }

      // Remove Item Logic
      function bindRemoveEvents() {
        document.querySelectorAll('.remove-cart-item').forEach(btn => {
          btn.onclick = function() {
            const key = this.getAttribute('data-key');
            fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: key, quantity: 0 })
            })
            .then(() => updateCartDrawer())
            .catch(err => console.error('Remove error:', err));
          };
        });
      }

      function showToast() {
        cartToast.classList.add('active');
        setTimeout(() => cartToast.classList.remove('active'), 3000);
      }

      function animateCartIcon() {
        const icons = document.querySelectorAll('.material-symbols-outlined');
        icons.forEach(icon => {
          if (icon.innerText === 'shopping_cart' || icon.innerText === 'shopping_basket') {
            icon.classList.add('animate-cart-bounce');
            setTimeout(() => icon.classList.remove('animate-cart-bounce'), 500);
          }
        });
      }

      // Open cart if clicking header cart icon
      document.addEventListener('click', (e) => {
        const cartLink = e.target.closest('a[href="/cart"]');
        if (cartLink) {
          e.preventDefault();
          openCart();
        }
      });

      bindRemoveEvents();

      // Day/Night Theme Toggling & Icon Sync
      (function() {
        function updateThemeIcons(theme) {
          const darkIcons = document.querySelectorAll('.theme-toggle-dark-icon');
          const lightIcons = document.querySelectorAll('.theme-toggle-light-icon');
          if (theme === 'dark') {
            darkIcons.forEach(i => i.classList.remove('hidden'));
            lightIcons.forEach(i => i.classList.add('hidden'));
          } else {
            darkIcons.forEach(i => i.classList.add('hidden'));
            lightIcons.forEach(i => i.classList.remove('hidden'));
          }
        }

        function toggleTheme() {
          const isDark = document.documentElement.classList.contains('dark');
          const newTheme = isDark ? 'light' : 'dark';
          document.documentElement.className = newTheme;
          localStorage.setItem('theme', newTheme);
          updateThemeIcons(newTheme);
        }

        // Bind events
        function bindThemeToggles() {
          const initialTheme = localStorage.getItem('theme') || 'light';
          updateThemeIcons(initialTheme);
          document.querySelectorAll('.theme-toggle-btn').forEach(btn => {
            btn.onclick = toggleTheme;
          });
        }
        
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', bindThemeToggles);
        } else {
          bindThemeToggles();
        }
        
        // Expose function globally
        window.initializeThemeToggles = bindThemeToggles;
        window.updateThemeIcons = updateThemeIcons;
      })();
    </script>

    <script>
      (function() {
        const isSubscribed = localStorage.getItem('tgpcop_subscribed') === 'true';
        
        if (isSubscribed) {
          // Disable PushOwl auto-prompts if the object is available
          window.pushowl = window.pushowl || [];
          window.pushowl.push(['onPermissionPrompt', function() {
            return false; // Prevent prompt
          }]);

          // Proactively hide any common popup containers after they load
          const observer = new MutationObserver((mutations) => {
            document.querySelectorAll('.pushowl-optin, .brevo-popup, .newsletter-popup, #pushowl-container').forEach(el => {
              el.style.display = 'none';
              el.remove();
            });
          });

          observer.observe(document.body, { childList: true, subtree: true });
        }
      })();
    </script>
  </body>
</html>
