<section class="pt-10 pb-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
  <div class="mb-12 text-center space-y-6">
    <h1 class="text-4xl md:text-5xl font-bold text-primary">
      {% if search.performed %}
        Search results for "{{ search.terms }}"
      {% else %}
        Search our notes
      {% endif %}
    </h1>
    
    <div class="max-w-xl mx-auto relative group">
      <form action="{{ routes.search_url }}" method="get" role="search" class="relative">
        <input type="text" 
               name="q" 
               value="{{ search.terms | escape }}" 
               placeholder="Find your semester notes..." 
               class="w-full h-14 pl-14 pr-6 rounded-2xl bg-surface-container border-2 border-transparent focus:border-primary focus:bg-white transition-all outline-none text-lg">
        <span class="material-symbols-outlined absolute left-5 top-1/2 -translate-y-1/2 text-primary opacity-40 group-focus-within:opacity-100">search</span>
        <button type="submit" class="hidden">Search</button>
      </form>
    </div>
  </div>

  {% if search.performed %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-gutter">
      {% paginate search.results by 12 %}
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
              {% render 'product-card', product: item %}
            </div>
          {% endif %}
        {% else %}
          <div class="col-span-full py-20 text-center glass-card rounded-3xl">
            <span class="material-symbols-outlined text-[80px] text-primary/10 mb-6">sentiment_dissatisfied</span>
            <h2 class="font-bold text-2xl text-primary">No matching products found</h2>
            <p class="text-on-surface-variant mt-2 max-w-md mx-auto">We couldn't find anything for "{{ search.terms }}". Try using more general terms or check your spelling.</p>
            <div class="mt-8 flex justify-center gap-4">
              <a href="/collections/all" class="bg-primary text-white px-8 py-4 rounded-2xl font-bold hover:shadow-lg transition-all">Browse Catalog</a>
              <a href="/" class="bg-primary/5 text-primary px-8 py-4 rounded-2xl font-bold">Back to Home</a>
            </div>
          </div>
        {% endfor %}

        {% if paginate.pages > 1 %}
          <div class="col-span-full mt-16 flex justify-center border-t border-outline-variant pt-10">
            {{ paginate | default_pagination }}
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  {% endif %}
</section>

<style>
  .pagination {
    display: flex;
    gap: 0.5rem;
  }
  .pagination .page, .pagination .prev, .pagination .next {
    padding: 0.75rem 1.25rem;
    border-radius: 0.75rem;
    background: rgba(7, 43, 107, 0.05);
    color: #072B6B;
    font-weight: 700;
    transition: all 0.3s ease;
  }
  .pagination .page.current {
    background: #072B6B;
    color: white;
  }
  .pagination .page:hover:not(.current) {
    background: rgba(7, 43, 107, 0.1);
  }
</style>
