<section class="section-padding">
  <div class="container">
    <h1 style="margin-bottom: 40px;">Your Cart</h1>
    
    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" novalidate>
        <div style="display: flex; flex-direction: column; gap: 24px;">
          {% for item in cart.items %}
            <div style="display: flex; align-items: center; gap: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--color-border);">
              <div style="width: 100px; height: 100px; border-radius: 12px; overflow: hidden; background: var(--color-surface);">
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" style="width: 100%; height: 100%; object-fit: cover;">
              </div>
              <div style="flex: 1;">
                <h3 style="margin: 0;">{{ item.product.title }}</h3>
                <p style="margin: 4px 0; opacity: 0.7;">{{ item.price | money }}</p>
                <a href="/cart/change?line={{ forloop.index }}&quantity=0" style="color: #ef4444; font-size: 0.85rem;">Remove</a>
              </div>
              <div style="text-align: right;">
                <p style="font-weight: 800;">{{ item.final_line_price | money }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
        
        <div style="margin-top: 40px; text-align: right;">
          <h2 style="margin-bottom: 12px;">Subtotal: {{ cart.total_price | money }}</h2>
          <p style="opacity: 0.7; margin-bottom: 24px;">Taxes and shipping calculated at checkout</p>
          <button type="submit" name="checkout" class="btn btn--primary btn--lg">Checkout</button>
        </div>
      </form>
    {% else %}
      <div style="text-align: center; padding: 60px 0;">
        <p style="font-size: 1.25rem; opacity: 0.7; margin-bottom: 24px;">Your cart is empty</p>
        <a href="/collections/all" class="btn btn--primary">Continue Shopping</a>
      </div>
    {% endif %}
  </div>
</section>
